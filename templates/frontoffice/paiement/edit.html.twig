{% extends 'base_dark.html.twig' %}

{% block title %}Modifier le Paiement #{{ paiement.id }}{% endblock %}

{% block body %}
<div class="payment-outer-wrapper">
    <div class="payment-container fade-in">
        <div class="payment-header">
            <span class="section-label">Correction de Transaction</span>
            <h1 class="section-title">Modifier le <em>Paiement</em></h1>
            <p class="section-sub">Ajustez les détails de votre transaction ci-dessous.</p>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="payment-alert {{ label == 'error' ? 'error' : 'success' }}">
                    <i class="fas {{ label == 'error' ? 'fa-exclamation-circle' : 'fa-check-circle' }}"></i>
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <form method="post" class="payment-form shadow-premium">
            <!-- AMOUNT SECTION -->
            <div class="amount-hero-section">
                <label for="amount" class="input-label">Montant corrigé</label>
                <div class="amount-input-wrapper">
                    <input type="number" step="0.01" name="amount" id="amount" class="premium-amount-input" value="{{ paiement.amount }}" required autofocus>
                    <span class="currency-tag">TND</span>
                </div>
                <div class="amount-underline"></div>
            </div>

            <!-- BILLING INFO -->
            <div class="billing-section">
                <p class="input-label centered">Détails de Facturation</p>
                <div class="form-row-pro">
                    <div class="input-group-pro">
                        <label for="prenom">Prénom</label>
                        <div class="input-wrapper-pro">
                            <i class="fas fa-user-tag"></i>
                            <input type="text" name="prenom" id="prenom" placeholder="Ex: Jean" value="{{ paiement.prenom }}" required>
                        </div>
                    </div>
                    <div class="input-group-pro">
                        <label for="nom">Nom</label>
                        <div class="input-wrapper-pro">
                            <i class="fas fa-user-tie"></i>
                            <input type="text" name="nom" id="nom" placeholder="Ex: Dupont" value="{{ paiement.nom }}" required>
                        </div>
                    </div>
                </div>
                <div class="form-row-pro">
                    <div class="input-group-pro">
                        <label for="email">E-mail de contact</label>
                        <div class="input-wrapper-pro">
                            <i class="fas fa-envelope"></i>
                            <input type="email" name="email" id="email" placeholder="jean.dupont@elite.com" value="{{ paiement.email }}">
                        </div>
                    </div>
                    <div class="input-group-pro">
                        <label for="telephone">Téléphone</label>
                        <div class="input-wrapper-pro">
                            <i class="fas fa-phone"></i>
                            <input type="tel" name="telephone" id="telephone" placeholder="+216 ..." value="{{ paiement.telephone }}">
                        </div>
                    </div>
                </div>
            </div>

            <!-- PAYMENT METHODS -->
            <div class="methods-section">
                <p class="input-label centered">Nouveau Canal de Paiement</p>
                <div class="methods-grid">
                    <div class="method-option">
                        <input type="radio" class="method-radio" name="method" id="method_stripe" value="Stripe" {{ paiement.methodePaiement == 'Stripe' ? 'checked' : '' }}>
                        <label class="method-card" for="method_stripe">
                            <div class="method-icon stripe"><i class="fab fa-stripe-s"></i></div>
                            <div class="method-info">
                                <span class="method-title">Carte Bancaire</span>
                                <span class="method-desc">Passerelle sécurisée Stripe</span>
                            </div>
                            <div class="selection-indicator"><i class="fas fa-check"></i></div>
                        </label>
                    </div>

                    <div class="method-option">
                        <input type="radio" class="method-radio" name="method" id="method_wallet" value="Wallet" {{ paiement.methodePaiement == 'Wallet' ? 'checked' : '' }}>
                        <label class="method-card" for="method_wallet">
                            <div class="method-icon wallet"><i class="fas fa-wallet"></i></div>
                            <div class="method-info">
                                <span class="method-title">Mon Wallet</span>
                                <span class="method-desc">Solde: <strong>{{ (user.walletBalance ?? 0)|number_format(2) }} TND</strong></span>
                            </div>
                            <div class="cashback-badge">+5% Cashback</div>
                            <div class="selection-indicator"><i class="fas fa-check"></i></div>
                        </label>
                    </div>
                </div>
            </div>

            <!-- ACTIONS -->
            <div class="payment-actions">
                <button type="submit" class="btn-primary-gradient">
                    <i class="fas fa-save"></i> Enregistrer les Modifications
                </button>
                <a href="{{ path('app_user_paiement_index') }}" class="btn-text-only">
                    Annuler et quitter
                </a>
            </div>
            
            <div class="security-footer">
                <i class="fas fa-shield-alt"></i> Modifications sécurisées via Symfony
            </div>
        </form>
    </div>
</div>

<style>
    .payment-outer-wrapper { padding: 6rem 5% 4rem; min-height: 100vh; background: var(--cream); }
    .payment-container { max-width: 720px; margin: 0 auto; }
    .payment-header { text-align: center; margin-bottom: 3rem; }
    .payment-form { background: var(--white); border: 1px solid rgba(201,168,76,0.1); border-radius: 30px; padding: 3.5rem; position: relative; }
    .shadow-premium { box-shadow: 0 15px 50px rgba(13,27,42,0.06); }
    .payment-alert { padding: 1rem 1.5rem; border-radius: 12px; margin-bottom: 2rem; display: flex; align-items: center; gap: 0.8rem; font-size: 0.9rem; font-weight: 500; }
    .payment-alert.error { background: #fef2f2; color: #dc2626; border: 1px solid #fee2e2; }
    .payment-alert.success { background: #ecfdf5; color: #059669; border: 1px solid #d1fae5; }
    .amount-hero-section { text-align: center; margin-bottom: 3.5rem; }
    .input-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 2px; color: var(--muted); font-weight: 700; margin-bottom: 1rem; display: block; }
    .input-label.centered { text-align: center; }
    .amount-input-wrapper { display: flex; align-items: center; justify-content: center; gap: 0.5rem; }
    .premium-amount-input { background: transparent; border: none; outline: none; font-size: 4.5rem; font-weight: 800; color: var(--navy); width: 240px; text-align: center; font-family: 'Playfair Display', serif; }
    .currency-tag { font-size: 1.5rem; font-weight: 700; color: var(--gold); opacity: 0.8; }
    .amount-underline { width: 100px; height: 3px; background: var(--gold); margin: 0 auto; border-radius: 10px; }
    .methods-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; margin-bottom: 3rem; }
    .method-radio { display: none; }
    .method-card { border: 1px solid rgba(0,0,0,0.06); border-radius: 20px; padding: 1.5rem; display: flex; flex-direction: column; align-items: center; gap: 1rem; cursor: pointer; transition: all 0.3s; position: relative; background: #fafbfd; height: 100%; }
    .method-card:hover { transform: translateY(-3px); border-color: var(--gold); background: #fff; }
    .method-icon { width: 54px; height: 54px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
    .method-icon.stripe { background: rgba(37, 99, 235, 0.08); color: #2563eb; }
    .method-icon.wallet { background: rgba(16, 185, 129, 0.08); color: #059669; }
    .method-info { text-align: center; }
    .method-title { display: block; font-weight: 700; font-size: 1rem; color: var(--navy); margin-bottom: 0.15rem; }
    .method-desc { display: block; font-size: 0.72rem; color: var(--muted); }
    .selection-indicator { position: absolute; top: 10px; right: 10px; width: 20px; height: 20px; background: var(--gold); color: var(--navy); border-radius: 50%; font-size: 0.6rem; display: flex; align-items: center; justify-content: center; opacity: 0; transform: scale(0.5); transition: all 0.3s; }
    .method-radio:checked + .method-card { border-color: var(--gold); background: var(--white); box-shadow: 0 10px 25px rgba(201,168,76,0.12); }
    .method-radio:checked + .method-card .selection-indicator { opacity: 1; transform: scale(1); }
    .cashback-badge { background: var(--gold); color: var(--navy); font-size: 0.55rem; font-weight: 800; padding: 0.15rem 0.5rem; border-radius: 5px; margin-top: 0.5rem; }
    .payment-actions { display: flex; flex-direction: column; gap: 1rem; align-items: center; }
    .btn-primary-gradient { width: 100%; background: linear-gradient(135deg, var(--gold), var(--gold-l)); border: none; color: var(--navy); padding: 1.2rem; border-radius: 12px; font-weight: 700; font-size: 1rem; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 0.7rem; transition: transform 0.3s, box-shadow 0.3s; font-family: 'Plus Jakarta Sans', sans-serif; }
    .btn-primary-gradient:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(201,168,76,0.35); }
    .btn-text-only { color: var(--muted); text-decoration: none; font-size: 0.8rem; font-weight: 600; transition: color 0.3s; }
    .btn-text-only:hover { color: var(--navy); }
    .security-footer { margin-top: 2rem; text-align: center; font-size: 0.65rem; color: var(--muted); display: flex; align-items: center; justify-content: center; gap: 0.4rem; }
    .security-footer i { color: var(--gold); }

    /* NEW BILLING STYLES */
    .billing-section { margin-bottom: 2.5rem; }
    .form-row-pro { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.2rem; }
    .input-group-pro { display: flex; flex-direction: column; gap: 0.5rem; }
    .input-group-pro label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1px; font-weight: 700; color: var(--muted); padding-left: 0.5rem; }
    .input-wrapper-pro { position: relative; }
    .input-wrapper-pro i { position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--gold); font-size: 0.85rem; }
    .input-wrapper-pro input { width: 100%; background: #f8fafc; border: 1px solid rgba(0,0,0,0.06); border-radius: 12px; padding: 0.8rem 1rem 0.8rem 2.8rem; color: var(--navy); font-weight: 600; outline: none; transition: all 0.3s; }
    .input-wrapper-pro input:focus { background: #fff; border-color: var(--gold); box-shadow: 0 5px 15px rgba(201,168,76,0.1); }

    @media (max-width: 600px) {
        .payment-form { padding: 2rem; }
        .methods-grid { grid-template-columns: 1fr; }
        .form-row-pro { grid-template-columns: 1fr; gap: 1rem; }
        .premium-amount-input { font-size: 3rem; }
    }
</style>
{% endblock %}
