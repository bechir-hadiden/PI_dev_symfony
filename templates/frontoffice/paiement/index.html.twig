        flex: 1;
    }
    .lab-tag { font-weight: 800; color: var(--gold); font-size: 0.8rem; }
    .lab-field { border: none; outline: none; font-weight: 700; color: var(--navy); width: 100%; font-size: 1rem; }
    .lab-divider { color: var(--gold); font-size: 1.2rem; animation: pulse 2s infinite; }
    
    .lab-result {
        flex: 1;
        text-align: right;
    }
    .lab-res-label { display: block; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); font-weight: 800; }
    .lab-res-val { font-size: 1.8rem; font-weight: 800; color: var(--navy); }
