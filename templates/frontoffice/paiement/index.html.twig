    .page-sep {
        color: var(--muted);
        font-weight: 800;
        padding: 0 5px;
    }

    .page-btn { 
        background: rgba(201, 168, 76, 0.05);
        border-color: rgba(201, 168, 76, 0.2);
        color: var(--gold);
    }



    /* SMARTPAY LAB / BUDGET CALCULATOR */
    .currency-converter-banner { margin-bottom: 3rem; }
    .glass-lab-card {
        background: var(--white);
        border-radius: 28px;
        padding: 2rem;
        border: 1px solid rgba(201,168,76,0.15);
        box-shadow: var(--shadow);
    }
    .lab-grid {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 3rem;
