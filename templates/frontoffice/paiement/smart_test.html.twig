{% extends 'base_dark.html.twig' %}

{% block title %}SmartPay Simulator — VoyageElite Laboratory{% endblock %}

{% block body %}
<style>
    :root {
        --deep-bg: #030712;
        --card-bg: rgba(17, 24, 39, 0.7);
        --accent-gold: #c9a84c;
        --accent-navy: #1e3a8a;
        --safe: #10b981;
        --danger: #ef4444;
        --warning: #f59e0b;
        --border-glass: rgba(255, 255, 255, 0.08);
    }

    .smart-pay-experience { 
        min-height: 100vh; 
        background: var(--deep-bg); 
        padding: 120px 0 80px;
        position: relative;
        overflow: hidden;
    }

    /* BACKGROUND DECORATIONS */
    .bg-accent-1 { position: absolute; top: -10%; right: -5%; width: 500px; height: 500px; background: radial-gradient(circle, rgba(201,168,76,0.15) 0%, transparent 70%); z-index: 0; filter: blur(60px); }
    .bg-accent-2 { position: absolute; bottom: 20%; left: -5%; width: 400px; height: 400px; background: radial-gradient(circle, rgba(30,58,138,0.15) 0%, transparent 70%); z-index: 0; filter: blur(50px); }

    /* HEADER */
    .simulator-header h1 { font-family: 'Playfair Display', serif; font-size: 3.8rem; font-weight: 900; background: linear-gradient(to right, #fff, rgba(255,255,255,0.6)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .simulator-header span { color: var(--accent-gold); -webkit-text-fill-color: var(--accent-gold); }
    .badge-lab { background: rgba(201,168,76,0.15); color: var(--accent-gold); padding: 6px 16px; border-radius: 30px; font-size: 0.7rem; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; border: 1px solid rgba(201,168,76,0.2); margin-bottom: 1rem; display: inline-block; }

    /* CARDS */
    .luxury-glass-card {
        background: var(--card-bg);
        backdrop-filter: blur(20px);
        border: 1px solid var(--border-glass);
        border-radius: 32px;
        padding: 2.5rem;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        position: relative;
    }
    
    .section-title-sm {
        font-size: 0.7rem;
        font-weight: 800;
        color: #94a3b8;
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .section-title-sm::before { content: ''; width: 3px; height: 14px; background: var(--accent-gold); border-radius: 4px; }

    /* INPUTS */
    .lab-input-wrapper { margin-bottom: 1.8rem; }
    .lab-input-wrapper label { display: block; font-size: 0.8rem; font-weight: 700; color: #cbd5e1; margin-bottom: 8px; margin-left: 4px; }
    .lab-input-pro {
        width: 100%;
        background: rgba(0,0,0,0.3);
        border: 1px solid rgba(255,255,255,0.06);
        padding: 1.2rem;
        border-radius: 18px;
        color: #fff;
        font-weight: 600;
        transition: 0.3s;
        outline: none;
    }
    .lab-input-pro:focus { border-color: var(--accent-gold); background: rgba(201,168,76,0.05); box-shadow: 0 0 20px rgba(201,168,76,0.1); }

    /* IP SELECTOR */
    .ip-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 1.8rem; }
    .ip-option { cursor: pointer; background: rgba(255,255,255,0.03); border: 1.5px solid rgba(255,255,255,0.05); padding: 12px; border-radius: 14px; transition: 0.3s; text-align: center; }
    .ip-option span { display: block; font-size: 0.65rem; font-weight: 900; color: #64748b; margin-top: 4px; }
    .ip-option i { font-size: 1rem; color: #475569; }
    .ip-option input { display: none; }
    .ip-option:has(input:checked) { border-color: var(--accent-gold); background: rgba(201,168,76,0.12); }
    .ip-option:has(input:checked) i { color: var(--accent-gold); }
    .ip-option:has(input:checked) span { color: #fff; }

    /* SWITCHES */
    .luxury-switch {
        background: rgba(255,255,255,0.03);
        padding: 1.2rem;
        border-radius: 18px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
        border: 1px solid rgba(255,255,255,0.03);
    }
    .luxury-switch span { font-size: 0.8rem; font-weight: 700; color: #fff; }

    /* RISK METER */
    .risk-monitor { background: rgba(0,0,0,0.25); padding: 1.5rem; border-radius: 20px; border: 1px solid rgba(255,255,255,0.03); margin: 2rem 0; }
    .risk-header { display: flex; justify-content: space-between; margin-bottom: 12px; }
    .risk-header span { font-size: 0.7rem; font-weight: 900; letter-spacing: 1px; color: #64748b; }
    .risk-val { font-family: 'Courier New', monospace; font-size: 1.2rem; color: var(--accent-gold); font-weight: 900; }
    .risk-bar-container { height: 8px; background: rgba(255,255,255,0.05); border-radius: 10px; overflow: hidden; }
    .risk-bar-fill { height: 100%; width: 15%; background: var(--safe); transition: 1s cubic-bezier(0.19, 1, 0.22, 1); }

    /* ACTION BUTTON */
    .btn-simulator-launch {
        background: linear-gradient(135deg, var(--accent-gold), #b38f36);
        color: var(--deep-bg);
        border: none;
        padding: 1.4rem;
        border-radius: 20px;
        width: 100%;
        font-weight: 900;
        font-size: 1rem;
        letter-spacing: 1px;
        transition: 0.4s;
        box-shadow: 0 10px 30px rgba(201, 168, 76, 0.3);
    }
    .btn-simulator-launch:hover:not(:disabled) { transform: translateY(-5px); box-shadow: 0 15px 40px rgba(201, 168, 76, 0.4); filter: brightness(1.1); }
    .btn-simulator-launch:disabled { opacity: 0.5; cursor: not-allowed; }

    /* MONITORING PANEL */
    .monitoring-panel {
        background: rgba(0,0,0,0.3);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 32px;
        padding: 2rem;
        height: 100%;
        position: relative;
    }
    .monitor-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem; }
    .monitor-status { display: flex; align-items: center; gap: 8px; color: var(--safe); font-size: 0.65rem; font-weight: 900; text-transform: uppercase; }
    .status-dot { width: 8px; height: 8px; background: var(--safe); border-radius: 50%; animation: pulse-safe 2s infinite; }

    @keyframes pulse-safe { 0% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.5); opacity: 0.5; } 100% { transform: scale(1); opacity: 1; } }

    /* TRANSACTIONS HANDLER */
    .tx-item {
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.03);
        border-radius: 20px;
        padding: 1.2rem 1.5rem;
        margin-bottom: 12px;
        border-left: 4px solid #334155;
        transition: 0.3s;
    }
    .tx-item:hover { background: rgba(255,255,255,0.05); transform: translateX(5px); border-left-color: var(--accent-gold); }

    /* SECURITY REPORTS */
    .audit-card { background: rgba(0,0,0,0.4); border-radius: 20px; padding: 1.5rem; border: 1px solid rgba(255,255,255,0.05); margin-bottom: 1.5rem; }
    .audit-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 15px; }
    .audit-item { background: rgba(255,255,255,0.02); padding: 10px; border-radius: 12px; font-size: 0.7rem; }
    .audit-item label { color: #64748b; font-weight: 800; display: block; margin-bottom: 2px; }
    .audit-item span { color: #fff; font-weight: 700; }

    .ai-badge-pro { background: var(--accent-gold); color: var(--deep-bg); padding: 2px 8px; border-radius: 4px; font-size: 0.55rem; font-weight: 900; margin-right: 8px; }

    /* CUSTOM BAR SCROLL */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); }
    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--accent-gold); }
</style>

<div class="smart-pay-experience">
    <div class="bg-accent-1"></div>
    <div class="bg-accent-2"></div>
    
    <div class="container relative">
        <div class="simulator-header mb-5 fade-in">
            <span class="badge-lab">Sandbox Laboratory Environment</span>
            <h1 class="mb-2">SmartPay <span>Simulator</span></h1>
            <p class="text-white-50" style="font-weight: 500; font-size: 1.1rem;">Orchestre financier intelligent : Fraude, Automation & Rétention.</p>
        </div>

        <div class="row g-4">
            <!-- CONTROLS COLUMN -->
            <div class="col-lg-5">
                <div class="luxury-glass-card">
                    <div class="section-title-sm">Transaction Parameters</div>
                    
                    <form action="{{ path('app_smart_payment_process') }}" method="POST">
                        <div class="lab-input-wrapper">
                            <label>Montant de la Transaction (TND)</label>
                            <input type="number" step="0.01" name="amount" class="lab-input-pro" placeholder="Ex: 150.00" required>
                        </div>
                        
                        <div class="lab-input-wrapper">
                            <label>Niveau de Service / Abonnement</label>
                            <select name="plan" class="lab-input-pro">
                                <option value="">🛒 Achat Ponctuel (Single)</option>
                                <option value="basic">⭐ Abonnement BASIC</option>
                                <option value="premium">💎 Abonnement PREMIUM</option>
                            </select>
                        </div>

                        <div class="section-title-sm">Geographical Simulation</div>
                        <div class="ip-grid">
                            <label class="ip-option">
                                <input type="radio" name="simulated_ip" value="193.95.64.0" checked>
                                <i class="fas fa-home"></i>
                                <span>TUNISIE</span>
                            </label>
                            <label class="ip-option">
                                <input type="radio" name="simulated_ip" value="176.31.255.255">
                                <i class="fas fa-plane-arrival"></i>
                                <span>FRANCE</span>
                            </label>
                            <label class="ip-option">
                                <input type="radio" name="simulated_ip" value="8.8.8.8">
                                <i class="fas fa-globe-americas"></i>
                                <span>INTERNAT.</span>
                            </label>
                        </div>

                        <div class="lab-input-wrapper">
                            <label>Origine de la Carte (Émetteur)</label>
                            <select name="card_country" class="lab-input-pro">
                                <option value="Tunisie">Tunisie 🇹🇳</option>
                                <option value="France">France 🇫🇷</option>
                                <option value="USA">États-Unis 🇺🇸</option>
                                <option value="Russia">Russie 🇷🇺</option>
                                <option value="China">Chine 🇨🇳</option>
                            </select>
                        </div>

                        <div class="section-title-sm">Security & Stress Test</div>
                        <div class="luxury-switch">
                            <span>Simuler IP Suspecte (Proxy/VPN)</span>
                            <div class="form-check form-switch p-0">
                                <input class="form-check-input" type="checkbox" name="simulate_suspicious_ip" id="fakeIp" style="width: 2.8em; height: 1.4em; cursor: pointer;">
                            </div>
                        </div>

                        <div class="luxury-switch" style="border-color: rgba(239, 68, 68, 0.2); background: rgba(239, 68, 68, 0.05);">
                            <span class="text-danger">Forcer Échec (Test Suspension)</span>
                            <div class="form-check form-switch p-0">
                                <input class="form-check-input" type="checkbox" name="force_failure" id="forceFail" style="width: 2.8em; height: 1.4em; cursor: pointer;">
                            </div>
                        </div>

                        <div class="risk-monitor">
                            <div class="risk-header">
                                <span>REAL-TIME RISK SCORE</span>
                                <span id="scoreVal" class="risk-val">0.02</span>
                            </div>
                            <div class="risk-bar-container">
                                <div id="riskBar" class="risk-bar-fill"></div>
                            </div>
                        </div>

                        <button type="submit" class="btn-simulator-launch" {{ user.estBloque ? 'disabled' : '' }}>
                            <i class="fas fa-bolt me-2"></i> EXÉCUTER LA TRANSACTION
                        </button>
                    </form>
                </div>
            </div>

            <!-- MONITORING COLUMN -->
            <div class="col-lg-7">
                <div class="monitoring-panel">
                    <div class="monitor-header">
                        <div class="section-title-sm mb-0">Engine Real-Time Monitoring</div>
                        <div class="monitor-status">
                            <div class="status-dot"></div>
                            System Live
                        </div>
                    </div>
                    
                    <div class="terminal-scroll" style="max-height: 800px; overflow-y: auto;">
                        {# AUDIT REPORTS #}
                        {% for message in app.flashes('smart_error') %}
                            <div class="audit-card" style="border-color: rgba(239, 68, 68, 0.3); background: rgba(239, 68, 68, 0.04);">
                                <div class="d-flex align-items-center gap-3 border-bottom pb-3 mb-3" style="border-color: rgba(239, 68, 68, 0.1) !important;">
                                    <div class="bg-danger text-white rounded-lg p-2" style="border-radius: 12px; width: 45px; height: 45px; display: flex; align-items: center; justify-content: center;">
                                        <i class="fas fa-shield-virus fa-lg"></i>
                                    </div>
                                    <div>
                                        <h6 class="text-white fw-800 mb-0">SECURITY ALERT BLOCKED</h6>
                                        <small class="text-danger fw-700">{{ message.message }}</small>
                                    </div>
                                    <div class="ms-auto text-end">
                                        <span class="badge bg-danger">RISK HIGH</span>
                                    </div>
                                </div>
                                <div class="audit-grid">
                                    <div class="audit-item"><label>Final Score</label><span>{{ message.score|number_format(2) }} / 1.0</span></div>
                                    <div class="audit-item"><label>Action</label><span class="text-danger">REJECTED</span></div>
                                </div>
                            </div>
                        {% endfor %}

                        {% for message in app.flashes('smart_success') %}
                            <div class="audit-card" style="border-color: rgba(16, 185, 129, 0.3); background: rgba(16, 185, 129, 0.04);">
                                <div class="d-flex align-items-center gap-3 border-bottom pb-3 mb-3" style="border-color: rgba(16, 185, 129, 0.1) !important;">
                                    <div class="bg-success text-white rounded-lg p-2" style="border-radius: 12px; width: 45px; height: 45px; display: flex; align-items: center; justify-content: center;">
                                        <i class="fas fa-shield-check fa-lg"></i>
                                    </div>
                                    <div>
                                        <h6 class="text-white fw-800 mb-0">TRANSACTION SECURED</h6>
                                        <small class="text-success fw-700">{{ message.message }}</small>
                                    </div>
                                    <div class="ms-auto text-end">
                                        <span class="badge bg-success">LOW RISK</span>
                                    </div>
                                </div>
                                <div class="audit-grid">
                                    <div class="audit-item"><label>Geo Source</label><span>{{ message.country }} ({{ message.ip }})</span></div>
                                    <div class="audit-item"><label>Security Level</label><span class="text-success">VERIFIED</span></div>
                                </div>
                            </div>
                        {% endfor %}

                        {# HISTORICAL NODES #}
                        <div class="section-title-sm mt-4 mb-3">Historical Activity Log</div>
                        {% for p in user.paiements|reverse|slice(0, 10) %}
                            <div class="tx-item" style="border-left-color: {{ p.status == 'Effectué' ? 'var(--safe)' : (p.status == 'bloqué' ? 'var(--danger)' : '#64748b') }}">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="d-flex align-items-center gap-2 mb-1">
                                            <span style="color: #64748b; font-size: 0.55rem; font-weight: 900; background: rgba(255,255,255,0.05); padding: 2px 6px; border-radius: 4px;">ID_#{{ p.id }}</span>
                                            <span style="font-size: 0.6rem; color: {{ p.status == 'Effectué' ? 'var(--safe)' : 'var(--danger)' }}; font-weight: 800;">• {{ p.status|upper }}</span>
                                        </div>
                                        <h6 class="text-white fw-800 mb-1">{{ p.amount|number_format(2) }} TND</h6>
                                        <small class="text-white-50" style="font-size: 0.6rem;">{{ p.datePaiement|date('H:i:s d/m/Y') }} — Reference: VElite_{{ p.id }}</small>
                                    </div>
                                    <div class="d-flex gap-2">
                                        {% if p.status == 'En attente' %}
                                            <form action="{{ path('app_smart_payment_validate_admin', {id: p.id}) }}" method="POST">
                                                <button class="btn btn-sm btn-outline-light" style="font-size: 0.5rem; font-weight: 800; border-radius: 6px;">APPROVE</button>
                                            </form>
                                        {% endif %}
                                        <form action="{{ path('app_smart_payment_fail', {id: p.id}) }}" method="POST">
                                            <button class="btn btn-sm btn-outline-danger" style="font-size: 0.5rem; font-weight: 800; border-radius: 6px;">FAIL</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const fakeIp = document.getElementById('fakeIp');
        const scoreVal = document.getElementById('scoreVal');
        const riskBar = document.getElementById('riskBar');

        fakeIp.addEventListener('change', function() {
            if (this.checked) {
                scoreVal.innerText = "0.89";
                riskBar.style.width = "89%";
                riskBar.style.background = "#ef4444";
                riskBar.style.boxShadow = "0 0 15px rgba(239, 68, 68, 0.4)";
            } else {
                scoreVal.innerText = "0.02";
                riskBar.style.width = "15%";
                riskBar.style.background = "#10b981";
                riskBar.style.boxShadow = "none";
            }
        });
    });
</script>
{% endblock %}

