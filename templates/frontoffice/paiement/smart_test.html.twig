{% extends 'base_dark.html.twig' %}

{% block title %}Simulateur SmartPayment — VoyageElite{% endblock %}

{% block body %}
<style>
    /* CYBER-PREMIUM SIMULATOR STYLES */
    .smart-pay-experience { min-height: 100vh; background: #010816; position: relative; overflow-x: hidden; font-family: 'Plus Jakarta Sans', sans-serif; padding-top: 100px; padding-bottom: 50px; }
    .hero-bg-glow { position: absolute; top: -10%; right: -5%; width: 60%; height: 70%; background: radial-gradient(circle, rgba(201,168,76,0.08) 0%, rgba(1,8,22,0) 70%); z-index: 0; pointer-events: none; }
    
    .header-v2 h1 { font-family: 'Playfair Display', serif; font-size: 3.5rem; letter-spacing: -1px; }
    .header-v2 h1 span { color: var(--gold); position: relative; }

    /* GLASS CARD PRO */
    .glass-card-pro { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(25px); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 32px; padding: 2.5rem; box-shadow: 0 25px 50px rgba(0,0,0,0.3); transition: all 0.4s ease; height: 100%; }
    
    .card-label-top { font-size: 0.65rem; font-weight: 800; color: #64748b; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 1.2rem; display: flex; align-items: center; gap: 10px; }
    .card-label-top i { color: var(--gold); }

    .input-field-pro { width: 100%; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.06); padding: 1.1rem 1.4rem; border-radius: 16px; color: #fff; font-weight: 600; font-size: 0.95rem; transition: all 0.3s; margin-bottom: 1.5rem; outline: none; }
    .input-field-pro:focus { border-color: var(--gold); background: rgba(201,168,76,0.05); }

    /* ORIGIN GROUP */
    .origin-group { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.8rem; margin-bottom: 1.5rem; }
    .origin-btn { cursor: pointer; text-align: center; background: rgba(255,255,255,0.03); border: 1.5px solid rgba(255,255,255,0.05); padding: 0.8rem; border-radius: 12px; transition: 0.3s; }
    .origin-btn span { display: block; font-size: 0.6rem; font-weight: 800; color: #94a3b8; }
    .origin-btn input { display: none; }
    .origin-btn:has(input:checked) { border-color: var(--gold); background: rgba(201,168,76,0.15); }

    .custom-switch-pro { display: flex; align-items: center; justify-content: space-between; background: rgba(0,0,0,0.2); padding: 1rem 1.4rem; border-radius: 16px; margin-bottom: 1.5rem; border: 1px solid rgba(255,255,255,0.03); }
    .custom-switch-pro label { font-size: 0.75rem; font-weight: 700; color: #fff; }

    .risk-meter-box { margin-bottom: 2rem; }
    .risk-info { display: flex; justify-content: space-between; margin-bottom: 0.8rem; font-size: 0.7rem; font-weight: 700; color: #94a3b8; }
    .progress-track { height: 6px; background: rgba(255,255,255,0.05); border-radius: 10px; overflow: hidden; }
    .progress-fill { height: 100%; width: 22%; background: linear-gradient(90deg, #10b981, #c9a84c); transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1); }

    /* LAB CARD */
    .lab-card { background: rgba(201,168,76,0.02); border: 1px dashed rgba(201,168,76,0.2); border-radius: 24px; padding: 2rem; margin-top: 2rem; }
    .btn-lab { background: #fff; color: #010816; border: none; padding: 1rem; border-radius: 14px; font-weight: 800; font-size: 0.75rem; text-transform: uppercase; cursor: pointer; transition: 0.3s; display: flex; align-items: center; justify-content: center; gap: 0.8rem; width: 100%; }
    .btn-lab-outline { background: transparent; border: 1.5px solid rgba(255,255,255,0.1) !important; color: #fff !important; }
    .btn-lab:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.2); }

    /* MONITOR */
    .terminal-neon { background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.05); border-radius: 32px; padding: 2rem; height: 100%; }
    .terminal-title { display: flex; align-items: center; gap: 0.8rem; color: var(--gold); font-weight: 800; font-size: 0.8rem; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 2rem; }
    .terminal-title::after { content: ''; flex: 1; height: 1px; background: linear-gradient(90deg, rgba(201,168,76,0.2), transparent); }

    .transaction-node { background: rgba(255,255,255,0.02); border-radius: 20px; padding: 1.5rem; margin-bottom: 1.2rem; border-left: 4px solid var(--gold); transition: 0.3s; }
    .transaction-node:hover { background: rgba(255,255,255,0.05); transform: translateX(5px); }

    .btn-bolt { background: var(--gold); color: #010816; border: none; padding: 1.2rem; border-radius: 18px; font-weight: 900; letter-spacing: 1px; cursor: pointer; transition: 0.3s; }
    .btn-bolt:hover:not(:disabled) { transform: scale(1.02); box-shadow: 0 0 30px rgba(201,168,76,0.3); }

    .btn-micro-pro { font-size: 0.65rem; font-weight: 800; background: rgba(255,255,255,0.08); color: #fff; border: 1px solid rgba(255,255,255,0.1); padding: 0.5rem 0.8rem; border-radius: 8px; text-decoration: none; transition: 0.3s; }
    .btn-micro-pro:hover { background: #fff; color: #010816; }

    .status-badge { font-size: 0.6rem; font-weight: 900; padding: 4px 10px; border-radius: 6px; }
    .status-success { background: rgba(16,185,129,0.15); color: #10b981; }

    @media (max-width: 900px) { .header-v2 h1 { font-size: 2.2rem; } .origin-group { grid-template-columns: 1fr; } }

    /* AUDIT REPORT STYLES */
    .security-audit-box { background: rgba(0,0,0,0.4); border-radius: 16px; padding: 1.2rem; border: 1px solid rgba(255,255,255,0.05); }
    .audit-header { display: flex; justify-content: space-between; margin-bottom: 1rem; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.5rem; }
    .audit-tag { font-size: 0.55rem; font-weight: 800; color: #94a3b8; letter-spacing: 1px; }
    .audit-score { font-size: 0.8rem; font-weight: 900; color: var(--gold); }
    .audit-row { display: flex; justify-content: space-between; align-items: center; padding: 0.4rem 0; font-size: 0.75rem; }
    .audit-label { color: #cbd5e1; }
    .audit-impact { font-weight: 800; color: #10b981; margin-right: 10px; }
    .audit-status { font-size: 0.55rem; font-weight: 900; padding: 2px 6px; border-radius: 4px; }
    .status-ok { background: rgba(16,185,129,0.1); color: #10b981; }
    .status-danger { background: rgba(239,68,68,0.1); color: #ef4444; }
    .status-warning { background: rgba(245,158,11,0.1); color: #f59e0b; }
    .audit-geo { font-size: 0.7rem; color: #64748b; font-weight: 600; }
</style>

<div class="smart-pay-experience">
    <div class="hero-bg-glow"></div>
    
    <div class="container">
        <div class="header-v2 mb-5 fade-in">
            <h1 class="text-white fw-900 mb-2">SmartPay <span>Simulator</span></h1>
            <p class="text-white-50">Gestion intelligente des flux financiers & Automatisation.</p>
        </div>

        <div class="row g-4">
            <div class="col-lg-5">
                <div class="glass-card-pro">
                    <span class="card-label-top"><i class="fas fa-sliders"></i> Paramètres Moteur</span>
                    
                    <form action="{{ path('app_smart_payment_process') }}" method="POST">
                        <label class="card-label-top">Montant (TND)</label>
                        <input type="number" step="0.01" name="amount" class="input-field-pro" placeholder="0.00" required>
                        
                        <label class="card-label-top">Option Service</label>
                        <select name="plan" class="input-field-pro">
                            <option value="">Achat Ponctuel</option>
                            <option value="basic">Abonnement BASIC</option>
                            <option value="premium">Abonnement PREMIUM</option>
                        </select>
                        <label class="card-label-top">Simulation d'IP Géolocalisée (via IPinfo)</label>
                        <div class="origin-group">
                            <label class="origin-btn" title="Topnet Tunisia">
                                <input type="radio" name="simulated_ip" value="193.95.64.0" checked>
                                <span>TUNISIE (Local)</span>
                            </label>
                            <label class="origin-btn" title="OVH France">
                                <input type="radio" name="simulated_ip" value="176.31.255.255">
                                <span>FRANCE (+10%)</span>
                            </label>
                            <label class="origin-btn" title="Google USA">
                                <input type="radio" name="simulated_ip" value="8.8.8.8">
                                <span>INTERNAT. (+10%)</span>
                            </label>
                        </div>

                        <div class="lab-input-group mt-3">
                            <span class="lab-tag"><i class="fas fa-credit-card"></i> Origine Carte</span>
                            <select name="card_country" class="lab-field">
                                <option value="Tunisie">Tunisie</option>
                                <option value="France">France</option>
                                <option value="USA">USA</option>
                                <option value="Russia">Russia</option>
                                <option value="China">China</option>
                            </select>
                        </div>

                        <div class="custom-switch-pro">
                            <label for="fakeIp">Simuler IP Suspecte</label>
                            <div class="form-check form-switch p-0">
                                <input class="form-check-input" type="checkbox" name="simulate_suspicious_ip" id="fakeIp" style="width: 2.5em; height: 1.25em; cursor: pointer;">
                            </div>
                        </div>

                        <div class="custom-switch-pro border-danger-soft" style="border-color: rgba(239, 68, 68, 0.2) !important; background: rgba(239, 68, 68, 0.05);">
                            <label for="forceFail" class="text-danger">Forcer Échec (Test Suspension Abonn.)</label>
                            <div class="form-check form-switch p-0">
                                <input class="form-check-input" type="checkbox" name="force_failure" id="forceFail" style="width: 2.5em; height: 1.25em; cursor: pointer;">
                            </div>
                        </div>

                        <div class="risk-meter-box">
                            <div class="risk-info">
                                <span>RISK SCORE</span>
                                <span id="scoreVal">0.02</span>
                            </div>
                            <div class="progress-track">
                                <div id="riskBar" class="progress-fill"></div>
                            </div>
                        </div>

                        <button type="submit" class="btn-bolt w-100" {{ user.estBloque ? 'disabled' : '' }}>
                            LANCER LA TRANSACTION
                        </button>
                    </form>

                    <div class="lab-card">
                        <h6 class="text-white fw-800 mb-3"><i class="fas fa-microscope text-gold me-2"></i> Zone d'Expérimentation</h6>
                        <div class="row g-2">
                            <div class="col-6">
                                <form action="{{ path('app_smart_payment_test_res') }}" method="POST">
                                    <button class="btn-lab">Ticket OK</button>
                                </form>
                            </div>
                            <div class="col-6">
                                <form action="{{ path('app_smart_payment_test_res') }}" method="POST">
                                    <input type="hidden" name="simulate_old" value="1">
                                    <button class="btn-lab btn-lab-outline">Timeout</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="terminal-neon">
                    <div class="terminal-title">Monitoring Live</div>
                    
                    <div class="terminal-scroll" style="max-height: 750px; overflow-y: auto; padding-right: 10px;">
                        {% for message in app.flashes('smart_error') %}
                            <div class="alert alert-cyber-danger mb-4 fade-in" style="background: rgba(239, 68, 68, 0.05); border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 20px; padding: 1.5rem;">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="me-3" style="width: 40px; height: 40px; background: #ef4444; color: white; border-radius: 10px; display: flex; align-items: center; justify-content: center;"><i class="fas fa-exclamation-triangle"></i></div>
                                    <div>
                                        <h6 class="text-white mb-0 fw-800">ALERTE : Échec & Suspension</h6>
                                        <small style="color: #ef4444; font-weight: 700;">{{ message.message }}</small>
                                    </div>
                                </div>
                                
                                <div class="security-audit-box" style="border-color: rgba(239,68,68,0.2);">
                                    <div class="audit-header">
                                        <span class="audit-tag">ANALYSE DU RISK SCORE</span>
                                        <span class="audit-score text-danger">{{ message.score|number_format(2) }} / 1.0</span>
                                    </div>
                                    
                                    <div class="audit-table">
                                        {% for detail in message.details %}
                                            <div class="audit-row">
                                                <span class="audit-label">{{ detail.label }}</span>
                                                <div class="audit-meta">
                                                    <span class="audit-impact" style="color: {{ detail.status == 'DANGER' ? '#ef4444' : '#f59e0b' }}">{{ detail.impact }}</span>
                                                    <span class="audit-status status-{{ detail.status|lower }}">{{ detail.status }}</span>
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>

                                    {% if message.retry_tip %}
                                        <div class="mt-3 p-2 rounded" style="background: rgba(245, 158, 11, 0.1); border-left: 3px solid #f59e0b;">
                                            <div style="font-size: 0.6rem; font-weight: 800; color: #f59e0b; text-transform: uppercase;"><i class="fas fa-brain me-1"></i> Conseil Optimisation IA</div>
                                            <div style="font-size: 0.75rem; color: #cbd5e1; font-weight: 600; margin-top: 2px;">{{ message.retry_tip }}</div>
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                        {% for message in app.flashes('smart_success') %}
                            <div class="alert alert-cyber-success mb-4 fade-in" style="background: rgba(16,185,129,0.05); border: 1px solid rgba(16,185,129,0.2); border-radius: 20px; padding: 1.5rem;">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="me-3" style="width: 40px; height: 40px; background: #10b981; color: white; border-radius: 10px; display: flex; align-items: center; justify-content: center;"><i class="fas fa-shield-check"></i></div>
                                    <div>
                                        <h6 class="text-white mb-0 fw-800">Rapport de Sécurité Positif</h6>
                                        <small style="color: #10b981; font-weight: 700;">{{ message.message }}</small>
                                    </div>
                                </div>
                                
                                <div class="security-audit-box">
                                    <div class="audit-header">
                                        <span class="audit-tag">ANALYSE DU RISK SCORE</span>
                                        <span class="audit-score">{{ message.score|number_format(2) }} / 1.0</span>
                                    </div>
                                    
                                    <div class="audit-table">
                                        {% for detail in message.details %}
                                            <div class="audit-row">
                                                <span class="audit-label">{{ detail.label }}</span>
                                                <div class="audit-meta">
                                                    <span class="audit-impact">{{ detail.impact }}</span>
                                                    <span class="audit-status status-{{ detail.status|lower }}">{{ detail.status }}</span>
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                    
                                    <div class="audit-geo mt-2">
                                        <i class="fas fa-globe-africa me-1"></i> Origine : <strong>{{ message.country }}</strong> (IP: {{ message.ip }})
                                    </div>
                                </div>
                            </div>
                        {% endfor %}

                        {% for r in pending_reservations %}
                            <div class="transaction-node" style="border-left-color: #f59e0b;">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <span style="color: #f59e0b; font-size: 0.6rem; font-weight: 900;">PENDING_RESERVATION_#{ r.id }</span>
                                        <h6 class="text-white mt-1 mb-0">Ticket Transport en attente</h6>
                                        <div class="text-white-50 mt-1" style="font-size: 0.65rem;">Timeout: {{ r.expiresAt|date('H:i') }}</div>
                                    </div>
                                    <a href="{{ path('app_user_paiement_new', {reservation: r.id}) }}" class="btn-micro-pro">PAYER (TIMER)</a>
                                </div>
                            </div>
                        {% endfor %}

                        {% for p in user.paiements|reverse %}
                            <div class="transaction-node" style="border-left-color: {{ p.status == 'Effectué' ? '#10b981' : (p.status == 'bloqué' ? '#ef4444' : '#64748b') }}">
                                <div class="d-flex justify-content-between">
                                    <div>
                                        <span class="text-white-50" style="font-size: 0.6rem; font-weight: 900;">TX_ID_#{ p.id }</span>
                                        <h6 class="text-white mt-1">{{ p.amount|number_format(2) }} TND</h6>
                                        <div class="text-white-50" style="font-size: 0.65rem;">{{ p.datePaiement|date('H:i:s') }} — {{ p.status|upper }}</div>
                                    </div>
                                    <div class="d-flex flex-column gap-2">
                                        {% if p.status == 'En attente' %}
                                            <form action="{{ path('app_smart_payment_validate_admin', {id: p.id}) }}" method="POST">
                                                <button class="btn-micro-pro">VALIDER</button>
                                            </form>
                                        {% endif %}
                                        <form action="{{ path('app_smart_payment_fail', {id: p.id}) }}" method="POST">
                                            <button class="btn-micro-pro text-danger">FAIL</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const fakeIp = document.getElementById('fakeIp');
        const scoreVal = document.getElementById('scoreVal');
        const riskBar = document.getElementById('riskBar');

        fakeIp.addEventListener('change', function() {
            if (this.checked) {
                scoreVal.innerText = "0.74";
                riskBar.style.width = "74%";
                riskBar.style.background = "#ef4444";
            } else {
                scoreVal.innerText = "0.02";
                riskBar.style.width = "22%";
                riskBar.style.background = "linear-gradient(90deg, #10b981, #c9a84c)";
            }
        });
    });
</script>
{% endblock %}
