{% extends 'base_dark.html.twig' %}

{% block title %}Espace Administration - VoyageElite{% endblock %}

{% block stylesheets %}
<style>
    .admin-container {
        padding-top: 100px;
        padding-bottom: 60px;
    }
    
    .dashboard-header {
        margin-bottom: 40px;
    }
    
    .status-badge {
        display: inline-block;
        padding: 5px 15px;
        border-radius: 20px;
        background: rgba(201, 168, 76, 0.1);
        border: 1px solid rgba(201, 168, 76, 0.3);
        color: var(--gold);
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 15px;
    }

    .welcome-title {
        font-family: 'Playfair Display', serif;
        font-size: 3rem;
        color: var(--navy);
        margin-bottom: 10px;
    }

    /* Stat Cards */
    .stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
        margin-bottom: 50px;
    }

    .stat-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(201, 168, 76, 0.2);
        border-radius: 20px;
        padding: 25px;
        display: flex;
        align-items: center;
        gap: 20px;
        transition: transform 0.3s, box-shadow 0.3s;
    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 40px rgba(13, 27, 42, 0.1);
    }

    .stat-icon {
        width: 60px;
        height: 60px;
        background: var(--navy);
        color: var(--gold);
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }

    .stat-info h4 {
        font-size: 0.8rem;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 5px;
    }

    .stat-info .stat-value {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--navy);
        line-height: 1;
    }

    /* Management Cards */
    .module-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        gap: 30px;
    }

    .module-card {
        background: var(--navy);
        color: var(--white);
        border-radius: 24px;
        overflow: hidden;
        border: 1px solid rgba(201, 168, 76, 0.2);
        position: relative;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .module-card:hover {
        transform: scale(1.02);
        border-color: var(--gold);
        box-shadow: 0 25px 60px rgba(0,0,0,0.4);
    }

    .module-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; height: 4px;
        background: linear-gradient(90deg, var(--gold), var(--gold-l));
    }

    .module-content {
        padding: 40px;
        text-align: center;
    }

    .module-icon {
        font-size: 3.5rem;
        color: var(--gold);
        margin-bottom: 25px;
        opacity: 0.9;
    }

    .module-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.8rem;
        margin-bottom: 15px;
    }

    .module-desc {
        color: rgba(255, 255, 255, 0.6);
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 30px;
        min-height: 3rem;
    }

    .module-stats {
        display: flex;
        justify-content: center;
        gap: 30px;
        margin-bottom: 35px;
        padding: 20px 0;
        border-top: 1px solid rgba(201, 168, 76, 0.1);
        border-bottom: 1px solid rgba(201, 168, 76, 0.1);
    }

    .m-stat {
        text-align: center;
    }

    .m-stat-val {
        display: block;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--gold);
    }

    .m-stat-lab {
        font-size: 0.7rem;
        color: rgba(255, 255, 255, 0.4);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .btn-admin {
        background: linear-gradient(135deg, var(--gold), var(--gold-l));
        color: var(--navy);
        padding: 15px 30px;
        border-radius: 12px;
        font-weight: 700;
        text-decoration: none;
        display: block;
        transition: transform 0.3s, box-shadow 0.3s;
    }

    .btn-admin:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 25px rgba(201, 168, 76, 0.4);
        color: var(--navy);
    }

    @media (max-width: 768px) {
        .welcome-title { font-size: 2.2rem; }
    }
</style>
{% endblock %}

{% block body %}
<div class="container admin-container">
    <!-- Header -->
    <div class="dashboard-header d-flex justify-content-between align-items-end">
        <div>
            <span class="status-badge">Espace Administrateur</span>
            <h1 class="welcome-title">Tableau de Bord</h1>
            <p class="text-muted mb-0">Gérez l'ensemble de l'écosystème VoyageElite avec précision.</p>
        </div>
        <div class="header-tools">
            <a href="{{ path('app_smart_payment_test') }}" class="btn-admin" style="background: #ef4444; color: white; border: none; padding: 12px 25px;">
                <i class="fas fa-flask me-2"></i> MODE TEST : SMARTPAY LAB 🧪
            </a>
        </div>
    </div>

    <!-- Quick Stats Grid -->
    <div class="stat-grid">
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-coins"></i></div>
            <div class="stat-info">
                <h4>Revenus</h4>
                <div class="stat-value">{{ total_revenue|number_format(2, ',', ' ') }} DT</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-users"></i></div>
            <div class="stat-info">
                <h4>Utilisateurs</h4>
                <div class="stat-value">{{ total_users }}</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-map-marked-alt"></i></div>
            <div class="stat-info">
                <h4>Destinations</h4>
                <div class="stat-value">{{ total_destinations }}</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-plane-departure"></i></div>
            <div class="stat-info">
                <h4>Voyages</h4>
                <div class="stat-value">{{ total_voyages }}</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="fa-solid fa-car-rear"></i></div>
            <div class="stat-info">
                <h4>Véhicules</h4>
                <div class="stat-value">{{ total_vehicules }}</div>
            </div>
        </div>
    </div>

    <!-- Management Modules -->
    <div class="module-grid">
        <!-- Paiements -->
        <div class="module-card">
            <div class="module-content">
                <i class="fas fa-file-invoice-dollar module-icon"></i>
                <h3 class="module-title">Finances & Paiements</h3>
                <p class="module-desc">Supervisez toutes les transactions, validez les paiements et gérez le cashback de fidélité.</p>
                <div class="module-stats">
                    <div class="m-stat">
                        <span class="m-stat-val">{{ total_payments }}</span>
                        <span class="m-stat-lab">Total</span>
                    </div>
                    <div class="m-stat">
                        <span class="m-stat-val" style="color: #ffc107;">{{ pending_payments }}</span>
                        <span class="m-stat-lab">En attente</span>
                    </div>
                </div>
                <a href="{{ path('app_admin_paiement_index') }}" class="btn-admin">Gérer les Paiements</a>
            </div>
        </div>

        <!-- Voyages -->
        <div class="module-card" style="background: rgba(13, 27, 42, 0.95);">
            <div class="module-content">
                <i class="fas fa-suitcase-rolling module-icon"></i>
                <h3 class="module-title">Offres de Voyages</h3>
                <p class="module-desc">Créez de nouvelles expériences, gérez les disponibilités et les tarifs des séjours.</p>
                <div class="module-stats">
                    <div class="m-stat">
                        <span class="m-stat-val">{{ total_voyages }}</span>
                        <span class="m-stat-lab">Offres</span>
                    </div>
                    <div class="m-stat">
                        <span class="m-stat-val">{{ total_destinations }}</span>
                        <span class="m-stat-lab">Lieux</span>
                    </div>
                </div>
                <a href="{{ path('admin_voyage_index') }}" class="btn-admin">Gérer les Voyages</a>
            </div>
        </div>

        <!-- Destinations -->
        <div class="module-card" style="background: rgba(13, 27, 42, 0.9);">
            <div class="module-content">
                <i class="fas fa-globe-europe module-icon"></i>
                <h3 class="module-title">Destinations & Lieux</h3>
                <p class="module-desc">Administrez les descriptions des pays et villes phares de votre catalogue.</p>
                <div class="module-stats">
                    <div class="m-stat">
                        <span class="m-stat-val">{{ total_destinations }}</span>
                        <span class="m-stat-lab">Actives</span>
                    </div>
                </div>
                <a href="{{ path('admin_destination_index') }}" class="btn-admin">Gérer les Destinations</a>
            </div>
        </div>

        <!-- Transports -->
        <div class="module-card" style="background: #0f172a;">
            <div class="module-content">
                <i class="fa-solid fa-van-shuttle module-icon"></i>
                <h3 class="module-title">Transport & Flotte</h3>
                <p class="module-desc">Gérez votre parc automobile, les chauffeurs et les trajets inter-villes.</p>
                <div class="module-stats">
                    <div class="m-stat">
                        <span class="m-stat-val">{{ total_vehicules }}</span>
                        <span class="m-stat-lab">Véhicules</span>
                    </div>
                    <div class="m-stat">
                        <span class="m-stat-val">{{ total_transports }}</span>
                        <span class="m-stat-lab">Trajets</span>
                    </div>
                </div>
                <a href="{{ path('app_admin_transport_index') }}" class="btn-admin">Gérer le Parc</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}

