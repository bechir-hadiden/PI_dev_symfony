{% extends 'BackOffice/base_admin.html.twig' %}
{% block title %}Véhicules – Admin{% endblock %}
{% block page_title %}Gestion des Véhicules{% endblock %}

{% block body %}
<div style="display:flex;gap:1rem;align-items:center;margin-bottom:1.5rem">
  <form method="GET" action="{{ path('admin_transport_index') }}" style="flex:1;display:flex;gap:.5rem">
    <input type="text" name="q" value="{{ q }}" placeholder="Rechercher par compagnie, numéro…" style="flex:1;padding:.55rem .9rem;border:1px solid var(--border);border-radius:8px;font-size:.875rem;outline:none">
    <input type="hidden" name="sort" value="{{ sort|default('id') }}">
    <input type="hidden" name="order" value="{{ order|default('ASC') }}">
    <button type="submit" class="btn btn-secondary"><i class="fas fa-search"></i></button>
    {% if q %}<a href="{{ path('admin_transport_index') }}" class="btn btn-secondary"><i class="fas fa-times"></i></a>{% endif %}
  </form>
  <div style="display:flex;gap:.5rem">
    <a href="{{ path('user_transport_recommendation_index') }}" class="btn" style="background:var(--navy);color:var(--gold);border:1px solid var(--gold);border-radius:50px;padding:.85rem 1.5rem;text-decoration:none;font-weight:700;display:flex;align-items:center;gap:.5rem"><i class="fas fa-robot"></i> Simulateur IA</a>
    <a href="{{ path('admin_transport_pdf') }}?q={{ q|default('') }}&sort={{ sort|default('id') }}&order={{ order|default('ASC') }}" class="btn" style="background:#dc2626;color:white;border-radius:50px;padding:.85rem 1.5rem;text-decoration:none;font-weight:700;display:flex;align-items:center;gap:.5rem" target="_blank"><i class="fas fa-file-pdf"></i> Impression PDF</a>
    <a href="{{ path('admin_transport_new') }}" class="btn btn-primary"><i class="fas fa-plus"></i> Nouveau véhicule</a>
  </div>
</div>

{% if weather %}
<div style="background:#fff;border-left:5px solid var(--{{ weather.color }});padding:1rem 1.5rem;border-radius:12px;margin-bottom:1.5rem;display:flex;align-items:center;gap:1.5rem;box-shadow:var(--shadow)">
  <div style="font-size:2rem;color:var(--{{ weather.color }})">
    {% if weather.status == 'Danger' %}<i class="fas fa-exclamation-triangle"></i>
    {% elseif weather.status == 'Warning' %}<i class="fas fa-cloud-sun-rain"></i>
    {% else %}<i class="fas fa-sun"></i>{% endif %}
  </div>
  <div style="flex:1">
    <span class="badge" style="background:var(--{{ weather.color }});color:#fff;margin-bottom:.3rem">API B : Conseil Météo - {{ weather.status }}</span>
    <p style="margin:0;font-weight:600;color:var(--navy)">{{ weather.message }}</p>
    <small style="color:var(--muted)">Température actuelle à Tunis : {{ weather.temperature|default('—') }}°C | Vent : {{ weather.windspeed|default('—') }} km/h</small>
  </div>
</div>
{% endif %}

<div class="card">
  <div class="card-header">
    <h2><i class="fas fa-truck" style="color:var(--gold);margin-right:.5rem"></i>{{ pagination.totalItemCount }} véhicule(s)</h2>
  </div>
  <div class="card-body" style="padding:0">
    {% if pagination is empty %}
      <div style="padding:2.5rem;text-align:center;color:var(--muted);">
        <i class="fas fa-inbox" style="font-size:2.5rem;margin-bottom:.8rem;display:block;opacity:.3"></i>
        Aucun véhicule trouvé. <a href="{{ path('admin_transport_new') }}" style="color:var(--gold)">Ajouter le premier</a>
      </div>
    {% else %}
      <table>
        <thead>
          <tr>
            <th><a href="?q={{ q }}&sort=id&order={{ sort == 'id' and order == 'ASC' ? 'DESC' : 'ASC' }}" style="color:var(--navy);text-decoration:none"># {% if sort == 'id' %}<i class="fas fa-sort-{{ order|lower }}"></i>{% endif %}</a></th>
            <th>Image</th>
            <th><a href="?q={{ q }}&sort=compagnie&order={{ sort == 'compagnie' and order == 'ASC' ? 'DESC' : 'ASC' }}" style="color:var(--navy);text-decoration:none">Compagnie {% if sort == 'compagnie' %}<i class="fas fa-sort-{{ order|lower }}"></i>{% endif %}</a></th>
            <th><a href="?q={{ q }}&sort=numero&order={{ sort == 'numero' and order == 'ASC' ? 'DESC' : 'ASC' }}" style="color:var(--navy);text-decoration:none">Numéro {% if sort == 'numero' %}<i class="fas fa-sort-{{ order|lower }}"></i>{% endif %}</a></th>
            <th>Type</th>
            <th><a href="?q={{ q }}&sort=capacite&order={{ sort == 'capacite' and order == 'ASC' ? 'DESC' : 'ASC' }}" style="color:var(--navy);text-decoration:none">Capacité {% if sort == 'capacite' %}<i class="fas fa-sort-{{ order|lower }}"></i>{% endif %}</a></th>
            <th><a href="?q={{ q }}&sort=prix&order={{ sort == 'prix' and order == 'ASC' ? 'DESC' : 'ASC' }}" style="color:var(--navy);text-decoration:none">Prix/place {% if sort == 'prix' %}<i class="fas fa-sort-{{ order|lower }}"></i>{% endif %}</a></th>
            <th>Réservations</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for t in pagination %}
          <tr>
            <td style="color:var(--muted);font-size:.8rem">{{ t.id }}</td>
            <td>
              {% if t.imageUrl %}
                <img src="{{ t.imageUrl }}" alt="{{ t.compagnie }}" style="width:52px;height:36px;object-fit:cover;border-radius:6px;border:1px solid var(--border)">
              {% else %}
                <div style="width:52px;height:36px;background:#f1f5f9;border-radius:6px;display:flex;align-items:center;justify-content:center;color:var(--muted)"><i class="fas fa-bus"></i></div>
              {% endif %}
            </td>
            <td><strong>{{ t.compagnie }}</strong></td>
            <td><code style="background:#f1f5f9;padding:.2rem .4rem;border-radius:4px;font-size:.8rem">{{ t.numero }}</code></td>
            <td>
              <span class="badge" style="background:rgba(201,168,76,0.1);color:var(--gold)">{{ t.transportType.nom }}</span>
            </td>
            <td>{{ t.capacite }} places</td>
            <td><strong style="color:var(--gold)">{{ t.prix|number_format(2, ',', ' ') }} DT</strong></td>
            <td>
              <span class="badge" style="background:rgba(59,130,246,0.1);color:var(--accent)">{{ t.reservations|length }}</span>
            </td>
            <td>
              <div style="display:flex;gap:.4rem;flex-wrap:wrap">
                <a href="{{ path('admin_transport_show', {id: t.id}) }}" class="btn btn-secondary btn-sm"><i class="fas fa-eye"></i></a>
                <a href="{{ path('admin_transport_edit', {id: t.id}) }}" class="btn btn-secondary btn-sm"><i class="fas fa-edit"></i></a>
                <form method="POST" action="{{ path('admin_transport_delete', {id: t.id}) }}" onsubmit="return confirm('Supprimer ce véhicule ?')">
                  <input type="hidden" name="_token" value="{{ csrf_token('delete_transport_' ~ t.id) }}">
                  <button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button>
                </form>
              </div>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </div>
  <div class="card-footer" style="padding:1rem;display:flex;justify-content:center">
    {{ knp_pagination_render(pagination) }}
  </div>
</div>
{% endblock %}
