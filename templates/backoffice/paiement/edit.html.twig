{% extends 'BackOffice/base_admin.html.twig' %}

{% block title %}Modifier Paiement – Admin{% endblock %}
{% block page_title %}Mise à jour Transaction #{{ paiement.id }}{% endblock %}

{% block body %}
<div class="card">
    <div class="card-header">
        <h2><i class="fa-solid fa-edit" style="color:var(--gold);margin-right:.5rem"></i>Modification Financière</h2>
        <a href="{{ path('app_admin_paiement_index') }}" class="btn btn-secondary btn-sm">
            <i class="fa-solid fa-arrow-left"></i> Retour
        </a>
    </div>
    <div class="card-body">
        <form method="post" class="voyage-form">
            <div class="form-grid">
                <div class="form-group">
                    <label>Utilisateur Bénéficiaire</label>
                    <input type="text" class="input-pro" value="{{ paiement.user.email }}" disabled>
                    <input type="hidden" name="user_id" value="{{ paiement.user.id }}">
                </div>

                <div class="form-group">
                    <label for="subscription_id">Abonnement lié (optionnel)</label>
                    <select name="subscription_id" id="subscription_id" class="input-pro">
                        <option value="">Aucun abonnement</option>
                        {% for sub in subscriptions %}
                            <option value="{{ sub.id }}" {% if paiement.subscription and paiement.subscription.id == sub.id %}selected{% endif %}>
                                #{{ sub.id }} - {{ sub.plan|capitalize }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            <div class="form-grid">
                <div class="form-group">
                    <label for="amount">Montant Transaction (DT)</label>
                    <input type="number" step="0.01" name="amount" id="amount" class="input-pro" value="{{ paiement.amount }}" required>
                </div>

                <div class="form-group">
                    <label for="methode_paiement">Mode de Règlement</label>
                    <select name="methode_paiement" id="methode_paiement" class="input-pro" required>
                        <option value="Stripe" {% if paiement.methodePaiement == 'Stripe' %}selected{% endif %}>💳 Carte Bancaire (Stripe)</option>
                        <option value="Wallet" {% if paiement.methodePaiement == 'Wallet' %}selected{% endif %}>👛 Portefeuille VoyageElite</option>
                        <option value="Espèces" {% if paiement.methodePaiement == 'Espèces' %}selected{% endif %}>💵 Règlement Espèces</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label for="status">Statut de la Transaction</label>
                <select name="status" id="status" class="input-pro" required>
                    <option value="En attente" {% if paiement.status == 'En attente' %}selected{% endif %}>🕒 En attente</option>
                    <option value="Effectué" {% if paiement.status == 'Effectué' %}selected{% endif %}>✅ Effectué</option>
                    <option value="Refusé" {% if paiement.status == 'Refusé' %}selected{% endif %}>❌ Refusé</option>
                </select>
            </div>

            <div style="margin: 2rem 0; padding: 1.5rem; background: #f8fafc; border-radius: 12px; border: 1px solid var(--border);">
                <h3 style="font-size: .85rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 1.5rem; color: var(--navy);">
                    <i class="fa-solid fa-file-invoice" style="color:var(--gold); margin-right:.5rem"></i>Détails de Facturation
                </h3>
                
                <div class="form-grid">
                    <div class="form-group">
                        <label for="nom">Nom</label>
                        <input type="text" name="nom" id="nom" class="input-pro" value="{{ paiement.nom }}" required>
                    </div>
                    <div class="form-group">
                        <label for="prenom">Prénom</label>
                        <input type="text" name="prenom" id="prenom" class="input-pro" value="{{ paiement.prenom }}" required>
                    </div>
                </div>

                <div class="form-grid">
                    <div class="form-group">
                        <label for="email">Email Facturation</label>
                        <input type="email" name="email" id="email" class="input-pro" value="{{ paiement.email }}" required>
                    </div>
                    <div class="form-group">
                        <label for="telephone">Téléphone</label>
                        <input type="text" name="telephone" id="telephone" class="input-pro" value="{{ paiement.telephone }}" required maxlength="8">
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-save"></i> Enregistrer les modifications
                </button>
                <a href="{{ path('app_admin_paiement_index') }}" class="btn btn-secondary">Annuler</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
