{% extends 'BackOffice/base_admin.html.twig' %}
{% block title %}Historique Transport – Admin{% endblock %}
{% block page_title %}Historique des Transports (Réservations){% endblock %}

{% block body %}
<div class="stat-row">
  <div class="stat-card">
    <div class="stat-icon gold"><i class="fas fa-calendar-alt"></i></div>
    <div><div class="stat-value">{{ pagination.totalItemCount }}</div><div class="stat-label">Total réservations</div></div>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h2><i class="fas fa-calendar-check" style="color:var(--gold);margin-right:.5rem"></i>Liste des réservations</h2>
  </div>
  <div class="card-body" style="padding:0">
    {% if pagination is empty %}
      <div style="padding:2.5rem;text-align:center;color:var(--muted)">
        <i class="fas fa-inbox" style="font-size:2.5rem;margin-bottom:.8rem;display:block;opacity:.3"></i>
        Aucune réservation enregistrée.
      </div>
    {% else %}
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Client</th>
            <th>Email</th>
            <th>Véhicule</th>
            <th>Type</th>
            <th>Places</th>
            <th>Montant</th>
            <th>Date</th>
            <th>Statut</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for r in pagination %}
          <tr>
            <td style="color:var(--muted);font-size:.8rem">{{ r.id }}</td>
            <td><strong>{{ r.nomClient }}</strong></td>
            <td style="font-size:.8rem;color:var(--muted)">{{ r.emailClient }}</td>
            <td>{{ r.transport.compagnie }} <span style="color:var(--muted);font-size:.78rem">({{ r.transport.numero }})</span></td>
            <td><span class="badge" style="background:rgba(201,168,76,0.1);color:var(--gold)">{{ r.transport.transportType.nom }}</span></td>
            <td>{{ r.nombrePlaces }}</td>
            <td><strong style="color:var(--gold)">{{ r.montantTotal|number_format(2, ',', ' ') }} DT</strong></td>
            <td style="font-size:.8rem">{{ r.dateReservation|date('d/m/Y H:i') }}</td>
            <td>
              {% if r.statut == 'confirmee' %}
                <span class="badge badge-confirm">Confirmée</span>
              {% elseif r.statut == 'annulee' %}
                <span class="badge badge-cancel">Annulée</span>
              {% else %}
                <span class="badge badge-pending">En attente</span>
              {% endif %}
            </td>
            <td>
              <a href="{{ path('admin_reservation_show', {id: r.id}) }}" class="btn btn-secondary btn-sm"><i class="fas fa-eye"></i></a>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </div>
  <div class="card-footer" style="padding:1rem;display:flex;justify-content:center">
    {{ knp_pagination_render(pagination) }}
  </div>
</div>
{% endblock %}
