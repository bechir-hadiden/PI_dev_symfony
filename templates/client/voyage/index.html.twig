{% extends 'base_dark.html.twig' %}
{% block title %}Nos Voyages — SmartTrip{% endblock %}

{% block body %}

{# ── HERO ── #}
<div style="background:var(--navy);padding:7rem 5% 4rem;border-bottom:1px solid rgba(201,168,76,0.15);position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:url('https://images.unsplash.com/photo-1436491865332-7a61a109cc05?w=1920&q=80') center/cover no-repeat;opacity:0.07;"></div>
  <div style="position:relative;z-index:2;text-align:center;">
    <span class="section-label">Partez à l'aventure</span>
    <h1 class="section-title light" style="margin-bottom:1rem;">Nos Voyages</h1>
    <p style="color:rgba(255,255,255,0.5);font-size:1rem;max-width:500px;margin:0 auto 2rem;">
      Des voyages sur-mesure pour chaque envie, chaque budget, chaque rêve.
    </p>

    {# ── RECHERCHE + FILTRE ── #}
    <form method="GET" action="" style="display:flex;gap:.75rem;max-width:600px;margin:0 auto;flex-wrap:wrap;justify-content:center;">

      <input type="text" name="q" value="{{ query }}"
             placeholder="Rechercher un voyage..."
             style="flex:1;min-width:200px;padding:.85rem 1.2rem;background:rgba(255,255,255,0.08);border:1px solid rgba(201,168,76,0.25);border-radius:10px;color:var(--white);font-family:'Plus Jakarta Sans',sans-serif;font-size:.9rem;outline:none;">

      <select name="destination"
              style="padding:.85rem 1.1rem;background:rgba(255,255,255,0.08);border:1px solid rgba(201,168,76,0.25);border-radius:10px;color:var(--white);font-family:'Plus Jakarta Sans',sans-serif;font-size:.85rem;outline:none;cursor:pointer;">
        <option value="" style="background:var(--navy);">Toutes destinations</option>
        {% for dest in destinations %}
          <option value="{{ dest.id }}" style="background:var(--navy);"
                  {{ filtreDestId == dest.id ? 'selected' : '' }}>
            {{ dest.nom }} — {{ dest.pays }}
          </option>
        {% endfor %}
      </select>

      <button type="submit"
              style="padding:.85rem 1.4rem;background:var(--gold);color:var(--navy);border:none;border-radius:10px;font-weight:700;cursor:pointer;font-family:inherit;transition:transform .2s;"
              onmouseover="this.style.transform='translateY(-2px)'"
              onmouseout="this.style.transform='translateY(0)'">
        <i class="fas fa-search"></i>
      </button>

      {% if query or filtreDestId %}
        <a href="{{ path('client_voyage_index') }}"
           style="padding:.85rem 1.2rem;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);border-radius:10px;color:rgba(255,255,255,0.6);font-size:.85rem;text-decoration:none;display:flex;align-items:center;gap:.4rem;transition:color .2s;"
           onmouseover="this.style.color='var(--white)'"
           onmouseout="this.style.color='rgba(255,255,255,0.6)'">
          <i class="fas fa-times"></i> Réinitialiser
        </a>
      {% endif %}

    </form>
  </div>
</div>

{# ── CONTENU ── #}
<div style="padding:3rem 5%;background:var(--cream);">

  {# Compteur #}
  <div style="margin-bottom:2rem;">
    <p style="font-size:.85rem;color:var(--muted);">
      {% if voyages|length > 0 %}
        <strong style="color:var(--navy);">{{ voyages|length }}</strong>
        voyage{{ voyages|length > 1 ? 's' : '' }} trouvé{{ voyages|length > 1 ? 's' : '' }}
        {% if query %} pour <em>"{{ query }}"</em>{% endif %}
        {% if filtreDestId %} dans cette destination{% endif %}
      {% endif %}
    </p>
  </div>

  {# ── GRILLE VOYAGES ── #}
  {% if voyages is empty %}
    <div style="text-align:center;padding:5rem 2rem;color:var(--muted);">
      <div style="font-size:4rem;margin-bottom:1rem;">✈️</div>
      <h3 style="font-family:'Playfair Display',serif;color:var(--navy);margin-bottom:.5rem;">Aucun voyage trouvé</h3>
      <p style="font-size:.9rem;">Essayez une autre recherche ou modifiez le filtre.</p>
      <a href="{{ path('client_voyage_index') }}" style="display:inline-block;margin-top:1rem;color:var(--gold);text-decoration:none;font-weight:600;">
        ← Voir tous les voyages
      </a>
    </div>

  {% else %}
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.5rem;">

      {% for voyage in voyages %}

        {# Résoudre la meilleure image disponible #}
        {% set imgFinal = voyage.firstImagePath 
            ?? (voyage.destinationRel ? voyage.destinationRel.firstImage : null) %}

        <a href="{{ path('client_voyage_show', {id: voyage.id}) }}"
           style="text-decoration:none;display:flex;flex-direction:column;background:var(--white);border-radius:16px;overflow:hidden;box-shadow:0 2px 16px rgba(13,27,42,0.08);transition:transform .3s,box-shadow .3s;border:1px solid rgba(13,27,42,0.06);"
           onmouseover="this.style.transform='translateY(-6px)';this.style.boxShadow='0 12px 40px rgba(13,27,42,0.16)'"
           onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 2px 16px rgba(13,27,42,0.08)'">

          {# ── Image ── #}
          <div style="position:relative;height:200px;overflow:hidden;background:var(--navy);flex-shrink:0;">
            {% if imgFinal %}
              <img src="{{ imgFinal starts with 'http' ? imgFinal : asset(imgFinal) }}"
                   alt="{{ voyage.destination }}"
                   style="width:100%;height:100%;object-fit:cover;transition:transform .4s;"
                   onmouseover="this.style.transform='scale(1.06)'"
                   onmouseout="this.style.transform='scale(1)'"
                   onerror="this.parentElement.innerHTML='<div style=\'width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:3rem;opacity:.3;\'>✈️</div>'">
            {% else %}
              <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:3rem;opacity:.3;">✈️</div>
            {% endif %}
          </div>

          {# ── Contenu carte ── #}
          <div style="padding:1.25rem;display:flex;flex-direction:column;flex:1;">
            <h3 style="font-family:'Playfair Display',serif;color:var(--navy);font-size:1.1rem;margin:0 0 .3rem;">
              {{ voyage.destination }}
            </h3>
            <p style="color:var(--muted);font-size:.82rem;margin:0 0 .8rem;">
              <i class="fas fa-map-marker-alt" style="color:var(--gold);margin-right:.3rem;"></i>
              {{ voyage.destinationRel ? voyage.destinationRel.pays : '' }}
            </p>

            <div style="margin-top:auto;display:flex;justify-content:space-between;align-items:center;">
              <span style="font-size:1rem;font-weight:700;color:var(--gold);">
                {{ voyage.prix ?? '—' }} TND
              </span>
              <span style="font-size:.78rem;color:var(--muted);">
                <i class="fas fa-calendar-alt" style="margin-right:.3rem;"></i>
                {{ voyage.dateDebut ? voyage.dateDebut|date('d/m/Y') : '—' }}
              </span>
            </div>
          </div>

        </a>
      {% endfor %}

    </div>
  {% endif %}

</div>

{% endblock %}
