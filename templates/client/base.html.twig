<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}SmartTrip{% endblock %} — Agence de Voyage</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,300;0,400;0,700;1,300;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --ink:      #0d1b2a;
            --gold:     #c9a84c;
            --gold-lt:  #dfc07a;
            --cream:    #f5f0e8;
            --sand:     #ede6d5;
            --muted:    #6b6560;
            --white:    #ffffff;
            --ink-soft: rgba(13,27,42,0.06);
        }

        html { scroll-behavior: smooth; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: var(--cream);
            color: var(--ink);
            overflow-x: hidden;
        }

        /* ── NAV ── */
        nav {
            position: fixed; top: 0; left: 0; right: 0; z-index: 100;
            display: flex; align-items: center; justify-content: space-between;
            padding: 1.3rem 3.5rem;
            background: rgba(245, 240, 232, 0.9);
            backdrop-filter: blur(14px);
            border-bottom: 0.5px solid rgba(201,168,76,0.3);
        }
        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 1.55rem; font-weight: 400; letter-spacing: 0.06em;
            color: var(--ink); text-decoration: none;
        }
        .logo em { font-style: italic; color: var(--gold); }
        .nav-links { display: flex; gap: 2.2rem; list-style: none; }
        .nav-links a {
            font-size: 0.76rem; font-weight: 500; letter-spacing: 0.12em;
            text-transform: uppercase; color: var(--muted);
            text-decoration: none; transition: color 0.2s;
        }
        .nav-links a:hover, .nav-links a.active { color: var(--gold); }
        .nav-cta {
            font-size: 0.74rem; font-weight: 600; letter-spacing: 0.12em;
            text-transform: uppercase; color: var(--ink);
            border: 0.5px solid var(--gold); padding: 0.55rem 1.4rem;
            text-decoration: none; transition: all 0.25s;
        }
        .nav-cta:hover { background: var(--gold); color: var(--white); }

        /* ── FLASH MESSAGES ── */
        .flash-wrapper {
            position: fixed; top: 5rem; right: 1.5rem; z-index: 200;
            display: flex; flex-direction: column; gap: 0.6rem;
        }
        .flash {
            padding: 0.9rem 1.4rem; font-size: 0.82rem; font-weight: 500;
            border-left: 3px solid; max-width: 320px;
            animation: slideIn 0.4s ease forwards;
        }
        .flash.success { background: #f0faf4; border-color: #4caf6b; color: #1e4d2b; }
        .flash.error   { background: #fdf3f3; border-color: #e05c5c; color: #6b1f1f; }
        @keyframes slideIn { from { opacity:0; transform:translateX(20px); } to { opacity:1; transform:translateX(0); } }

        /* ── FOOTER ── */
        footer {
            background: var(--ink); padding: 3rem 3.5rem;
            display: grid; grid-template-columns: 1fr auto 1fr;
            align-items: center; gap: 2rem;
            border-top: 0.5px solid rgba(201,168,76,0.2);
        }
        .footer-logo {
            font-family: 'Playfair Display', serif;
            font-size: 1.35rem; font-weight: 400; letter-spacing: 0.08em;
            color: var(--white); text-decoration: none;
        }
        .footer-logo em { font-style: italic; color: var(--gold); }
        .footer-links { display: flex; gap: 2rem; justify-content: center; }
        .footer-links a {
            font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase;
            color: rgba(245,240,232,0.4); text-decoration: none; transition: color 0.2s;
        }
        .footer-links a:hover { color: var(--gold); }
        .footer-copy {
            font-size: 0.7rem; color: rgba(245,240,232,0.25);
            letter-spacing: 0.06em; text-align: right;
        }

        /* ── UTILITIES ── */
        .section-tag {
            font-size: 0.7rem; letter-spacing: 0.22em; text-transform: uppercase;
            color: var(--gold); display: flex; align-items: center; gap: 0.7rem;
            margin-bottom: 0.9rem;
        }
        .section-tag::before {
            content:''; display:block; width:28px; height:0.5px; background:var(--gold);
        }
        h2.serif {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2rem,3.5vw,3rem); font-weight: 300; line-height: 1.15;
        }
        .btn-primary {
            display: inline-block; background: var(--ink); color: var(--white);
            padding: 0.85rem 2rem; font-size: 0.78rem; font-weight: 600;
            letter-spacing: 0.12em; text-transform: uppercase;
            text-decoration: none; transition: all 0.25s; border: none; cursor: pointer;
        }
        .btn-primary:hover { background: var(--gold); color: var(--white); }
        .btn-outline {
            display: inline-block; border: 0.5px solid var(--gold);
            color: var(--ink); padding: 0.75rem 1.6rem; font-size: 0.76rem;
            font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
            text-decoration: none; transition: all 0.25s;
        }
        .btn-outline:hover { background: var(--gold); color: var(--white); }
        .btn-ghost {
            font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase;
            font-weight: 500; color: var(--muted); text-decoration: none;
            display: inline-flex; align-items: center; gap: 0.5rem; transition: color 0.2s;
        }
        .btn-ghost .arrow { transition: transform 0.2s; }
        .btn-ghost:hover { color: var(--ink); }
        .btn-ghost:hover .arrow { transform: translateX(4px); }

        /* ── TICKER ── */
        .ticker-wrap {
            background: var(--gold); overflow: hidden; padding: 0.65rem 0;
        }
        .ticker {
            display: flex; animation: ticker 30s linear infinite; white-space: nowrap;
        }
        .ticker span {
            font-size: 0.7rem; letter-spacing: 0.22em; text-transform: uppercase;
            color: var(--ink); padding: 0 1.8rem;
        }
        .ticker-dot { color: rgba(0,0,0,0.3); user-select: none; }
        @keyframes ticker { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }

        {% block extra_css %}{% endblock %}
    </style>
</head>
<body>

{# ── FLASH MESSAGES ── #}
{% for label, messages in app.flashes %}
    <div class="flash-wrapper">
        {% for msg in messages %}
            <div class="flash {{ label }}">{{ msg }}</div>
        {% endfor %}
    </div>
{% endfor %}

{# ── NAV ── #}
<nav>
    <a href="{{ path('app_home') }}" class="logo">Smart<em>trip</em></a>
    <ul class="nav-links">
        <li><a href="{{ path('app_home') }}" class="{{ app.request.attributes.get('_route') == 'app_home' ? 'active' }}">Accueil</a></li>
        <li><a href="{{ path('client_destination_index') }}" class="{{ app.request.attributes.get('_route') starts with 'client_destination' ? 'active' }}">Destinations</a></li>
        <li><a href="{{ path('client_voyage_index') }}" class="{{ app.request.attributes.get('_route') starts with 'client_voyage' ? 'active' }}">Voyages</a></li>
        <li><a href="{{ path('app_home') }}#contact">Contact</a></li>
    </ul>
    <a href="{{ path('client_voyage_index') }}" class="nav-cta">Réserver</a>
</nav>

{% block body %}{% endblock %}

{# ── TICKER ── #}
<div class="ticker-wrap">
    <div class="ticker">
        {% set cities = ['Djerba','Paris','Dubai','Tokyo','Maldives','Marrakech','Bali','Santorin','Islande','New York','Kyoto','Amalfi'] %}
        {% for city in cities %}<span>{{ city }}</span><span class="ticker-dot">✦</span>{% endfor %}
        {% for city in cities %}<span>{{ city }}</span><span class="ticker-dot">✦</span>{% endfor %}
    </div>
</div>

{# ── FOOTER ── #}
<footer>
    <a href="{{ path('app_home') }}" class="footer-logo">Travel<em>Pro</em></a>
    <div class="footer-links">
        <a href="{{ path('client_destination_index') }}">Destinations</a>
        <a href="{{ path('client_voyage_index') }}">Voyages</a>
        <a href="{{ path('app_home') }}#contact">Contact</a>
    </div>
    <div class="footer-copy">© {{ "now"|date("Y") }} SmartTrip. Tous droits réservés.</div>
</footer>

{% block javascripts %}{% endblock %}
</body>
</html>
