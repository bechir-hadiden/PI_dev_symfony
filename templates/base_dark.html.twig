{# ══ JAVASCRIPT ══════════════════════════════════════════════════ #}
{% block javascripts %}
<script>
  window.addEventListener('scroll', () => {
    const nav = document.getElementById('navbar');
    if (!nav) return;
    nav.style.background = window.scrollY > 50 ? 'rgba(13,27,42,0.99)' : 'rgba(13,27,42,0.96)';
  });

  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', e => {
      const href = a.getAttribute('href');
      if (href === '#') return;
      const t = document.querySelector(href);
      if (t) { e.preventDefault(); t.scrollIntoView({behavior:'smooth'}); }
    });
  });

  // Dropdown handler
  document.addEventListener('DOMContentLoaded', function() {
      const dropdowns = document.querySelectorAll('.dropdown');
      dropdowns.forEach(dropdown => {
          const link = dropdown.querySelector('a');
          link.addEventListener('click', function(e) {
              e.preventDefault();
              e.stopPropagation();
              dropdowns.forEach(d => { if (d !== dropdown) d.classList.remove('active'); });
              dropdown.classList.toggle('active');
          });
      });
      document.addEventListener('click', () => dropdowns.forEach(d => d.classList.remove('active')));
  });

  function openModal() {
    document.getElementById('loginModal').classList.add('open');
    document.body.style.overflow = 'hidden';
    setTimeout(() => document.getElementById('modal_email')?.focus(), 100);
  }

  function closeModal() {
    document.getElementById('loginModal')?.classList.remove('open');
    document.body.style.overflow = '';
    const video = document.getElementById('webcam');
    if (video && video.srcObject) {
      video.srcObject.getTracks().forEach(t => t.stop());
      video.srcObject = null;
      cameraStarted = false;
    }
  }

  document.getElementById('loginModal')?.addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });

  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

  {% if app.request.attributes.get('_route') == 'app_login' and error is defined and error %}
    document.addEventListener('DOMContentLoaded', () => openModal());
  {% endif %}

  function switchTab(tab) {
    const isPassword = tab === 'password';
    document.getElementById('panel-password').style.display = isPassword ? 'block' : 'none';
    document.getElementById('panel-faceid').style.display   = isPassword ? 'none'  : 'block';
    const tabPwd  = document.getElementById('tab-password');
    const tabFace = document.getElementById('tab-faceid');
    if (isPassword) {
      tabPwd.style.cssText  += 'background:linear-gradient(135deg,var(--gold),var(--gold-l));color:var(--navy);border:1px solid var(--gold);font-weight:700;';
      tabFace.style.cssText += 'background:transparent;color:rgba(255,255,255,0.6);border:1px solid rgba(201,168,76,0.3);font-weight:600;';
    } else {
      tabFace.style.cssText += 'background:linear-gradient(135deg,var(--gold),var(--gold-l));color:var(--navy);border:1px solid var(--gold);font-weight:700;';
      tabPwd.style.cssText  += 'background:transparent;color:rgba(255,255,255,0.6);border:1px solid rgba(201,168,76,0.3);font-weight:600;';
      startCamera();
    }
  }

  let cameraStarted = false;
  function startCamera() {
    if (cameraStarted) return;
    const video  = document.getElementById('webcam');
    const result = document.getElementById('faceResult');
    if (!video) return;
    navigator.mediaDevices.getUserMedia({ video: true })
      .then(stream => { video.srcObject = stream; cameraStarted = true; })
      .catch(() => {
        if (result) { result.textContent = '❌ Caméra non accessible'; result.style.color = '#f87171'; }
      });
  }

  document.getElementById('faceLoginBtn')?.addEventListener('click', async () => {
    const result = document.getElementById('faceResult');
    const btn    = document.getElementById('faceLoginBtn');
    const video  = document.getElementById('webcam');
    const canvas = document.getElementById('canvas');
    const ctx    = canvas.getContext('2d');
    ctx.drawImage(video, 0, 0, 320, 240);
    result.textContent = '⏳ Identification en cours...';
    result.style.color = 'rgba(255,255,255,0.6)';
    btn.disabled = true;
    const formData = new FormData();
    formData.append('face_image', canvas.toDataURL('image/jpeg'));
    try {
      const res  = await fetch('/face-login', { method: 'POST', body: formData });
      const data = await res.json();
      if (data.success) {
        result.textContent = `✅ Bienvenue ! (${data.confidence}%)`;
        result.style.color = '#4ade80';
        setTimeout(() => window.location.href = data.redirect, 1200);
      } else {
        result.textContent = `❌ ${data.error ?? 'Visage non reconnu'} (${data.confidence ?? 0}%)`;
        result.style.color = '#f87171';
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-camera"></i> Réessayer';
      }
    } catch (e) {
      result.textContent = '❌ Erreur réseau';
      result.style.color = '#f87171';
      btn.disabled = false;
    }
  });
</script>
{% endblock %}

</body>
</html>
