<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}SmartTrip{% endblock %}</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.6.0/css/all.min.css">
  <style>
    :root {
      --navy:   #0d1b2a;
      --navy-2: #112236;
      --gold:   #c9a84c;
      --gold-l: #e8c97a;
      --cream:  #f5f0e8;
      --white:  #ffffff;
      --muted:  #7a8a99;
      --shadow: 0 8px 32px rgba(13,27,42,0.18);
    }
    * { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior:smooth; }
    body { font-family:'Plus Jakarta Sans',sans-serif; background:var(--cream); color:var(--navy); overflow-x:hidden; }

    /* ── NAV ── */
    nav {
      position:fixed; top:0; width:100%; z-index:1000;
      display:flex; align-items:center; justify-content:space-between;
      padding:1.1rem 5%;
      background:rgba(13,27,42,0.96);
      backdrop-filter:blur(20px);
      border-bottom:1px solid rgba(201,168,76,0.2);
      transition:all .3s;
    }
    .nav-logo { font-family:'Playfair Display',serif; font-size:1.5rem; font-weight:700; color:var(--gold); text-decoration:none; letter-spacing:1px; }
    .nav-logo span { color:var(--white); }
    .nav-links { display:flex; gap:1.2rem; list-style:none; }
    .nav-links a { color:rgba(255,255,255,0.7); text-decoration:none; font-size: 0.78rem; font-weight: 600; letter-spacing: 0.3px; transition:color .3s; position:relative; }
    .nav-links a::after { content:''; position:absolute; bottom:-4px; left:0; width:0; height:1px; background:var(--gold); transition:width .3s; }
    .nav-links a:hover, .dropdown:hover > a { color:var(--gold); }
    .nav-links a:hover::after, .dropdown:hover > a::after { width:100%; }
    .nav-cta { background:linear-gradient(135deg,var(--gold),var(--gold-l)); color:var(--navy) !important; padding:.55rem 1.4rem; border-radius:50px; font-weight:700 !important; }

    /* ── DROPDOWNS ── */
    .dropdown { position: relative; display: inline-block; }
    .dropdown-content {
      display: none; position: absolute; top: 100%; left: 50%; transform: translateX(-50%);
      background: rgba(13,27,42,0.98); border: 1px solid rgba(201,168,76,0.3); border-radius: 12px;
      min-width: 200px; box-shadow: 0 15px 40px rgba(0,0,0,0.4); z-index: 1000; padding: 0.8rem 0;
      backdrop-filter: blur(15px); margin-top: 10px; animation: navFadeUp 0.3s ease;
      list-style: none;
    }
    .dropdown-content::before { content: ''; position: absolute; top: -6px; left: 50%; transform: translateX(-50%); border-left: 6px solid transparent; border-right: 6px solid transparent; border-bottom: 6px solid rgba(201,168,76,0.3); }
    .dropdown.active .dropdown-content { display: block; }
    .dropdown-content li { width: 100%; }
    .dropdown-content a { display: block; padding: 0.7rem 1.5rem; text-align: left; font-size: 0.75rem; white-space: nowrap; }
    .dropdown-content a::after { display: none; }
    .dropdown-content a:hover { background: rgba(201,168,76,0.1); color: var(--gold); }
    
    @keyframes navFadeUp { from { opacity: 0; transform: translateX(-50%) translateY(10px); } to { opacity: 1; transform: translateX(-50%) translateY(0); } }

    /* ── FLASH ── */
    .flash { padding:1rem 5%; margin-top:72px; font-size:.875rem; position:relative; z-index: 1001; }
    .flash-success { background:rgba(74,222,128,.1); border-left:3px solid #4ade80; color:#166534; }
    .flash-error   { background:rgba(248,113,113,.1); border-left:3px solid #f87171; color:#991b1b; }

    /* ── HERO ── */
    .hero { min-height:100vh; position:relative; display:flex; align-items:center; overflow:hidden; }
    .hero-bg { position:absolute; inset:0; background:url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1920&q=80') center/cover no-repeat; }
    .hero-overlay { position:absolute; inset:0; background:linear-gradient(135deg,rgba(13,27,42,0.95) 0%,rgba(13,27,42,0.65) 50%,rgba(13,27,42,0.4) 100%); }
    .hero-content { position:relative; z-index:2; padding:0 5%; max-width:720px; }
    .hero-badge { display:inline-flex; align-items:center; gap:.5rem; background:rgba(201,168,76,0.15); border:1px solid rgba(201,168,76,0.35); color:var(--gold); padding:.4rem 1rem; border-radius:50px; font-size:.75rem; font-weight:600; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:1.5rem; }
    .hero h1 { font-family:'Playfair Display',serif; font-size:clamp(2.5rem,6vw,5rem); line-height:1.1; margin-bottom:1.5rem; color:var(--white); }
    .hero h1 em { font-style:italic; color:var(--gold); }
    .hero p { font-size:1.05rem; color:rgba(255,255,255,0.7); line-height:1.75; margin-bottom:2.5rem; max-width:500px; }
    
    .hero-search { position:absolute; bottom:2.5rem; left:5%; right:5%; z-index:2; }
    .search-box { background:rgba(13,27,42,0.92); border:1px solid rgba(201,168,76,0.25); border-radius:16px; padding:1.4rem 2rem; display:flex; gap:1rem; align-items:center; flex-wrap:wrap; backdrop-filter:blur(20px); }
    .search-field { flex:1; min-width:140px; display:flex; flex-direction:column; gap:.25rem; }
    .search-field label { font-size:.65rem; text-transform:uppercase; letter-spacing:1.2px; color:var(--gold); font-weight:700; }
    .search-field input, .search-field select { background:transparent; border:none; outline:none; color:var(--white); font-size:.9rem; font-family:'Plus Jakarta Sans',sans-serif; cursor:pointer; }
    .search-btn { background:linear-gradient(135deg,var(--gold),var(--gold-l)); color:var(--navy); border:none; cursor:pointer; padding:.85rem 1.6rem; border-radius:10px; font-weight:700; font-size:.875rem; display:flex; align-items:center; gap:.5rem; transition:transform .3s; white-space:nowrap; }

    /* ── SECTIONS ── */
    section { padding:5rem 5%; }
    .section-label { display:inline-block; color:var(--gold); font-size:.72rem; font-weight:700; letter-spacing:2.5px; text-transform:uppercase; margin-bottom:.75rem; }
    .section-title { font-family:'Playfair Display',serif; font-size:clamp(1.8rem,3.5vw,2.8rem); color:var(--navy); line-height:1.2; margin-bottom:.75rem; }
    .section-title.light { color:var(--white); }
    .section-sub { color:var(--muted); font-size:.95rem; line-height:1.75; max-width:480px; }

    /* ── DESTINATIONS GRID ── */
    #destinations { background:var(--cream); }
    .dest-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.2rem; }
    .dest-card { position:relative; border-radius:14px; overflow:hidden; cursor:pointer; }
    .dest-card img { width:100%; height:100%; min-height:220px; object-fit:cover; transition:transform .6s; }
    .dest-overlay { position:absolute; inset:0; background:linear-gradient(to top,rgba(13,27,42,0.92) 0%,transparent 55%); display:flex; flex-direction:column; justify-content:flex-end; padding:1.6rem; }
    .dest-name { font-family:'Playfair Display',serif; font-size:1.3rem; color:var(--white); }

    /* ── PACKAGES & CARDS ── */
    #packages { background:var(--navy); }
    .packages-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.4rem; }
    .pkg-card { background:var(--navy-2); border:1px solid rgba(201,168,76,0.12); border-radius:14px; overflow:hidden; transition:transform .3s; }
    .pkg-body { padding:1.4rem; color: var(--white); }
    .pkg-price { color: var(--gold); font-size: 1.4rem; font-weight: 700; }

    /* ── ABOUT ── */
    #about { background:var(--cream); display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:center; }
    .about-img-main { width:100%; height:480px; object-fit:cover; border-radius:16px; }
    .about-feat { display:flex; gap:.9rem; background:var(--white); padding:1.1rem; border-radius:12px; margin-bottom: 1rem; }

    /* ── CONTACT ── */
    #contact { background:var(--navy); display:grid; grid-template-columns:1fr 1.5fr; gap:5rem; }
    .contact-form { background:rgba(255,255,255,0.04); border:1px solid rgba(201,168,76,0.15); border-radius:18px; padding:2.2rem; min-width: 100%; }
    .form-group { margin-bottom:1.1rem; }
    .form-group label { display:block; font-size:.72rem; color:rgba(255,255,255,0.55); text-transform:uppercase; margin-bottom:.45rem; }
    .form-group input, .form-group select, .form-group textarea { width:100%; background:rgba(255,255,255,0.06); border:1px solid rgba(201,168,76,0.15); border-radius:10px; padding:.75rem 1rem; color:var(--white); outline:none; }
    .btn-submit { background:linear-gradient(135deg,var(--gold),var(--gold-l)); color:var(--navy); border:none; padding:.95rem; border-radius:10px; font-weight:700; cursor:pointer; width: 100%; }

    /* ── ANIMATIONS ── */
    @keyframes fadeInUp { from{opacity:0;transform:translateY(28px)} to{opacity:1;transform:translateY(0)} }
    .fade-in { animation:fadeInUp .8s ease forwards; }
    .delay-1 { animation-delay:.2s; opacity:0; }
    .delay-2 { animation-delay:.4s; opacity:0; }

    /* ── FOOTER ── */
    footer { background:#07101a; border-top:1px solid rgba(201,168,76,0.1); padding:3.5rem 5% 2rem; color: white; }

    /* ───────────────────────────────────────────────────────────
       ── ELITE ADMIN DASHBOARD (CENTRALIZED)
       ─────────────────────────────────────────────────────────── */
    .admin-dashboard-wrapper { padding: 5rem 5% 6rem !important; background: #f8fafc !important; min-height: 100vh !important; color: #0f172a !important; font-family: 'Plus Jakarta Sans', sans-serif !important; }
    .admin-header { display: flex !important; justify-content: space-between !important; align-items: center !important; margin-bottom: 3.5rem !important; }
    .page-main-title { font-family: 'Playfair Display', serif !important; font-size: 2.2rem !important; color: #0f172a !important; }
    .page-main-title em { font-style: italic !important; color: var(--gold) !important; }
    .page-subtitle { color: #64748b !important; font-size: 0.95rem !important; }
    
    .btn-action-outline { border: 1.5px solid #e2e8f0 !important; color: #0f172a !important; padding: 0.8rem 1.4rem !important; border-radius: 12px !important; font-weight: 700 !important; text-decoration: none !important; display: flex !important; align-items: center !important; gap: 0.7rem !important; background: white !important; transition: all 0.3s !important; }
    .btn-action-primary { background: #0f172a !important; color: white !important; padding: 0.8rem 1.4rem !important; border-radius: 12px !important; font-weight: 700 !important; text-decoration: none !important; display: flex !important; align-items: center !important; gap: 0.7rem !important; }

    .metrics-container { display: grid !important; grid-template-columns: repeat(3, 1fr) !important; gap: 1.5rem !important; margin-bottom: 3.5rem !important; }
    .metric-box { padding: 2rem !important; border-radius: 24px !important; display: flex !important; align-items: center !important; gap: 1.5rem !important; box-shadow: 0 4px 20px rgba(0,0,0,0.02) !important; border: 1px solid #e2e8f0 !important; background: white !important; }
    .bg-pro-navy { background: #0f172a !important; color: white !important; }
    .icon-gold { color: var(--gold) !important; }
    .m-label { display: block !important; font-size: 0.7rem !important; text-transform: uppercase !important; letter-spacing: 1px !important; opacity: 0.6 !important; font-weight: 700 !important; }
    .m-val { font-size: 1.6rem !important; font-weight: 800 !important; display: block !important; }
    
    .table-section-pro { background: white !important; border-radius: 30px !important; box-shadow: 0 10px 40px rgba(0,0,0,0.03) !important; border: 1px solid #e2e8f0 !important; overflow: hidden !important; }
    .table-toolbar { padding: 1.5rem 2rem !important; border-bottom: 1px solid #f1f5f9 !important; display: flex !important; justify-content: space-between !important; align-items: center !important; background: #fafbfd !important; }
    .advanced-search { position: relative !important; width: 320px !important; }
    .advanced-search input { width: 100% !important; border: 1px solid #e2e8f0 !important; border-radius: 14px !important; padding: 0.8rem 1rem 0.8rem 3rem !important; }
    .advanced-search i { position: absolute !important; left: 1.2rem !important; top: 50% !important; transform: translateY(-50%) !important; color: #64748b !important; }
    
    .pro-admin-table { width: 100% !important; border-collapse: collapse !important; }
    .pro-admin-table thead th { text-align: left !important; padding: 1.2rem 1.5rem !important; font-size: 0.7rem !important; text-transform: uppercase !important; color: #64748b !important; font-weight: 800 !important; }
    .pro-row td { padding: 1.4rem 1.5rem !important; border-bottom: 1px solid #f1f5f9 !important; vertical-align: middle !important; }
    
    .badge-status { padding: 0.4rem 0.8rem !important; border-radius: 50px !important; font-size: 0.65rem !important; font-weight: 800 !important; text-transform: uppercase !important; display: inline-block !important; }
    .badge-status.st-success, .badge-status.active { background: #f0fdf4 !important; color: #166534 !important; }
    .badge-status.st-pending, .badge-status.suspended { background: #fffbeb !important; color: #92400e !important; }
    .badge-status.st-danger, .badge-status.cancelled { background: #fef2f2 !important; color: #991b1b !important; }
    
    .btn-sq { width: 36px !important; height: 36px !important; border-radius: 10px !important; background: white !important; border: 1.5px solid #f1f5f9 !important; display: flex !important; align-items: center !important; justify-content: center !important; cursor: pointer !important; text-decoration: none !important; color: #64748b !important; }
    .btn-sq:hover { border-color: var(--gold) !important; color: var(--gold) !important; transform: translateY(-2px) !important; }

    /* ── CARD-BASED MANAGEMENT (NEW) ── */
    .admin-cards-grid { display: grid !important; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)) !important; gap: 2rem !important; margin-top: 2rem !important; }
    .sub-card { background: white !important; border-radius: 24px !important; border: 1px solid #e2e8f0 !important; overflow: hidden !important; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important; position: relative !important; }
    .sub-card:hover { transform: translateY(-8px) !important; box-shadow: 0 20px 40px rgba(0,0,0,0.06) !important; border-color: var(--gold) !important; }
    
    .sub-card-header { padding: 1.5rem !important; background: #fafbfd !important; border-bottom: 1px solid #f1f5f9 !important; display: flex !important; justify-content: space-between !important; align-items: center !important; }
    .sub-card-header .plan-name { font-weight: 800 !important; text-transform: uppercase !important; letter-spacing: 1px !important; font-size: 0.85rem !important; color: #0f172a !important; }
    
    .sub-card-body { padding: 1.5rem !important; }
    .sub-card-user { display: flex !important; align-items: center !important; gap: 1rem !important; margin-bottom: 1.5rem !important; }
    .sub-card-user .avatar { width: 50px !important; height: 50px !important; border-radius: 50% !important; background: #f1f5f9 !important; display: flex !important; align-items: center !important; justify-content: center !important; font-weight: 800 !important; color: #0f172a !important; font-size: 1.2rem !important; }
    .sub-card-user .info { overflow: hidden !important; }
    .sub-card-user .email { display: block !important; font-weight: 700 !important; color: #0f172a !important; overflow: hidden !important; text-overflow: ellipsis !important; }
    
    .sub-card-stats { display: flex !important; justify-content: space-between !important; margin-bottom: 1rem !important; font-size: 0.8rem !important; color: #64748b !important; font-weight: 600 !important; }
    
    .sub-card-footer { padding: 1.2rem 1.5rem !important; background: #fafbfd !important; border-top: 1px solid #f1f5f9 !important; display: flex !important; justify-content: flex-end !important; gap: 0.8rem !important; }
    
    /* CLIENT VIP PASS */
    .vip-pass-card { max-width: 500px !important; margin: 0 auto !important; background: linear-gradient(135deg, #0d1b2a 0%, #1b263b 100%) !important; border-radius: 30px !important; padding: 3rem !important; color: white !important; position: relative !important; overflow: hidden !important; border: 1px solid rgba(201,168,76,0.2) !important; box-shadow: 0 40px 100px rgba(13,27,42,0.4) !important; }
    .vip-pass-card::before { content: '' !important; position: absolute !important; top: -50% !important; left: -50% !important; width: 200% !important; height: 200% !important; background: radial-gradient(circle, rgba(201,168,76,0.05) 0%, transparent 70%) !important; pointer-events: none !important; }
    .vip-pass-card .vip-glow { position: absolute !important; width: 150px !important; height: 150px !important; background: var(--gold) !important; filter: blur(100px) !important; opacity: 0.1 !important; top: -50px !important; right: -50px !important; }
    
    .vip-pass-title { font-family: 'Playfair Display', serif !important; font-size: 2.5rem !important; margin-bottom: 0.5rem !important; color: var(--gold) !important; }
    .vip-pass-subtitle { font-size: 0.9rem !important; opacity: 0.6 !important; letter-spacing: 2px !important; text-transform: uppercase !important; margin-bottom: 3rem !important; display: block !important; }
    
    .vip-pass-detail { margin-bottom: 1.5rem !important; }
    .vip-pass-detail label { display: block !important; font-size: 0.7rem !important; opacity: 0.4 !important; text-transform: uppercase !important; letter-spacing: 1px !important; margin-bottom: 0.3rem !important; }
    .vip-pass-detail .value { font-size: 1.1rem !important; font-weight: 700 !important; }
    
    .vip-pass-footer { margin-top: 3rem !important; border-top: 1px solid rgba(255,255,255,0.1) !important; padding-top: 2rem !important; display: flex !important; justify-content: space-between !important; align-items: flex-end !important; }
  </style>
  {% block stylesheets %}{% endblock %}
</head>
<body>

<nav id="navbar">
  <a href="{{ path('app_home') }}" class="nav-logo">Voyage<span>Elite</span></a>
  <ul class="nav-links">
    <li><a href="{{ path('app_home') }}">Accueil</a></li>
    <li><a href="{{ path('destination_index') }}">Destinations</a></li>
    <li><a href="{{ path('voyage_index') }}">Voyages</a></li>
    
    {% if app.user %}
      <li class="dropdown">
        <a href="#">Espace Client <i class="fas fa-chevron-down" style="font-size: 0.6rem; margin-left: 3px;"></i></a>
        <ul class="dropdown-content">
          <li><a href="{{ path('app_user_paiement_index') }}"><i class="fas fa-wallet"></i> Mes Paiements</a></li>
          <li><a href="{{ path('app_user_subscription_index') }}"><i class="fas fa-crown"></i> Mon Abonnement</a></li>
          <li><a href="{{ path('app_logout') }}"><i class="fas fa-sign-out-alt"></i> Déconnexion</a></li>
        </ul>
      </li>

      {% if is_granted('ROLE_ADMIN') %}
        <li class="dropdown">
          <a href="#" style="color: var(--gold-l);">Administration <i class="fas fa-chevron-down" style="font-size: 0.6rem; margin-left: 3px;"></i></a>
          <ul class="dropdown-content">
            <li><a href="{{ path('app_admin_paiement_index') }}"><i class="fas fa-chart-line"></i> Gestion Paiements</a></li>
            <li><a href="{{ path('app_admin_subscription_index') }}"><i class="fas fa-users-gear"></i> Gestion Abonnements</a></li>
          </ul>
        </li>
      {% endif %}
    {% else %}
      <li><a href="{{ path('app_login') }}"><i class="fas fa-user"></i> Connexion</a></li>
    {% endif %}

    <li><a href="{{ path('app_home') }}#about">À propos</a></li>
    <li><a href="{{ path('app_home') }}#contact" class="nav-cta">Réserver</a></li>

  </ul>
</nav>

{% for msg in app.flashes('success') %}
  <div class="flash flash-success">✅ {{ msg is iterable ? msg.message : msg }}</div>
{% endfor %}
{% for msg in app.flashes('error') %}
  <div class="flash flash-error">❌ {{ msg is iterable ? msg.message : msg }}</div>
{% endfor %}

{% block body %}{% endblock %}

<footer>
  <div class="footer-grid">
    <div class="footer-brand">
      <a href="{{ path('app_home') }}" class="nav-logo">Voyage<span>Elite</span></a>
      <p>Votre partenaire de confiance pour des voyages d'exception.</p>
    </div>
    <div class="footer-col">
      <p style="color:rgba(255,255,255,0.45); font-size:0.8rem">© 2025 SmartTrip. Tous droits réservés.</p>
    </div>
  </div>
</footer>

{% block javascripts %}
<script>
window.addEventListener('scroll', () => {
    const nav = document.getElementById('navbar');
    if (nav) nav.style.background = window.scrollY > 50 ? 'rgba(13,27,42,0.99)' : 'rgba(13,27,42,0.96)';
});

// Correction pour les menus "collants"
document.querySelectorAll('.dropdown-content a').forEach(link => {
    link.addEventListener('click', () => {
        const dropdown = link.closest('.dropdown-content');
        if (dropdown) {
            dropdown.style.display = 'none';
            setTimeout(() => { dropdown.style.display = ''; }, 100);
        }
    });
});
</script>
{% endblock %}
  <script>
    document.addEventListener('DOMContentLoaded', function() {
        const dropdowns = document.querySelectorAll('.dropdown');
        
        dropdowns.forEach(dropdown => {
            const link = dropdown.querySelector('a');
            link.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                
                // Close others
                dropdowns.forEach(d => {
                    if (d !== dropdown) d.classList.remove('active');
                });
                
                dropdown.classList.toggle('active');
            });
        });

        // Close when clicking outside
        document.addEventListener('click', function() {
            dropdowns.forEach(d => d.classList.remove('active'));
        });
    });
  </script>
</body>
</html>
