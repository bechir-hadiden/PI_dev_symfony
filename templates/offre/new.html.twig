{% extends 'base.html.twig' %}

{% block body %}
<div class="container-fluid py-5" style="background-color: #F4F7FB; min-height: 100vh;">
    <div class="text-center mb-5">
        <h1 class="label-title">Nouvelle Promotion</h1>
        <p class="text-muted">Créez une offre attractive pour vos voyageurs.</p>
    </div>

    {{ include('offre/_form.html.twig') }}
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    
    <!-- SCRIPT POUR LA LISTE DÉROULANTE DYNAMIQUE (Catégorie -> Éléments) -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Ces IDs dépendent de comment Symfony a généré ton OffreType. 
            // Par défaut, Symfony utilise l'id "nomdelentite_nomduchamp", par exemple "offre_category".
            const categorySelect = document.querySelector('#offre_category'); 
            const targetSelect = document.querySelector('#offre_id_target');

            if (categorySelect && targetSelect) {
                categorySelect.addEventListener('change', function() {
                    const category = this.value;
                    
                    // On vide la liste pendant le chargement
                    targetSelect.innerHTML = '<option value="">Chargement en cours...</option>';

                    if (!category) {
                        targetSelect.innerHTML = '<option value="">Sélectionnez d\'abord une catégorie</option>';
                        return;
                    }

                    // Appel vers l'API de ton OffreController
                    fetch(`/offre/api/items/${category}`)
                        .then(response => {
                            if (!response.ok) throw new Error('Erreur réseau');
                            return response.json();
                        })
                        .then(data => {
                            targetSelect.innerHTML = '<option value="">-- Choisissez un élément --</option>';
                            
                            // On remplit le select avec les données
                            data.forEach(item => {
                                const option = document.createElement('option');
                                option.value = item.id;
                                option.textContent = item.label; // Affichera le nom avec le prix !
                                targetSelect.appendChild(option);
                            });
                        })
                        .catch(error => {
                            console.error('Erreur API:', error);
                            targetSelect.innerHTML = '<option value="">Erreur lors du chargement des éléments</option>';
                        });
                });
            }
        });
    </script>
{% endblock %}