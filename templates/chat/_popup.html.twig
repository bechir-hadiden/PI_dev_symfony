{# templates/chat/_popup.html.twig #}

<div id="chat-widget" style="position:fixed;bottom:28px;right:28px;z-index:2000;font-family:'Plus Jakarta Sans',sans-serif">

  {# ══ POPUP WINDOW ══ #}
  <div id="chat-popup" style="
    display:none; flex-direction:column;
    width:360px; height:560px;
    background:#0d1b2a;
    border:1px solid rgba(201,168,76,0.25);
    border-radius:18px;
    box-shadow:0 20px 60px rgba(0,0,0,0.55);
    overflow:hidden; margin-bottom:14px;
  ">

    {# ── Header ── #}
    <div style="background:linear-gradient(135deg,#112236,#0d1b2a);padding:15px 18px;display:flex;align-items:center;gap:12px;justify-content:space-between;border-bottom:1px solid rgba(201,168,76,0.2);">
      <div style="display:flex;align-items:center;gap:12px">
        <div style="width:44px;height:44px;border-radius:50%;background:rgba(201,168,76,0.1);border:1px solid rgba(201,168,76,0.3);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;">✈️</div>
        <div>
          <p style="color:#ffffff;font-size:14px;font-weight:700;margin:0;font-family:'Playfair Display',serif;letter-spacing:.3px;">Sarah — Smart Trip</p>
          <span id="sarah-status-text" style="font-size:11px;display:flex;align-items:center;gap:5px;margin-top:3px;color:rgba(255,255,255,0.45);">
            <span style="width:7px;height:7px;border-radius:50%;background:#4ade80;display:inline-block;flex-shrink:0;"></span>
            Votre conseillère de voyage 🌍
          </span>
        </div>
      </div>
      <div style="display:flex;align-items:center;gap:8px;">
        {# Bouton son #}
        <button id="btn-sarah-sound" onclick="toggleSarahSound()" title="Activer/couper la voix"
          style="background:rgba(201,168,76,0.1);border:1px solid rgba(201,168,76,0.25);border-radius:50%;width:32px;height:32px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:14px;transition:all .2s;color:#c9a84c;">🔊</button>
        {# Bouton fermer #}
        <button onclick="toggleSarahChat()"
          style="background:none;border:none;cursor:pointer;color:rgba(255,255,255,0.3);padding:5px;line-height:0;"
          onmouseover="this.style.color='#c9a84c'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    </div>

    {# ── Messages ── #}
    <div id="sarah-messages" style="flex:1;overflow-y:auto;padding:16px 14px;display:flex;flex-direction:column;gap:10px;background:#0d1b2a;">
      <div style="display:flex;justify-content:flex-start;">
        <div style="background:#112236;border:1px solid rgba(201,168,76,0.15);border-radius:14px;border-bottom-left-radius:3px;padding:10px 14px;font-size:13px;color:rgba(255,255,255,0.82);line-height:1.65;max-width:88%;">
          Bonjour ! Je suis <strong style="color:#c9a84c;">Sarah</strong>, votre conseillère chez Smart Trip 🌍✈️<br><br>
          Dites-moi votre rêve de voyage, et je vous crée un séjour sur-mesure !
        </div>
      </div>
      <div id="sarah-typing" style="display:none;">
        <div style="background:#112236;border:1px solid rgba(201,168,76,0.15);border-radius:14px;border-bottom-left-radius:3px;padding:10px 14px;display:inline-flex;gap:5px;align-items:center;">
          <span style="width:7px;height:7px;border-radius:50%;background:#c9a84c;animation:sarahBlink 1.2s infinite;opacity:.35;"></span>
          <span style="width:7px;height:7px;border-radius:50%;background:#c9a84c;animation:sarahBlink 1.2s .2s infinite;opacity:.35;"></span>
          <span style="width:7px;height:7px;border-radius:50%;background:#c9a84c;animation:sarahBlink 1.2s .4s infinite;opacity:.35;"></span>
          <span style="font-size:11px;color:rgba(201,168,76,0.55);margin-left:5px;">Sarah rédige...</span>
        </div>
      </div>
    </div>

    {# ── Indicateur micro actif ── #}
    <div id="sarah-voice-bar" style="display:none;padding:6px 14px;background:rgba(239,68,68,0.08);border-top:1px solid rgba(239,68,68,0.15);align-items:center;gap:8px;font-size:11px;color:#fca5a5;">
      <span style="width:8px;height:8px;border-radius:50%;background:#ef4444;animation:sarahPulse .8s infinite alternate;flex-shrink:0;display:inline-block;"></span>
      Sarah vous écoute... parlez maintenant
    </div>

    {# ── Indicateur Sarah parle ── #}
    <div id="sarah-speaking-bar" style="display:none;padding:6px 14px;background:rgba(201,168,76,0.07);border-top:1px solid rgba(201,168,76,0.12);align-items:center;gap:8px;font-size:11px;color:#e8c97a;">
      <div style="display:flex;gap:2px;align-items:center;">
        <span style="width:3px;background:#c9a84c;border-radius:2px;animation:sarahWave 1s 0s infinite;"></span>
        <span style="width:3px;background:#c9a84c;border-radius:2px;animation:sarahWave 1s .1s infinite;"></span>
        <span style="width:3px;background:#c9a84c;border-radius:2px;animation:sarahWave 1s .2s infinite;"></span>
        <span style="width:3px;background:#c9a84c;border-radius:2px;animation:sarahWave 1s .15s infinite;"></span>
        <span style="width:3px;background:#c9a84c;border-radius:2px;animation:sarahWave 1s .05s infinite;"></span>
      </div>
      Sarah parle...
      <button onclick="stopSarahSpeech()" style="margin-left:auto;background:none;border:none;cursor:pointer;color:#c9a84c;font-size:11px;padding:0;font-family:'Plus Jakarta Sans',sans-serif;">⏹ Stop</button>
    </div>

    {# ── Input bar ── #}
    <div style="padding:11px 13px;border-top:1px solid rgba(201,168,76,0.15);background:#112236;display:flex;gap:9px;align-items:center;">
      <input id="sarah-input" type="text" placeholder="Tapez ou 🎤 parlez..."
        onkeydown="if(event.key==='Enter')sendSarahMessage()"
        onfocus="this.style.borderColor='rgba(201,168,76,0.55)'"
        onblur="this.style.borderColor='rgba(201,168,76,0.2)'"
        style="flex:1;background:rgba(255,255,255,0.05);border:1px solid rgba(201,168,76,0.2);border-radius:50px;padding:9px 16px;font-size:13px;outline:none;color:#ffffff;font-family:'Plus Jakarta Sans',sans-serif;transition:border-color .3s;"
      />
      {# Micro #}
      <button id="btn-sarah-mic" onclick="toggleSarahMic()" title="Parler à Sarah"
        style="width:38px;height:38px;border-radius:50%;border:1px solid rgba(201,168,76,0.3);background:rgba(201,168,76,0.08);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:16px;color:#c9a84c;transition:all .2s;flex-shrink:0;">🎤</button>
      {# Envoyer #}
      <button onclick="sendSarahMessage()"
        onmouseover="this.style.transform='scale(1.08)'" onmouseout="this.style.transform='scale(1)'"
        style="width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,#c9a84c,#e8c97a);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:transform .2s;">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#0d1b2a" stroke-width="2.8"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>
    </div>

    <div style="text-align:center;padding:6px;font-size:10px;color:rgba(255,255,255,0.22);background:#0d1b2a;letter-spacing:.3px;">
      Propulsé par <strong style="color:rgba(201,168,76,0.6);">Smart Trip AI</strong> × N8N × Mistral
    </div>
  </div>

  {# ══ FLOATING BUTTON ══ #}
  <div style="display:flex;justify-content:flex-end;">
    <button id="sarah-fab" onclick="toggleSarahChat()"
      onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'"
      style="width:58px;height:58px;border-radius:50%;background:linear-gradient(135deg,#c9a84c,#e8c97a);border:none;cursor:pointer;position:relative;box-shadow:0 6px 24px rgba(201,168,76,0.4);transition:transform .25s;display:flex;align-items:center;justify-content:center;">
      <span id="sarah-badge" style="position:absolute;top:-3px;right:-3px;width:19px;height:19px;background:#dc2626;border:2px solid #0d1b2a;border-radius:50%;font-size:10px;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;">1</span>
      <span id="sarah-icon-chat" style="font-size:22px;">✈️</span>
      <svg id="sarah-icon-x" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0d1b2a" stroke-width="2.8" style="display:none;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
</div>

{# ══ STYLES ══ #}
<style>
@keyframes sarahBlink { 0%,80%,100%{opacity:.15} 40%{opacity:1} }
@keyframes sarahPulse { from{opacity:1;transform:scale(1)} to{opacity:.4;transform:scale(.7)} }
@keyframes sarahWave  { 0%,100%{height:4px} 50%{height:13px} }
@keyframes micActive  { from{box-shadow:0 0 0 rgba(239,68,68,.4)} to{box-shadow:0 0 14px rgba(239,68,68,.7)} }
#sarah-messages::-webkit-scrollbar       { width:4px; }
#sarah-messages::-webkit-scrollbar-thumb { background:rgba(201,168,76,0.2);border-radius:4px; }
#sarah-input::placeholder                { color:rgba(255,255,255,0.22); }
#btn-sarah-mic.listening {
  background:rgba(239,68,68,0.2) !important;
  border-color:rgba(239,68,68,0.5) !important;
  color:#ef4444 !important;
  animation:micActive .8s infinite alternate;
}
</style>

{# ══ JAVASCRIPT ══ #}
<script>
(function () {
  const ENDPOINT  = '{{ path('chat_message') }}';
  let sarahIsOpen  = false;
  let sarahMuted   = false;
  let sarahListen  = false;
  let recognition  = null;
  const synth      = window.speechSynthesis;
  let voiceFR      = null;

  /* ── Voix française ── */
  function loadVoice() {
    const v = synth ? synth.getVoices() : [];
    voiceFR = v.find(x => x.lang==='fr-FR' && /female|marie|amelie|audrey|lea|google/i.test(x.name))
           || v.find(x => x.lang==='fr-FR')
           || v.find(x => x.lang.startsWith('fr'))
           || null;
  }
  loadVoice();
  if (synth) synth.onvoiceschanged = loadVoice;

  /* ── Toggle popup ── */
  window.toggleSarahChat = function () {
    sarahIsOpen = !sarahIsOpen;
    document.getElementById('chat-popup').style.display    = sarahIsOpen ? 'flex'  : 'none';
    document.getElementById('sarah-icon-chat').style.display = sarahIsOpen ? 'none'  : 'block';
    document.getElementById('sarah-icon-x').style.display    = sarahIsOpen ? 'block' : 'none';
    document.getElementById('sarah-badge').style.display     = 'none';
    if (sarahIsOpen) {
      if (!sessionStorage.getItem('sarah_welcomed')) {
        sessionStorage.setItem('sarah_welcomed', '1');
        setTimeout(() => speak("Bonjour ! Je suis Sarah, votre conseillère Smart Trip. Parlez-moi de votre rêve de voyage !"), 500);
      }
      setTimeout(() => document.getElementById('sarah-input').focus(), 80);
    } else {
      stopSarahSpeech();
      stopMic();
    }
  };

  /* ── Envoyer message ── */
  window.sendSarahMessage = function () {
    const input = document.getElementById('sarah-input');
    const text  = (input.value || '').trim();
    if (!text) return;
    appendMsg(text, 'user');
    input.value = '';
    showTyping(true);
    stopSarahSpeech();
    setStatus('Sarah réfléchit...');

    fetch(ENDPOINT, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ message: text, session_id: getSessionId() })
    })
    .then(r => { if (!r.ok) throw new Error('HTTP '+r.status); return r.json(); })
    .then(data => {
      showTyping(false);
      const reply = data.reply || 'Je traite votre demande…';
      appendMsg(reply, 'bot');
      speak(reply);
      if (data.voyage_cree) {
        setTimeout(() => { const x='🎉 Voyage créé ! E-mail de confirmation envoyé.'; appendMsg(x,'bot'); speak(x); }, 800);
      }
      setStatus('Votre conseillère de voyage 🌍');
    })
    .catch(err => {
      showTyping(false);
      setStatus('Votre conseillère de voyage 🌍');
      appendMsg('Sarah est momentanément indisponible. Veuillez réessayer.', 'bot');
      console.error('Sarah error:', err);
    });
  };

  /* ── Synthèse vocale ── */
  function speak(text) {
    if (sarahMuted || !synth) return;
    stopSarahSpeech();
    const clean = text.replace(/\[([^\]]+)\]\([^\)]+\)/g,'$1').replace(/<[^>]+>/g,'').replace(/[^\p{L}\p{N}\s.,!?;:\-'«»"]/gu,'').trim();
    if (!clean) return;
    const u = new SpeechSynthesisUtterance(clean);
    u.lang='fr-FR'; u.rate=1.0; u.pitch=1.1; u.volume=1.0;
    if (voiceFR) u.voice = voiceFR;
    u.onstart = () => { document.getElementById('sarah-speaking-bar').style.display='flex'; setStatus('Sarah parle...'); };
    u.onend = u.onerror = () => { document.getElementById('sarah-speaking-bar').style.display='none'; setStatus('Votre conseillère de voyage 🌍'); };
    synth.speak(u);
  }

  window.stopSarahSpeech = function () {
    if (synth) synth.cancel();
    document.getElementById('sarah-speaking-bar').style.display = 'none';
  };

  window.toggleSarahSound = function () {
    sarahMuted = !sarahMuted;
    const btn = document.getElementById('btn-sarah-sound');
    btn.textContent = sarahMuted ? '🔇' : '🔊';
    btn.style.color = sarahMuted ? 'rgba(255,255,255,0.3)' : '#c9a84c';
    if (sarahMuted) stopSarahSpeech();
  };

  /* ── Reconnaissance vocale ── */
  function initRec() {
    const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (!SR) {
      const b = document.getElementById('btn-sarah-mic');
      b.title='❌ Utilisez Chrome pour la reconnaissance vocale'; b.style.opacity='.35'; b.disabled=true;
      return null;
    }
    const rec = new SR();
    rec.lang='fr-FR'; rec.continuous=false; rec.interimResults=true;
    rec.onstart = () => {
      sarahListen=true;
      document.getElementById('btn-sarah-mic').classList.add('listening');
      document.getElementById('sarah-voice-bar').style.display='flex';
      setStatus('Sarah vous écoute...');
      stopSarahSpeech();
    };
    rec.onresult = e => {
      let f='',i='';
      for (let x=e.resultIndex;x<e.results.length;x++) e.results[x].isFinal ? f+=e.results[x][0].transcript : i+=e.results[x][0].transcript;
      document.getElementById('sarah-input').value = f||i;
    };
    rec.onend = () => {
      sarahListen=false;
      document.getElementById('btn-sarah-mic').classList.remove('listening');
      document.getElementById('sarah-voice-bar').style.display='none';
      setStatus('Votre conseillère de voyage 🌍');
      const t = document.getElementById('sarah-input').value.trim();
      if (t) setTimeout(()=>sendSarahMessage(), 300);
    };
    rec.onerror = e => {
      sarahListen=false;
      document.getElementById('btn-sarah-mic').classList.remove('listening');
      document.getElementById('sarah-voice-bar').style.display='none';
      if (e.error==='not-allowed') alert('❌ Autorisez le microphone dans votre navigateur.');
    };
    return rec;
  }

  window.toggleSarahMic = function () {
    if (sarahListen) { stopMic(); }
    else { if (!recognition) recognition=initRec(); if (recognition) try{recognition.start();}catch(e){} }
  };
  function stopMic() { if (recognition&&sarahListen) try{recognition.stop();}catch(e){} }

  /* ── Helpers ── */
  function appendMsg(text, who) {
    const msgs=document.getElementById('sarah-messages'), typing=document.getElementById('sarah-typing');
    const wrap=document.createElement('div');
    wrap.style.cssText='display:flex;justify-content:'+(who==='user'?'flex-end':'flex-start')+';';
    const bub=document.createElement('div');
    bub.style.cssText = who==='user'
      ? 'background:linear-gradient(135deg,#c9a84c,#e8c97a);color:#0d1b2a;font-weight:600;border-radius:14px;border-bottom-right-radius:3px;padding:10px 14px;font-size:13px;line-height:1.55;max-width:82%;'
      : 'background:#112236;border:1px solid rgba(201,168,76,0.15);border-radius:14px;border-bottom-left-radius:3px;padding:10px 14px;font-size:13px;color:rgba(255,255,255,0.82);line-height:1.65;max-width:88%;';
    bub.innerHTML = text
      .replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')
      .replace(/\[([^\]]+)\]\((https?:\/\/[^)]+)\)/g,'<a href="$2" target="_blank" style="color:#e8c97a;text-decoration:underline;font-weight:600;">$1</a>')
      .replace(/\n/g,'<br>');
    wrap.appendChild(bub);
    msgs.insertBefore(wrap, typing);
    msgs.scrollTop=msgs.scrollHeight;
  }

  function showTyping(show) {
    document.getElementById('sarah-typing').style.display=show?'block':'none';
    document.getElementById('sarah-messages').scrollTop=99999;
  }

  function setStatus(msg) {
    const el=document.getElementById('sarah-status-text');
    if (el) el.innerHTML='<span style="width:7px;height:7px;border-radius:50%;background:#4ade80;display:inline-block;flex-shrink:0;"></span> '+msg;
  }

  function getSessionId() {
    let s=sessionStorage.getItem('smarttrip_sid');
    if (!s) { s='st_'+Math.random().toString(36).slice(2)+Date.now(); sessionStorage.setItem('smarttrip_sid',s); }
    return s;
  }
})();
</script>
