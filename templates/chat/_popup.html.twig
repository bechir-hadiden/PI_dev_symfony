{# templates/chat/_popup.html.twig #}
{#
  INTÉGRATION dans base_dark.html.twig :
  Ajoutez la ligne suivante juste avant  {% block javascripts %}
  ──────────────────────────────────────
  {% include 'chat/_popup.html.twig' %}
  ──────────────────────────────────────
#}

<div id="chat-widget" style="position:fixed;bottom:28px;right:28px;z-index:2000;font-family:'Plus Jakarta Sans',sans-serif">

  {# ══ POPUP WINDOW ══ #}
  <div id="chat-popup" style="
    display:none; flex-direction:column;
    width:360px; height:520px;
    background:#0d1b2a;
    border:1px solid rgba(201,168,76,0.25);
    border-radius:18px;
    box-shadow:0 20px 60px rgba(0,0,0,0.55);
    overflow:hidden; margin-bottom:14px;
  ">

    {# ── Header ── #}
    <div style="
      background:linear-gradient(135deg,#112236,#0d1b2a);
      padding:15px 18px;
      display:flex;align-items:center;gap:12px;justify-content:space-between;
      border-bottom:1px solid rgba(201,168,76,0.2);
    ">
      <div style="display:flex;align-items:center;gap:12px">
        <div style="
          width:44px;height:44px;border-radius:50%;
          background:rgba(201,168,76,0.1);
          border:1px solid rgba(201,168,76,0.3);
          display:flex;align-items:center;justify-content:center;
          font-size:20px;flex-shrink:0;
        ">✈️</div>
        <div>
          <p style="
            color:#ffffff;font-size:14px;font-weight:700;margin:0;
            font-family:'Playfair Display',serif;letter-spacing:.3px;
          ">Sarah — Smart Trip</p>
          <span style="font-size:11px;display:flex;align-items:center;gap:5px;margin-top:3px;color:rgba(255,255,255,0.45);">
            <span style="width:7px;height:7px;border-radius:50%;background:#4ade80;display:inline-block;flex-shrink:0;"></span>
            Votre conseillère de voyage 🌍
          </span>
        </div>
      </div>
      <button onclick="toggleSarahChat()"
        style="background:none;border:none;cursor:pointer;color:rgba(255,255,255,0.3);padding:5px;line-height:0;transition:color .2s;"
        onmouseover="this.style.color='#c9a84c'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    {# ── Messages area ── #}
    <div id="sarah-messages" style="
      flex:1;overflow-y:auto;
      padding:16px 14px;
      display:flex;flex-direction:column;gap:10px;
      background:#0d1b2a;
    ">
      {# Message de bienvenue de Sarah #}
      <div style="display:flex;justify-content:flex-start;">
        <div style="
          background:#112236;
          border:1px solid rgba(201,168,76,0.15);
          border-radius:14px;border-bottom-left-radius:3px;
          padding:10px 14px;font-size:13px;
          color:rgba(255,255,255,0.82);line-height:1.65;max-width:88%;
        ">
          Bonjour ! Je suis <strong style="color:#c9a84c;">Sarah</strong>, votre conseillère chez Smart Trip 🌍✈️<br><br>
          Dites-moi votre rêve de voyage, et je vous crée un séjour sur-mesure !
        </div>
      </div>

      {# Typing indicator — toujours en bas #}
      <div id="sarah-typing" style="display:none;">
        <div style="
          background:#112236;
          border:1px solid rgba(201,168,76,0.15);
          border-radius:14px;border-bottom-left-radius:3px;
          padding:10px 14px;display:inline-flex;gap:5px;align-items:center;
        ">
          <span style="width:7px;height:7px;border-radius:50%;background:#c9a84c;animation:sarahBlink 1.2s infinite;opacity:.35;"></span>
          <span style="width:7px;height:7px;border-radius:50%;background:#c9a84c;animation:sarahBlink 1.2s .2s infinite;opacity:.35;"></span>
          <span style="width:7px;height:7px;border-radius:50%;background:#c9a84c;animation:sarahBlink 1.2s .4s infinite;opacity:.35;"></span>
          <span style="font-size:11px;color:rgba(201,168,76,0.55);margin-left:5px;">Sarah rédige...</span>
        </div>
      </div>
    </div>

    {# ── Input bar ── #}
    <div style="
      padding:11px 13px;
      border-top:1px solid rgba(201,168,76,0.15);
      background:#112236;
      display:flex;gap:9px;align-items:center;
    ">
      <input
        id="sarah-input"
        type="text"
        placeholder="Tapez votre message..."
        onkeydown="if(event.key==='Enter')sendSarahMessage()"
        onfocus="this.style.borderColor='rgba(201,168,76,0.55)'"
        onblur="this.style.borderColor='rgba(201,168,76,0.2)'"
        style="
          flex:1;
          background:rgba(255,255,255,0.05);
          border:1px solid rgba(201,168,76,0.2);
          border-radius:50px;
          padding:9px 16px;
          font-size:13px;outline:none;
          color:#ffffff;
          font-family:'Plus Jakarta Sans',sans-serif;
          transition:border-color .3s;
        "
      />
      <button
        onclick="sendSarahMessage()"
        onmouseover="this.style.transform='scale(1.08)';this.style.boxShadow='0 6px 20px rgba(201,168,76,0.45)'"
        onmouseout="this.style.transform='scale(1)';this.style.boxShadow='none'"
        style="
          width:38px;height:38px;border-radius:50%;
          background:linear-gradient(135deg,#c9a84c,#e8c97a);
          border:none;cursor:pointer;
          display:flex;align-items:center;justify-content:center;
          flex-shrink:0;transition:transform .2s,box-shadow .2s;
        "
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#0d1b2a" stroke-width="2.8">
          <line x1="22" y1="2" x2="11" y2="13"/>
          <polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </button>
    </div>

    {# ── Branding footer ── #}
    <div style="
      text-align:center;padding:6px;
      font-size:10px;color:rgba(255,255,255,0.22);
      background:#0d1b2a;letter-spacing:.3px;
    ">
      Propulsé par <strong style="color:rgba(201,168,76,0.6);">Smart Trip AI</strong> × N8N × Mistral
    </div>
  </div>

  {# ══ FLOATING BUTTON ══ #}
  <div style="display:flex;justify-content:flex-end;">
    <button
      id="sarah-fab"
      onclick="toggleSarahChat()"
      onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 12px 35px rgba(201,168,76,0.55)'"
      onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 6px 24px rgba(201,168,76,0.4)'"
      style="
        width:58px;height:58px;border-radius:50%;
        background:linear-gradient(135deg,#c9a84c,#e8c97a);
        border:none;cursor:pointer;position:relative;
        box-shadow:0 6px 24px rgba(201,168,76,0.4);
        transition:transform .25s,box-shadow .25s;
        display:flex;align-items:center;justify-content:center;
      "
    >
      {# Badge rouge #}
      <span id="sarah-badge" style="
        position:absolute;top:-3px;right:-3px;
        width:19px;height:19px;
        background:#dc2626;border:2px solid #0d1b2a;
        border-radius:50%;font-size:10px;color:#fff;
        display:flex;align-items:center;justify-content:center;
        font-weight:700;
      ">1</span>

      <span id="sarah-icon-chat" style="font-size:22px;">✈️</span>
      <svg id="sarah-icon-x" width="20" height="20" viewBox="0 0 24 24" fill="none"
           stroke="#0d1b2a" stroke-width="2.8" style="display:none;">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>
</div>

{# ══ STYLES ══ #}
<style>
@keyframes sarahBlink { 0%,80%,100%{opacity:.15} 40%{opacity:1} }
#sarah-messages::-webkit-scrollbar { width:4px; }
#sarah-messages::-webkit-scrollbar-thumb { background:rgba(201,168,76,0.2); border-radius:4px; }
#sarah-input::placeholder { color:rgba(255,255,255,0.22); }
</style>

{# ══ JAVASCRIPT ══ #}
<script>
(function () {
  const ENDPOINT = '{{ path('chat_message') }}';
  let isOpen = false;

  /* ── Toggle popup ── */
  window.toggleSarahChat = function () {
    isOpen = !isOpen;
    const popup  = document.getElementById('chat-popup');
    const iconCh = document.getElementById('sarah-icon-chat');
    const iconX  = document.getElementById('sarah-icon-x');
    const badge  = document.getElementById('sarah-badge');

    popup.style.display  = isOpen ? 'flex' : 'none';
    iconCh.style.display = isOpen ? 'none'  : 'block';
    iconX.style.display  = isOpen ? 'block' : 'none';
    badge.style.display  = 'none';

    if (isOpen) setTimeout(() => document.getElementById('sarah-input').focus(), 80);
  };

  /* ── Envoyer un message ── */
  window.sendSarahMessage = function () {
    const input = document.getElementById('sarah-input');
    const text  = (input.value || '').trim();
    if (!text) return;

    appendMsg(text, 'user');
    input.value = '';
    showTyping(true);

    fetch(ENDPOINT, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({
        message:    text,
        session_id: getSessionId()
      })
    })
    .then(r => r.json())
    .then(data => {
      showTyping(false);
      appendMsg(data.reply || 'Je traite votre demande…', 'bot');

      /* Si N8N a terminé la collecte et créé le voyage */
      if (data.voyage_cree) {
        setTimeout(() => appendMsg(
          '🎉 Votre voyage a été créé ! Un e-mail de confirmation vous a été envoyé.', 'bot'
        ), 700);
      }
    })
    .catch(() => {
      showTyping(false);
      appendMsg('Sarah est momentanément indisponible. Veuillez réessayer.', 'bot');
    });
  };

  /* ── Ajouter un message dans la fenêtre ── */
  function appendMsg(text, who) {
    const msgs   = document.getElementById('sarah-messages');
    const typing = document.getElementById('sarah-typing');

    const wrap = document.createElement('div');
    wrap.style.cssText = `display:flex;justify-content:${who === 'user' ? 'flex-end' : 'flex-start'};`;

    const bub = document.createElement('div');
    if (who === 'user') {
      bub.style.cssText = `
        background:linear-gradient(135deg,#c9a84c,#e8c97a);
        color:#0d1b2a;font-weight:600;
        border-radius:14px;border-bottom-right-radius:3px;
        padding:10px 14px;font-size:13px;line-height:1.55;max-width:82%;
      `;
    } else {
      bub.style.cssText = `
        background:#112236;
        border:1px solid rgba(201,168,76,0.15);
        border-radius:14px;border-bottom-left-radius:3px;
        padding:10px 14px;font-size:13px;
        color:rgba(255,255,255,0.82);line-height:1.65;max-width:88%;
      `;
    }
    bub.innerHTML = text.replace(/\n/g, '<br>');
    wrap.appendChild(bub);
    msgs.insertBefore(wrap, typing);
    msgs.scrollTop = msgs.scrollHeight;
  }

  /* ── Afficher/masquer l'indicateur de saisie ── */
  function showTyping(show) {
    const t = document.getElementById('sarah-typing');
    t.style.display = show ? 'block' : 'none';
    document.getElementById('sarah-messages').scrollTop = 99999;
  }

  /* ── Session ID persistant ── */
  function getSessionId() {
    let sid = sessionStorage.getItem('smarttrip_sid');
    if (!sid) {
      sid = 'st_' + Math.random().toString(36).slice(2) + Date.now();
      sessionStorage.setItem('smarttrip_sid', sid);
    }
    return sid;
  }
})();
</script>
