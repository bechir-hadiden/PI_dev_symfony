<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Boarding Pass - {{ reservation.nomClient }}</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Arial', sans-serif;
            background: #f0f2f5;
            padding: 40px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }
        
        .boarding-pass {
            max-width: 800px;
            width: 100%;
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            overflow: hidden;
        }
        
        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px 30px;
            text-align: center;
        }
        
        .header h1 {
            font-size: 24px;
            margin-bottom: 5px;
        }
        
        .header p {
            opacity: 0.9;
            font-size: 14px;
        }
        
        .qr-section {
            text-align: center;
            padding: 20px;
            background: white;
            border-bottom: 1px solid #e0e0e0;
        }
        
        .qr-code {
            display: inline-block;
            padding: 10px;
            background: white;
            border-radius: 10px;
        }
        
        .qr-code img {
            width: 150px;
            height: 150px;
        }
        
        .info-section {
            padding: 25px 30px;
            background: white;
        }
        
        .flight-info {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 25px;
            text-align: center;
        }
        
        .flight-info .item {
            padding: 10px;
        }
        
        .flight-info .label {
            font-size: 11px;
            text-transform: uppercase;
            color: #999;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }
        
        .flight-info .value {
            font-size: 22px;
            font-weight: bold;
            color: #333;
        }
        
        .flight-info .sub {
            font-size: 12px;
            color: #666;
            margin-top: 5px;
        }
        
        .passenger-details {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 12px;
            margin-bottom: 20px;
        }
        
        .passenger-details h3 {
            font-size: 16px;
            color: #667eea;
            margin-bottom: 15px;
        }
        
        .details-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
        }
        
        .details-grid .detail {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid #e0e0e0;
        }
        
        .details-grid .detail .detail-label {
            font-size: 12px;
            color: #999;
        }
        
        .details-grid .detail .detail-value {
            font-size: 14px;
            font-weight: 600;
            color: #333;
        }
        
        .footer {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 15px 30px;
            text-align: center;
            font-size: 12px;
        }
        
        .footer p {
            margin: 5px 0;
        }
        
        .status {
            text-align: center;
            margin-top: 15px;
        }
        
        .status .confirmed {
            background: #4caf50;
            color: white;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 12px;
            display: inline-block;
        }
        
        @media print {
            body {
                background: white;
                padding: 0;
            }
            .boarding-pass {
                box-shadow: none;
                max-width: 100%;
            }
            .no-print {
                display: none;
            }
        }
        
        .no-print {
            text-align: center;
            margin-top: 20px;
        }
        
        .no-print button {
            background: #667eea;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 14px;
            margin: 0 5px;
        }
        
        .no-print button:hover {
            background: #5a67d8;
        }
    </style>
</head>
<body>
    <div class="boarding-pass">
        <div class="header">
            <h1>✈️ BOARDING PASS</h1>
            <p>Carte d'embarquement électronique</p>
        </div>
        
        <div class="qr-section">
            <div class="qr-code">
                {% if qrCodeUrl %}
                    <img src="{{ qrCodeUrl }}" alt="QR Code">
                {% else %}
                    <div style="width: 150px; height: 150px; background: #f0f0f0; display: flex; align-items: center; justify-content: center;">
                        QR Code
                    </div>
                {% endif %}
            </div>
            <div class="status">
                <span class="confirmed">✓ {{ reservation.statusLabel }}</span>
            </div>
        </div>
        
        <div class="info-section">
            <div class="flight-info">
                <div class="item">
                    <div class="label">VOL</div>
                    <div class="value">{{ reservation.flightNumber }}</div>
                    <div class="sub">{{ reservation.airline }}</div>
                </div>
                <div class="item">
                    <div class="label">RÉSERVATION</div>
                    <div class="value">#{{ reservation.id }}</div>
                    <div class="sub">{{ reservation.reservationNumber ?? 'N/A' }}</div>
                </div>
                <div class="item">
                    <div class="label">DATE</div>
                    <div class="value">{{ reservation.departureTime ? reservation.departureTime|date('d/m/Y') : 'N/A' }}</div>
                    <div class="sub">{{ reservation.departureTime ? reservation.departureTime|date('H:i') : 'N/A' }}</div>
                </div>
            </div>
            
            <div class="flight-info">
                <div class="item">
                    <div class="label">DÉPART</div>
                    <div class="value">{{ reservation.departureAirport }}</div>
                    <div class="sub">{{ reservation.departureCity ?? 'N/A' }}</div>
                </div>
                <div class="item">
                    <div class="label">ARRIVÉE</div>
                    <div class="value">{{ reservation.arrivalAirport }}</div>
                    <div class="sub">{{ reservation.destination }}</div>
                </div>
                <div class="item">
                    <div class="label">PORTE</div>
                    <div class="value">À confirmer</div>
                    <div class="sub">40 min avant</div>
                </div>
            </div>
        </div>
        
        <div class="passenger-details">
            <h3>👤 INFORMATIONS PASSAGER</h3>
            <div class="details-grid">
                <div class="detail">
                    <span class="detail-label">Nom complet</span>
                    <span class="detail-value">{{ reservation.nomClient }}</span>
                </div>
                <div class="detail">
                    <span class="detail-label">Email</span>
                    <span class="detail-value">{{ reservation.email }}</span>
                </div>
                <div class="detail">
                    <span class="detail-label">Téléphone</span>
                    <span class="detail-value">{{ reservation.telephone ?? 'Non renseigné' }}</span>
                </div>
                <div class="detail">
                    <span class="detail-label">Date réservation</span>
                    <span class="detail-value">{{ reservation.reservationDate ? reservation.reservationDate|date('d/m/Y') : 'N/A' }}</span>
                </div>
            </div>
        </div>
        
        <div class="passenger-details">
            <h3>💰 INFORMATIONS PAIEMENT</h3>
            <div class="details-grid">
                <div class="detail">
                    <span class="detail-label">Prix total</span>
                    <span class="detail-value">{{ reservation.totalPrice }} €</span>
                </div>
                <div class="detail">
                    <span class="detail-label">Statut</span>
                    <span class="detail-value">{{ reservation.statusLabel }}</span>
                </div>
            </div>
        </div>
        
        <div class="footer">
            <p>Merci de choisir notre compagnie !</p>
            <p>Présentez-vous à l'embarquement 40 minutes avant le départ</p>
            <p>Ce document fait office de carte d'embarquement</p>
        </div>
    </div>
    
    <div class="no-print">
        <button onclick="window.print()">🖨️ Imprimer</button>
        <button onclick="window.close()">✖️ Fermer</button>
    </div>
    
    <script>
        window.onload = function() {
            setTimeout(function() {
                window.print();
            }, 500);
        };
    </script>
</body>
</html>