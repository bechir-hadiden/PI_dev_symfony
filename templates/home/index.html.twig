{% extends 'base_dark.html.twig' %}
{% block title %}Smart Trip – Agence de Voyage Premium{% endblock %}

{% block body %}
{# ── TEST MODE BAR ── #}
<div class="test-mode-bar" style="position:fixed; top:0; left:0; right:0; z-index:9999; background:rgba(15,23,42,0.95); backdrop-filter:blur(10px); border-bottom:1px solid rgba(201,168,76,0.3); padding:10px 20px; display:flex; justify-content:center; gap:15px; flex-wrap:wrap;">
    <span style="color:var(--gold-l); font-weight:bold; align-self:center; margin-right:auto;"><i class="fas fa-dollar-sign"></i> MODULE PAIEMENT ISOLÉ</span>
    <a href="{{ path('app_home') }}" class="btn-outline-light" style="padding:5px 15px; font-size:0.85rem; text-decoration:none; border:1px solid rgba(255,255,255,0.3);">
        <i class="fas fa-home"></i> Accueil
    </a>
    <a href="{{ path('app_admin_dashboard') }}" class="btn-gold" style="padding:5px 15px; font-size:0.85rem; text-decoration:none;">
        <i class="fas fa-user-shield"></i> PAIEMENT (ADMIN)
    </a>
    <a href="{{ path('app_client_dashboard') }}" class="btn-outline-light" style="padding:5px 15px; font-size:0.85rem; text-decoration:none; border:1px solid var(--gold-l); color:var(--gold-l);">
        <i class="fas fa-wallet"></i> PAIEMENT (CLIENT)
    </a>
</div>

{# Adjust hero top padding to account for the bar #}
<style> .hero { padding-top: 60px !important; } </style>

{# ── HERO ── #}
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content fade-in">
    <div class="hero-badge"><i class="fas fa-star"></i> Agence Premium depuis 2026</div>
    <h1>Explorez le Monde<br>avec <em>Élégance</em></h1>
    <p>Des voyages sur mesure, des expériences inoubliables. Laissez-nous vous emmener vers des destinations exceptionnelles soigneusement sélectionnées.</p>
    <div class="hero-btns">
      <a href="{{ path('client_voyage_index') }}" class="btn-primary delay-1"><i class="fas fa-compass"></i> Voir nos voyages</a>
      <a href="#contact" class="btn-outline-light delay-2"><i class="fas fa-phone"></i> Nous contacter</a>
    </div>
  </div>

  <div class="hero-search">
    <form class="search-box" action="{{ path('client_destination_index') }}" method="GET">
      <div class="search-field">
        <label><i class="fas fa-map-marker-alt"></i> Destination</label>
        <select name="q">
          <option value="">Toutes les destinations</option>
          {% for dest in destinations %}
            <option value="{{ dest.nom }}">{{ dest.nom }}, {{ dest.pays }}</option>
          {% endfor %}
        </select>
      </div>
      <div class="search-divider"></div>
      <div class="search-field">
        <label><i class="fas fa-globe"></i> Pays</label>
        <select name="pays">
          <option value="">Tous les pays</option>
          {% for dest in destinations %}
            <option value="{{ dest.pays }}">{{ dest.pays }}</option>
          {% endfor %}
        </select>
      </div>
      <button class="search-btn" type="submit">
        <i class="fas fa-search"></i> Rechercher
      </button>
    </form>
  </div>
</section>

{# ── DESTINATIONS ── #}
<section id="destinations">
  <div class="section-header">
    <div>
      <span class="section-label">Explorer</span>
      <h2 class="section-title">Destinations Populaires</h2>
      <p class="section-sub">Des endroits magiques sélectionnés par nos experts pour des voyages mémorables.</p>
    </div>
    <a href="{{ path('client_destination_index') }}" class="btn-navy">Voir tout <i class="fas fa-arrow-right"></i></a>
  </div>
  <div class="dest-grid">
    {% for dest in destinations %}
      <div class="dest-card {% if loop.first %}dest-card-featured{% endif %}">
        {% set img = dest.firstImage %}
        <img src="{{ img ?? 'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=600&q=80' }}"
             alt="{{ dest.nom }}" loading="lazy">
        <div class="dest-overlay">
          {% if loop.first %}
            <div class="dest-badge">⭐ Coup de cœur</div>
          {% elseif dest.codeIata %}
            <div class="dest-badge">{{ dest.codeIata }}</div>
          {% endif %}
          <div class="dest-name">{{ dest.nom }}, {{ dest.pays }}</div>
          <div class="dest-info">
            <span style="color:rgba(255,255,255,0.65);font-size:.82rem;"><i class="fas fa-map-marker-alt"></i> {{ dest.pays }}</span>
            <span class="dest-price">
              {% if dest.voyages|length > 0 %}À partir de {{ dest.voyages|first.prix|number_format(0,',',' ') }} TND
              {% else %}Sur devis{% endif %}
            </span>
            <a href="{{ path('client_destination_show', {id: dest.id}) }}" class="dest-action"><i class="fas fa-arrow-right"></i></a>
          </div>
        </div>
      </div>
    {% else %}
      <div style="grid-column:1/-1;text-align:center;padding:3rem;color:var(--muted);">
        <p>Aucune destination disponible.</p>
        <a href="{{ path('admin_destination_new') }}" class="btn-gold" style="margin-top:1rem;">+ Ajouter une destination</a>
      </div>
    {% endfor %}
  </div>
</section>

{# ── VOYAGES ── #}
<section id="packages">
  <div class="section-header">
    <div>
      <span class="section-label" style="color:var(--gold-l)">Nos Formules</span>
      <h2 class="section-title light">Voyages & Packages</h2>
      <p class="section-sub" style="color:rgba(255,255,255,0.55)">Tout inclus pour voyager l'esprit serein, du budget au luxe absolu.</p>
    </div>
    <a href="{{ path('client_voyage_index') }}" class="btn-gold">Tous les voyages <i class="fas fa-arrow-right"></i></a>
  </div>
  <div class="packages-grid">
    {% for voyage in voyages %}
      {% if voyage.imagePath %}
        {% set pkgImg = voyage.imagePath %}
      {% elseif voyage.destinationRel and voyage.destinationRel.firstImage %}
        {% set pkgImg = voyage.destinationRel.firstImage %}
      {% else %}
        {% set pkgImg = 'https://images.unsplash.com/photo-1501179691627-eeaa65ea017c?w=600&q=80' %}
      {% endif %}

      <div class="pkg-card {% if loop.first %}featured{% endif %}">
        {% if loop.first %}<div class="pkg-ribbon">⭐ Populaire</div>{% endif %}
        <div class="pkg-img">
          <img src="{{ pkgImg }}" alt="{{ voyage.destination }}" loading="lazy">
        </div>
        <div class="pkg-body">
          <div class="pkg-meta">
            <span><i class="fas fa-map-marker-alt"></i> {{ voyage.destination }}</span>
            <span><i class="fas fa-clock"></i> {{ voyage.dureeJours }} jours</span>
            {% if voyage.paysDepart %}
              <span><i class="fas fa-plane-departure"></i> {{ voyage.paysDepart }}</span>
            {% endif %}
          </div>
          <div class="pkg-name">{{ voyage.destination }}</div>
          {% if voyage.description %}
            <div class="pkg-desc">{{ voyage.description|slice(0,100) }}{% if voyage.description|length > 100 %}...{% endif %}</div>
          {% endif %}
          <ul class="pkg-features">
            <li><i class="fas fa-check-circle"></i> Du {{ voyage.dateDebut|date('d/m/Y') }} au {{ voyage.dateFin|date('d/m/Y') }}</li>
            <li><i class="fas fa-check-circle"></i> {{ voyage.dureeJours }} jours / {{ voyage.dureeJours - 1 }} nuits</li>
            {% if voyage.paysDepart %}
              <li><i class="fas fa-check-circle"></i> Départ depuis {{ voyage.paysDepart }}</li>
            {% endif %}
          </ul>
          <div class="pkg-footer">
            <div>
              <div class="pkg-price-label">À partir de</div>
              <div class="pkg-price">{{ voyage.prix|number_format(0,',',' ') }} <small>TND / pers.</small></div>
            </div>
            <a href="{{ path('client_voyage_show', {id: voyage.id}) }}" class="btn-gold">Voir le voyage</a>
          </div>
        </div>
      </div>
    {% else %}
      <div style="grid-column:1/-1;text-align:center;padding:3rem;color:rgba(255,255,255,0.4);">
        <p>Aucun voyage disponible.</p>
        <a href="{{ path('admin_voyage_new') }}" class="btn-gold" style="margin-top:1rem;">+ Ajouter un voyage</a>
      </div>
    {% endfor %}
  </div>
</section>

{# ══ CONVERTISSEUR DE DEVISES ════════════════════════════════════ #}
<section id="currency" style="background:var(--cream);padding:5rem 5%;">
  <div style="text-align:center;margin-bottom:3rem;">
    <span class="section-label">💱 Outil voyage</span>
    <h2 class="section-title">Convertisseur de devises</h2>
    <p class="section-sub" style="margin:0 auto;text-align:center;">
      Préparez votre budget voyage en temps réel grâce aux taux officiels de la BCE.
    </p>
  </div>

  <div style="max-width:700px;margin:0 auto;background:var(--navy);border:1px solid rgba(201,168,76,0.2);border-radius:20px;padding:2.5rem;box-shadow:var(--shadow);">

    {# ── Ligne montant + devises ── #}
    <div style="display:grid;grid-template-columns:1fr auto 1fr;gap:1rem;align-items:flex-end;margin-bottom:1.5rem;">

      {# Colonne gauche : montant + devise source #}
      <div>
        <label style="display:block;font-size:.7rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,0.45);margin-bottom:.45rem;">
          Montant
        </label>
        <input id="cv-amount" type="number" value="100" min="0" step="any"
          style="width:100%;padding:.85rem 1rem;background:rgba(255,255,255,0.06);border:1px solid rgba(201,168,76,0.2);border-radius:10px;color:#fff;font-size:1.1rem;font-family:'Plus Jakarta Sans',sans-serif;outline:none;transition:border-color .3s;"
          onfocus="this.style.borderColor='var(--gold)'"
          onblur="this.style.borderColor='rgba(201,168,76,0.2)'">
    <select id="cv-from"
      style="width:100%;margin-top:.5rem;padding:.7rem 1rem;
         background:#1a2f47;
         border:1px solid rgba(201,168,76,0.2);
         border-radius:10px;color:#fff;
         font-family:'Plus Jakarta Sans',sans-serif;
         font-size:.875rem;outline:none;cursor:pointer;
         -webkit-appearance:none;appearance:none;">
      </select>
      </div>

      {# Bouton swap #}
      <div style="text-align:center;padding-bottom:.4rem;">
        <button id="cv-swap" title="Inverser les devises"
          style="width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,var(--gold),var(--gold-l));border:none;cursor:pointer;font-size:1.1rem;color:var(--navy);transition:transform .4s;display:flex;align-items:center;justify-content:center;margin:0 auto;">
          ⇄
        </button>
      </div>

      {# Colonne droite : résultat + devise cible #}
      <div>
        <label style="display:block;font-size:.7rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,0.45);margin-bottom:.45rem;">
          Résultat
        </label>
        <div id="cv-result-amount"
          style="width:100%;padding:.85rem 1rem;background:rgba(201,168,76,0.07);border:1px solid rgba(201,168,76,0.25);border-radius:10px;color:var(--gold);font-size:1.1rem;font-weight:700;font-family:'Plus Jakarta Sans',sans-serif;min-height:50px;line-height:1.3;">
          —
        </div>
        <select id="cv-to"
          style="width:100%;margin-top:.5rem;padding:.7rem 1rem;background:rgba(255,255,255,0.06);border:1px solid rgba(201,168,76,0.2);border-radius:10px;color:#fff;font-family:'Plus Jakarta Sans',sans-serif;font-size:.875rem;outline:none;cursor:pointer;">
          <option>Chargement...</option>
        </select>
      </div>
    </div>

    {# ── Taux + date ── #}
    <div id="cv-rate-box"
      style="display:none;background:rgba(201,168,76,0.07);border:1px solid rgba(201,168,76,0.15);border-radius:10px;padding:.9rem 1.2rem;margin-bottom:1.4rem;flex-wrap:wrap;gap:.5rem;justify-content:space-between;align-items:center;">
      <span id="cv-rate-label" style="font-size:.82rem;color:rgba(255,255,255,0.55);"></span>
      <span id="cv-date-label" style="font-size:.72rem;color:rgba(255,255,255,0.3);"></span>
    </div>

    {# ── Bouton convertir ── #}
    <button id="cv-btn"
      style="width:100%;padding:.95rem;background:linear-gradient(135deg,var(--gold),var(--gold-l));color:var(--navy);border:none;border-radius:10px;font-family:'Plus Jakarta Sans',sans-serif;font-size:.95rem;font-weight:700;cursor:pointer;transition:transform .3s,box-shadow .3s;display:flex;align-items:center;justify-content:center;gap:.5rem;">
      💱 Convertir
    </button>

    {# ── Raccourcis devises populaires ── #}
    <div style="margin-top:1.5rem;padding-top:1.3rem;border-top:1px solid rgba(201,168,76,0.1);">
      <p style="font-size:.7rem;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,0.3);margin-bottom:.75rem;font-weight:700;">
        Devises populaires
      </p>
      <div id="cv-shortcuts" style="display:flex;flex-wrap:wrap;gap:.5rem;"></div>
    </div>

    {# ── Erreur ── #}
    <p id="cv-error" style="display:none;margin-top:1rem;color:#f87171;font-size:.82rem;text-align:center;"></p>
  </div>
</section>

{# ── À PROPOS ── #}
<section id="about">
  <div class="about-img-wrap">
    <img class="about-img-main" src="https://images.unsplash.com/photo-1578894381163-e72c17f2d45f?w=700&q=80" alt="Notre équipe">
    <div class="about-img-badge"><strong>16</strong><span>ans d'expertise</span></div>
  </div>
  <div class="about-content">
    <span class="section-label">Notre histoire</span>
    <h2 class="section-title">Votre confiance,<br>notre passion</h2>
    <p class="section-sub" style="max-width:100%;margin-bottom:1.5rem;">
      Depuis 2008, notre agence accompagne des milliers de voyageurs dans la réalisation de leurs rêves.
    </p>
    <div class="about-features">
      <div class="about-feat">
        <div class="about-feat-icon"><i class="fas fa-shield-alt"></i></div>
        <div><h4>Voyages sécurisés</h4><p>Suivi en temps réel et assistance 24h/24 durant votre séjour.</p></div>
      </div>
      <div class="about-feat">
        <div class="about-feat-icon"><i class="fas fa-user-tie"></i></div>
        <div><h4>Conseillers experts</h4><p>Une équipe dédiée avec une connaissance terrain approfondie.</p></div>
      </div>
      <div class="about-feat">
        <div class="about-feat-icon"><i class="fas fa-tag"></i></div>
        <div><h4>Meilleur prix garanti</h4><p>Nous alignons tout concurrent sur le même séjour.</p></div>
      </div>
      <div class="about-feat">
        <div class="about-feat-icon"><i class="fas fa-sliders-h"></i></div>
        <div><h4>100% sur mesure</h4><p>Chaque voyage est conçu selon vos envies et votre budget.</p></div>
      </div>
    </div>
    <a href="#contact" class="btn-primary">Parler à un conseiller <i class="fas fa-arrow-right"></i></a>
  </div>
</section>

{# ── CONTACT ── #}
{# ── CONTACT ── #}
<section id="contact">
  <div class="contact-info">
    <span class="section-label" style="color:var(--gold-l)">Contactez-nous</span>
    <h2 class="section-title light">Planifions votre<br>voyage ensemble</h2>
    <p class="section-sub" style="color:rgba(255,255,255,0.55);margin-bottom:0;">
      Un conseiller dédié vous répond sous 24h pour construire votre voyage idéal.
    </p>
    <div class="contact-items">
      <div class="contact-item">
        <div class="contact-icon"><i class="fas fa-phone"></i></div>
        <div><h4>Téléphone</h4><p>+216 71 234 567</p></div>
      </div>
      <div class="contact-item">
        <div class="contact-icon"><i class="fas fa-envelope"></i></div>
        <div><h4>Email</h4><p>contact@SmartTrip.tn</p></div>
      </div>
      <div class="contact-item">
        <div class="contact-icon"><i class="fas fa-map-marker-alt"></i></div>
        <div><h4>Adresse</h4><p>Avenue Habib Bourguiba, Tunis</p></div>
      </div>
      <div class="contact-item">
        <div class="contact-icon"><i class="fas fa-clock"></i></div>
        <div><h4>Horaires</h4><p>Lun–Sam : 8h00 – 18h00</p></div>
      </div>
    </div>
  </div>

  <div class="contact-form">
    <h3>Demande de devis gratuit</h3>

    {# Message succès / erreur #}
    <div id="form-success" style="display:none;background:rgba(74,222,128,0.15);
         border:1px solid rgba(74,222,128,0.4);border-radius:10px;
         padding:.9rem 1.2rem;margin-bottom:1.2rem;align-items:center;gap:.6rem;">
      <span style="font-size:1.1rem;">✅</span>
      <p style="color:#d1fae5;font-size:.875rem;margin:0;font-weight:500;">
        Votre demande a été envoyée ! Un conseiller vous contactera sous 24h.
      </p>
    </div>
    <div id="form-error" style="display:none;background:rgba(239,68,68,0.15);
         border:1px solid rgba(239,68,68,0.35);border-radius:10px;
         padding:.9rem 1.2rem;margin-bottom:1.2rem;align-items:center;gap:.6rem;">
      <span style="font-size:1.1rem;">❌</span>
      <p style="color:#fecaca;font-size:.875rem;margin:0;font-weight:500;">
        Erreur lors de l'envoi. Veuillez réessayer.
      </p>
    </div>

    {# Formulaire HTML pur — plus de form Symfony #}
    <form id="contactForm">
      <div class="form-row">
        <div class="form-group">
          <label>Prénom *</label>
          <input type="text" id="prenom" name="prenom" placeholder="Votre prénom" required>
        </div>
        <div class="form-group">
          <label>Nom *</label>
          <input type="text" id="nom" name="nom" placeholder="Votre nom" required>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Email *</label>
          <input type="email" id="email" name="email" placeholder="votre@email.com" required>
        </div>
        <div class="form-group">
          <label>Téléphone</label>
          <input type="text" id="telephone" name="telephone" placeholder="+216 XX XXX XXX">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Destination souhaitée</label>
          <input type="text" id="destination" name="destination" placeholder="Ex: Paris, Bali...">
        </div>
        <div class="form-group">
          <label>Budget estimé</label>
          <input type="text" id="budget" name="budget" placeholder="Ex: 2 000 TND">
        </div>
      </div>
      <div class="form-group">
        <label>Votre message *</label>
        <textarea id="message" name="message" rows="4"
                  placeholder="Décrivez votre projet de voyage..." required></textarea>
      </div>
      <button type="submit" class="btn-submit" id="submitBtn">
        <i class="fas fa-paper-plane"></i> Envoyer ma demande
      </button>
    </form>
  </div>
</section>

{# ── EMAILJS ── #}
{# ── EMAILJS ── #}
<script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
<script>
  emailjs.init('4BlvonMs6VdYcIqZH');

  document.getElementById('contactForm').addEventListener('submit', function(e) {
    e.preventDefault();

    const btn = document.getElementById('submitBtn');
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Envoi en cours...';
    btn.disabled = true;

    const templateParams = {
      prenom:      document.getElementById('prenom').value,
      nom:         document.getElementById('nom').value,
      email:       document.getElementById('email').value,
      telephone:   document.getElementById('telephone').value || 'Non renseigné',
      destination: document.getElementById('destination').value || 'Non précisée',
      budget:      document.getElementById('budget').value || 'Non précisé',
      message:     document.getElementById('message').value,
    };

    // ── DEBUG : voir exactement ce qui est envoyé
    console.log('Service ID  :', 'service_4eqhlsp');
    console.log('Template ID :', 'template_nk82mdw');
    console.log('Params      :', templateParams);

    emailjs.send('service_4eqhlsp', 'template_nk82mdw', templateParams)
      .then(function(response) {
        console.log('✅ Succès :', response.status, response.text);
        document.getElementById('form-success').style.display = 'flex';
        document.getElementById('form-error').style.display   = 'none';
        document.getElementById('contactForm').reset();
        btn.innerHTML = '<i class="fas fa-paper-plane"></i> Envoyer ma demande';
        btn.disabled = false;
      })
      .catch(function(error) {
        // ── Affiche l'erreur complète dans la console
        console.error('❌ EmailJS error status :', error.status);
        console.error('❌ EmailJS error text   :', error.text);
        console.error('❌ EmailJS error complet:', JSON.stringify(error));

        // ── Affiche l'erreur précise sur la page
        const errEl = document.getElementById('form-error');
        errEl.querySelector('p').textContent =
          'Erreur ' + error.status + ' : ' + (error.text || 'Veuillez réessayer.');
        errEl.style.display   = 'flex';
        document.getElementById('form-success').style.display = 'none';
        btn.innerHTML = '<i class="fas fa-paper-plane"></i> Envoyer ma demande';
        btn.disabled = false;
      });
  });
</script>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
// ══ CONVERTISSEUR DE DEVISES — via API Symfony ═══════════════════
(function () {
  const POPULAR = [
    { code: 'TND', flag: '🇹🇳' },
    { code: 'EUR', flag: '🇪🇺' },
    { code: 'USD', flag: '🇺🇸' },
    { code: 'GBP', flag: '🇬🇧' },
    { code: 'MAD', flag: '🇲🇦' },
    { code: 'DZD', flag: '🇩🇿' },
    { code: 'SAR', flag: '🇸🇦' },
    { code: 'AED', flag: '🇦🇪' },
    { code: 'CAD', flag: '🇨🇦' },
    { code: 'JPY', flag: '🇯🇵' },
  ];

  const el = {
    amount   : document.getElementById('cv-amount'),
    from     : document.getElementById('cv-from'),
    to       : document.getElementById('cv-to'),
    result   : document.getElementById('cv-result-amount'),
    rateBox  : document.getElementById('cv-rate-box'),
    rateLabel: document.getElementById('cv-rate-label'),
    dateLabel: document.getElementById('cv-date-label'),
    btn      : document.getElementById('cv-btn'),
    swap     : document.getElementById('cv-swap'),
    shorts   : document.getElementById('cv-shortcuts'),
    error    : document.getElementById('cv-error'),
  };

  if (!el.amount) return;

  // ── 1. Charger les devises depuis ton API Symfony ─────────────
  async function loadCurrencies() {
    try {
      const res  = await fetch('/api/currency/currencies');
      const data = await res.json(); // { EUR: "Euro", USD: "US Dollar", ... }

      [el.from, el.to].forEach(sel => {
        sel.innerHTML = '';
        Object.entries(data).forEach(([code, name]) => {
          const pop = POPULAR.find(p => p.code === code);
          const opt = document.createElement('option');
          opt.value = code;
          opt.textContent = pop ? `${pop.flag} ${code} — ${name}` : `${code} — ${name}`;
          sel.appendChild(opt);
        });
      });

      el.from.value = 'EUR';
      el.to.value   = 'USD';

      buildShortcuts();
      await convert();
    } catch (e) {
      showError('Impossible de charger les devises.');
    }
  }

  // ── 2. Convertir via ton API Symfony ─────────────────────────
  async function convert() {
    const amount = parseFloat(el.amount.value);
    const from   = el.from.value;
    const to     = el.to.value;

    if (!amount || amount <= 0 || !from || !to) {
      el.result.textContent = '—';
      return;
    }

    el.btn.disabled     = true;
    el.btn.textContent  = '⏳ Chargement...';
    hideError();

    try {
      const url  = `/api/currency/convert?amount=${amount}&from=${from}&to=${to}`;
      const res  = await fetch(url);
      const data = await res.json();

      if (!res.ok || data.error) {
        throw new Error(data.error ?? 'Erreur de conversion');
      }

      // Résultat
      el.result.textContent = formatNum(data.result, data.to);

      // Taux + date
      el.rateLabel.textContent = `1 ${data.from} = ${parseFloat(data.rate).toFixed(4)} ${data.to}`;
      el.dateLabel.textContent = data.date ? `Mis à jour : ${formatDate(data.date)}` : '';
      el.rateBox.style.display = 'flex';

    } catch (e) {
      showError(e.message || 'Erreur lors de la conversion.');
      el.result.textContent = '—';
      el.rateBox.style.display = 'none';
    } finally {
      el.btn.disabled    = false;
      el.btn.innerHTML   = '💱 Convertir';
    }
  }

  // ── 3. Raccourcis devises populaires ─────────────────────────
  function buildShortcuts() {
    el.shorts.innerHTML = '';
    POPULAR.forEach(({ code, flag }) => {
      const btn = document.createElement('button');
      btn.textContent   = `${flag} ${code}`;
      btn.type          = 'button';
      btn.style.cssText = [
        'padding:.35rem .85rem',
        'border-radius:50px',
        'cursor:pointer',
        'font-size:.75rem',
        'font-weight:600',
        'background:rgba(255,255,255,0.05)',
        'border:1px solid rgba(201,168,76,0.2)',
        'color:rgba(255,255,255,0.6)',
        'transition:all .2s',
        "font-family:'Plus Jakarta Sans',sans-serif",
      ].join(';');

      btn.addEventListener('mouseenter', () => {
        btn.style.background  = 'rgba(201,168,76,0.15)';
        btn.style.borderColor = 'var(--gold)';
        btn.style.color       = 'var(--gold)';
      });
      btn.addEventListener('mouseleave', () => {
        btn.style.background  = 'rgba(255,255,255,0.05)';
        btn.style.borderColor = 'rgba(201,168,76,0.2)';
        btn.style.color       = 'rgba(255,255,255,0.6)';
      });
      btn.addEventListener('click', () => {
        el.to.value = code;
        convert();
      });

      el.shorts.appendChild(btn);
    });
  }

  // ── Helpers ───────────────────────────────────────────────────
  function formatNum(n, currency) {
    try {
      return new Intl.NumberFormat('fr-TN', {
        style: 'currency',
        currency,
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
      }).format(n);
    } catch {
      return parseFloat(n).toFixed(2) + ' ' + currency;
    }
  }

  function formatDate(d) {
    if (!d) return '';
    const [y, m, day] = d.split('-');
    return `${day}/${m}/${y}`;
  }

  function showError(msg) {
    el.error.textContent  = msg;
    el.error.style.display = 'block';
  }
  function hideError() {
    el.error.style.display = 'none';
  }

  // ── Événements ────────────────────────────────────────────────
  el.btn.addEventListener('click', convert);

  el.amount.addEventListener('keydown', e => {
    if (e.key === 'Enter') convert();
  });

  el.swap.addEventListener('click', () => {
    [el.from.value, el.to.value] = [el.to.value, el.from.value];
    convert();
  });
  el.swap.addEventListener('mouseenter', () => el.swap.style.transform = 'rotate(180deg)');
  el.swap.addEventListener('mouseleave', () => el.swap.style.transform = 'rotate(0deg)');

  // ── Lancement ─────────────────────────────────────────────────
  loadCurrencies();
})();
</script>
{% endblock %}
