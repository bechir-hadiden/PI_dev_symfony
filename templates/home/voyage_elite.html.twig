{% block javascripts %}
    {{ parent() }}
    <script>
        // Chat functionality
        const responses = [
            "Excellente question ! Pour un budget de 3 000 € par personne, je vous recommande le Hôtel Canaves Oia Epitome à Santorin — une vue à couper le souffle — puis le Monastero Santa Rosa sur la côte amalfitaine. Voulez-vous que je prépare l'itinéraire complet ?",
            "Absolument ! J'ai trouvé des vols directs Paris–Athènes et Naples–Paris avec vos dates. Je peux bloquer les options dès maintenant. Préférez-vous Business ou Première Classe ?",
            "Votre itinéraire est prêt. 5 nuits à Santorin avec excursion en catamaran, puis 5 nuits à Positano avec dîner privé sur terrasse. Je vous envoie le dossier complet par email. Avez-vous des restrictions alimentaires ?",
            "Je réserve immédiatement ! Votre voyage romantique Santorin–Amalfi est confirmé. Vous recevrez tous les détails d'ici quelques minutes. Y a-t-il autre chose que je puisse faire pour vous ?"
        ];
        let rIdx = 0;

        function addMessage(text, isUser) {
            const msgs = document.getElementById('chatMessages');
            if (!msgs) return;
            const div = document.createElement('div');
            div.className = 'voyage-msg' + (isUser ? ' user' : '');
            const av = document.createElement('div');
            av.className = 'voyage-msg-avatar' + (isUser ? ' user-av' : '');
            av.textContent = isUser ? 'V' : 'E';
            const bubble = document.createElement('div');
            bubble.className = 'voyage-msg-bubble ' + (isUser ? 'user' : 'agent');
            bubble.textContent = text;
            div.appendChild(av);
            div.appendChild(bubble);
            msgs.appendChild(div);
            msgs.scrollTop = msgs.scrollHeight;
        }

        const sendBtn = document.getElementById('chatSend');
        const chatInput = document.getElementById('chatInput');
        
        if (sendBtn && chatInput) {
            sendBtn.addEventListener('click', function() {
                const text = chatInput.value.trim();
                if (!text) return;
                addMessage(text, true);
                chatInput.value = '';
                
                const typingDiv = document.createElement('div');
                typingDiv.className = 'voyage-msg';
                typingDiv.id = 'typingMsg';
                const typingAv = document.createElement('div');
                typingAv.className = 'voyage-msg-avatar';
                typingAv.textContent = 'E';
                const typingBubble = document.createElement('div');
                typingBubble.className = 'voyage-msg-bubble agent voyage-typing';
                typingBubble.innerHTML = '<span></span><span></span><span></span>';
                typingDiv.appendChild(typingAv);
                typingDiv.appendChild(typingBubble);
                document.getElementById('chatMessages').appendChild(typingDiv);
                document.getElementById('chatMessages').scrollTop = 99999;
                
                setTimeout(() => {
                    const typingEl = document.getElementById('typingMsg');
                    if (typingEl) typingEl.remove();
                    const resp = responses[rIdx % responses.length];
                    rIdx++;
                    addMessage(resp, false);
                }, 1600);
            });
            
            chatInput.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') sendBtn.click();
            });
        }
        
        // Newsletter subscription
        const newsletterSubmit = document.getElementById('newsletterSubmit');
        if (newsletterSubmit) {
            newsletterSubmit.addEventListener('click', function() {
                const email = document.getElementById('newsletterEmail').value;
                if (email && email.includes('@')) {
                    alert('Merci pour votre inscription ! Vous recevrez nos meilleures offres.');
                    document.getElementById('newsletterEmail').value = '';
                } else {
                    alert('Veuillez entrer une adresse email valide.');
                }
            });
        }
    </script>
{% endblock %}