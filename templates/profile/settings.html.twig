{% extends 'base.html.twig' %}
{% block title %}Account Settings{% endblock %}

{% block extra_css %}
.settings-page { max-width: 800px; margin: 0 auto; padding: 2.5rem 2rem 4rem; }
.settings-header { margin-bottom: 2.5rem; }
.settings-header h1 { font-size: 2rem; }

.profile-hero {
    background: var(--ink);
    padding: 2rem 2.5rem;
    display: flex; align-items: center; gap: 1.8rem;
    margin-bottom: 2rem;
    position: relative; overflow: hidden;
}
.profile-hero::before {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(184,150,62,0.12) 0%, transparent 60%);
}
.profile-hero-content { position: relative; z-index: 1; display: flex; align-items: center; gap: 1.8rem; width: 100%; }
.profile-avatar { width: 76px; height: 76px; border-radius: 50%; border: 2px solid rgba(184,150,62,0.5); object-fit: cover; flex-shrink: 0; }
.profile-info { flex: 1; }
.profile-name { font-family:'Cormorant Garamond',serif; font-size: 1.6rem; font-weight: 300; color: var(--white); margin-bottom: 0.2rem; }
.profile-username { font-size: 0.8rem; color: rgba(240,232,216,0.5); letter-spacing: 0.06em; }
.profile-meta { display: flex; gap: 1rem; margin-top: 0.6rem; flex-wrap: wrap; }
.profile-meta-item { font-size: 0.72rem; color: rgba(240,232,216,0.5); letter-spacing: 0.08em; text-transform: uppercase; }

.settings-tabs { display: flex; border-bottom: 0.5px solid var(--border); margin-bottom: 2rem; }
.tab-btn {
    padding: 0.8rem 1.6rem; font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--muted); background: none; border: none; cursor: pointer;
    border-bottom: 2px solid transparent; margin-bottom: -0.5px;
    transition: color 0.2s, border-color 0.2s; font-family: 'DM Sans', sans-serif;
}
.tab-btn:hover { color: var(--gold); }
.tab-btn.active { color: var(--gold); border-bottom-color: var(--gold); }
.tab-panel { display: none; }
.tab-panel.active { display: block; }

.settings-section { background: var(--white); border: 0.5px solid var(--border); padding: 1.8rem 2rem; margin-bottom: 1.2rem; }
.settings-section-title {
    font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--muted); padding-bottom: 1rem; margin-bottom: 1.5rem;
    border-bottom: 0.5px solid var(--border);
}
.settings-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }
.settings-grid .full { grid-column: 1 / -1; }

.strength-bar { height: 3px; background: var(--border); margin-top: 0.5rem; border-radius: 2px; overflow: hidden; }
.strength-fill { height: 100%; width: 0; transition: width 0.3s, background 0.3s; }
.pw-wrap { position: relative; }
.pw-toggle { position: absolute; right: 0.8rem; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: var(--muted); font-size: 0.85rem; padding: 0; }
.pw-toggle:hover { color: var(--gold); }
.req-item { font-size: 0.71rem; color: var(--muted); display: flex; align-items: center; gap: 0.4rem; padding: 0.12rem 0; transition: color 0.2s; }
.req-item .dot { width: 5px; height: 5px; border-radius: 50%; background: var(--border); transition: background 0.2s; flex-shrink: 0; }
.req-item.met { color: var(--success); }
.req-item.met .dot { background: var(--success); }

.google-notice {
    background: rgba(66,133,244,0.07);
    border-left: 3px solid #4285F4;
    padding: 1rem 1.2rem; margin-bottom: 1rem;
    font-size: 0.83rem; color: var(--muted); line-height: 1.6;
}
.google-notice strong { color: #4285F4; }

@media (max-width: 600px) {
    .settings-grid { grid-template-columns: 1fr; }
    .settings-grid .full { grid-column: 1; }
    .profile-hero-content { flex-direction: column; align-items: flex-start; gap: 1rem; }
}
{% endblock %}

{% block body %}
<div class="settings-page">

    <div class="settings-header">
        <div class="section-tag">Account</div>
        <h1>Profile <em style="font-style:italic;color:var(--gold);">Settings</em></h1>
    </div>

    {# ── Profile Hero ── #}
    <div class="profile-hero">
        <div class="profile-hero-content">
            <img src="{{ user.avatarUrl }}" alt="{{ user.username }}" class="profile-avatar">
            <div class="profile-info">
                <div class="profile-name">{{ user.fullName }}</div>
                <div class="profile-username">@{{ user.username }}</div>
                <div class="profile-meta">
                    <span class="profile-meta-item">{{ user.email }}</span>
                    {% if user.phone %}<span class="profile-meta-item">{{ user.phone }}</span>{% endif %}
                    <span class="profile-meta-item">{{ user.role }}</span>
                    {% if user.createdAt %}<span class="profile-meta-item">Member since {{ user.createdAt|date('M Y') }}</span>{% endif %}
                    {% if user.isGoogleAccount() %}<span class="profile-meta-item" style="color:rgba(212,176,106,0.7);">Google Account</span>{% endif %}
                </div>
            </div>
            <div>
                {% if user.isAdmin() %}
                    <span class="badge badge-admin">◈ Admin</span>
                {% else %}
                    <span class="badge badge-client">◈ Client</span>
                {% endif %}
            </div>
        </div>
    </div>

    {# ── Tabs ── #}
    <div class="settings-tabs">
        <button class="tab-btn {{ active_tab == 'info' or active_tab == '' ? 'active' }}" onclick="switchTab('info')" id="tab-btn-info">Personal Info</button>
        <button class="tab-btn {{ active_tab == 'password' ? 'active' }}" onclick="switchTab('password')" id="tab-btn-password">Change Password</button>
    </div>

    {# ── Tab: Personal Info ── #}
    <div class="tab-panel {{ active_tab == 'info' or active_tab == '' ? 'active' }}" id="panel-info">
        <form method="post" action="{{ path('profile_settings') }}" novalidate>
            <input type="hidden" name="_tab" value="info">
            <div class="settings-section">
                <div class="settings-section-title">Personal Information</div>
                <div class="settings-grid">
                    <div class="form-group">
                        <label class="form-label">Full Name *</label>
                        <input type="text" name="fullName" value="{{ user.fullName }}" class="form-control" placeholder="Your full name" required>
                        {% if errors.fullName is defined %}<div class="form-error">{{ errors.fullName }}</div>{% endif %}
                    </div>
                    <div class="form-group">
                        <label class="form-label">Username *</label>
                        <input type="text" name="username" value="{{ user.username }}" class="form-control" placeholder="hamdi123" required>
                        {% if errors.username is defined %}
                            <div class="form-error">{{ errors.username }}</div>
                        {% else %}
                            <div class="form-help">Must start with a letter, then letters/numbers only.</div>
                        {% endif %}
                    </div>
                    <div class="form-group full">
                        <label class="form-label">Email Address *</label>
                        <input type="email" name="email" value="{{ user.email }}" class="form-control" placeholder="you@email.com" required>
                        {% if errors.email is defined %}<div class="form-error">{{ errors.email }}</div>{% endif %}
                    </div>
                    <div class="form-group full">
                        <label class="form-label">Phone Number</label>
                        <input type="tel" name="phone" value="{{ user.phone ?? '' }}" class="form-control" placeholder="+216 XX XXX XXX">
                    </div>
                </div>
            </div>
            <div style="display:flex;gap:1rem;align-items:center;">
                <button type="submit" class="btn btn-primary">Save Changes →</button>
                <span style="font-size:0.75rem;color:var(--muted);">* Required fields</span>
            </div>
        </form>
    </div>

    {# ── Tab: Change Password ── #}
    <div class="tab-panel {{ active_tab == 'password' ? 'active' }}" id="panel-password">
        <form method="post" action="{{ path('profile_settings') }}" novalidate>
            <input type="hidden" name="_tab" value="password">
            <div class="settings-section">
                <div class="settings-section-title">🔒 Change Password</div>

                {# Notice for Google-only accounts #}
                {% if user.isGoogleAccount() and not user.password %}
                <div class="google-notice">
                    <strong>Google Account</strong> — Your account uses Google sign-in and has no local password.
                    To set one, use <a href="{{ path('password_reset_request') }}" style="color:#4285F4;">Forgot Password</a> on the login page.
                </div>
                {% else %}
                <div class="form-group">
                    <label class="form-label">Current Password *</label>
                    <div class="pw-wrap">
                        <input type="password" name="current_password" id="current_pw" class="form-control" placeholder="Your current password" autocomplete="current-password">
                        <button type="button" class="pw-toggle" onclick="togglePw('current_pw',this)">👁</button>
                    </div>
                    {% if errors.current_password is defined %}<div class="form-error">{{ errors.current_password }}</div>{% endif %}
                </div>

                <div style="height:0.5px;background:var(--border);margin:1.2rem 0;"></div>

                <div class="settings-grid">
                    <div class="form-group">
                        <label class="form-label">New Password *</label>
                        <div class="pw-wrap">
                            <input type="password" id="new_pw" name="new_password" class="form-control" placeholder="Min. 8 characters" autocomplete="new-password">
                            <button type="button" class="pw-toggle" onclick="togglePw('new_pw',this)">👁</button>
                        </div>
                        <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.2rem;margin-top:0.5rem;">
                            <div class="req-item" id="req-len"><span class="dot"></span>8+ characters</div>
                            <div class="req-item" id="req-upper"><span class="dot"></span>Uppercase</div>
                            <div class="req-item" id="req-lower"><span class="dot"></span>Lowercase</div>
                            <div class="req-item" id="req-num"><span class="dot"></span>Number</div>
                            <div class="req-item" id="req-sym"><span class="dot"></span>Symbol</div>
                        </div>
                        {% if errors.new_password is defined %}<div class="form-error">{{ errors.new_password }}</div>{% endif %}
                    </div>
                    <div class="form-group">
                        <label class="form-label">Confirm New Password *</label>
                        <div class="pw-wrap">
                            <input type="password" id="confirm_pw" name="confirm_password" class="form-control" placeholder="Repeat new password" autocomplete="new-password">
                            <button type="button" class="pw-toggle" onclick="togglePw('confirm_pw',this)">👁</button>
                        </div>
                        <div class="form-error" id="matchErr" style="display:none;">Passwords do not match.</div>
                        {% if errors.confirm_password is defined %}<div class="form-error">{{ errors.confirm_password }}</div>{% endif %}
                    </div>
                </div>
                <button type="submit" class="btn btn-primary" style="margin-top:0.5rem;">Update Password →</button>
                {% endif %}
            </div>
        </form>
    </div>

</div>
{% endblock %}

{% block extra_js %}
<script>
function switchTab(name) {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    document.getElementById('tab-btn-' + name).classList.add('active');
    document.getElementById('panel-' + name).classList.add('active');
}

function togglePw(id, btn) {
    const input = document.getElementById(id);
    if (!input) return;
    input.type = input.type === 'password' ? 'text' : 'password';
    btn.textContent = input.type === 'password' ? '👁' : '🙈';
}

const newPw    = document.getElementById('new_pw');
const confirmEl = document.getElementById('confirm_pw');

if (newPw) {
    newPw.addEventListener('input', () => {
        const val = newPw.value;
        const checks = {
            'req-len':  val.length >= 8,
            'req-upper':/[A-Z]/.test(val),
            'req-lower':/[a-z]/.test(val),
            'req-num':  /\d/.test(val),
            'req-sym':  /[\W_]/.test(val),
        };
        let met = 0;
        for (const [id, ok] of Object.entries(checks)) {
            const el = document.getElementById(id);
            if (el) { el.classList.toggle('met', ok); if (ok) met++; }
        }
        const fill = document.getElementById('strengthFill');
        if (fill) {
            const colors = ['','#c0392b','#e67e22','#f1c40f','#2d7a4f','#2d7a4f'];
            fill.style.width = (met / 5 * 100) + '%';
            fill.style.background = met > 0 ? colors[met] : '';
        }
    });
}

if (confirmEl && newPw) {
    confirmEl.addEventListener('input', () => {
        const err = document.getElementById('matchErr');
        if (err) err.style.display = (confirmEl.value && confirmEl.value !== newPw.value) ? 'block' : 'none';
    });
}
</script>
{% endblock %}
