{# templates/reservation/my_reservations.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}VoyageÉlite - Mes réservations{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --ink: #0d0d0d;
            --sand: #f0e8d8;
            --cream: #faf6ef;
            --gold: #b8963e;
            --gold-lt: #d4b06a;
            --muted: #6b6560;
            --white: #ffffff;
        }
        
        body {
            background: var(--cream);
            font-family: 'DM Sans', sans-serif;
        }
        
        .my-reservations-container {
            max-width: 900px;
            margin: 0 auto;
            padding: 7rem 2rem 4rem;
        }
        
        /* Header */
        .page-header {
            text-align: center;
            margin-bottom: 3rem;
        }
        
        .page-header h1 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2.5rem;
            font-weight: 300;
            letter-spacing: 0.02em;
            margin-bottom: 0.5rem;
        }
        
        .page-header h1 span {
            color: var(--gold);
            font-style: italic;
        }
        
        .page-header p {
            color: var(--muted);
            font-size: 0.9rem;
        }
        
        /* Search Card */
        .search-card {
            background: var(--white);
            padding: 2rem;
            margin-bottom: 2rem;
            text-align: center;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        }
        
        .search-icon {
            width: 60px;
            height: 60px;
            background: rgba(184,150,62,0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
        }
        
        .search-icon i {
            font-size: 1.8rem;
            color: var(--gold);
        }
        
        .search-card h3 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.3rem;
            font-weight: 300;
            margin-bottom: 0.5rem;
        }
        
        .search-card p {
            color: var(--muted);
            font-size: 0.85rem;
            margin-bottom: 1.5rem;
        }
        
        .search-form {
            display: flex;
            gap: 0.5rem;
            max-width: 400px;
            margin: 0 auto;
        }
        
        .search-input {
            flex: 1;
            padding: 0.8rem 1rem;
            border: 0.5px solid rgba(184,150,62,0.3);
            background: var(--white);
            font-family: 'DM Sans', sans-serif;
            font-size: 0.9rem;
            outline: none;
            transition: border 0.2s;
        }
        
        .search-input:focus {
            border-color: var(--gold);
        }
        
        .search-btn {
            background: var(--gold);
            border: none;
            padding: 0.8rem 1.5rem;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: 500;
        }
        
        .search-btn:hover {
            background: var(--ink);
            color: var(--white);
        }
        
        /* Results */
        .results-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            padding-bottom: 0.5rem;
            border-bottom: 0.5px solid rgba(184,150,62,0.3);
        }
        
        .results-header h3 {
            font-size: 1.1rem;
            font-weight: 500;
        }
        
        .results-count {
            color: var(--gold);
            font-weight: 600;
        }
        
        /* Reservation Cards */
        .reservations-list {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }
        
        .reservation-item {
            background: var(--white);
            transition: transform 0.2s, box-shadow 0.2s;
            overflow: hidden;
        }
        
        .reservation-item:hover {
            transform: translateX(5px);
            box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        }
        
        .reservation-content {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            padding: 1.2rem;
            gap: 1rem;
        }
        
        .reservation-info {
            flex: 2;
            min-width: 200px;
        }
        
        .flight-badge {
            display: inline-block;
            background: rgba(184,150,62,0.1);
            padding: 0.2rem 0.6rem;
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.05em;
            margin-bottom: 0.5rem;
        }
        
        .destination-name {
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 0.3rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .destination-name i {
            color: var(--gold);
            font-size: 0.9rem;
        }
        
        .flight-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            font-size: 0.75rem;
            color: var(--muted);
        }
        
        .flight-meta i {
            margin-right: 0.3rem;
        }
        
        .reservation-stats {
            flex: 1;
            min-width: 150px;
            text-align: center;
        }
        
        .price {
            font-size: 1.3rem;
            font-weight: 600;
            color: var(--gold);
        }
        
        .passengers {
            font-size: 0.7rem;
            color: var(--muted);
        }
        
        .status-badge {
            font-size: 0.7rem;
            padding: 0.3rem 0.8rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            display: inline-block;
        }
        
        .status-confirmed {
            background: #28a745;
            color: white;
        }
        
        .status-cancelled {
            background: #dc3545;
            color: white;
        }
        
        .status-pending {
            background: #ffc107;
            color: #333;
        }
        
        .status-completed {
            background: var(--gold);
            color: var(--ink);
        }
        
        .reservation-actions {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }
        
        .btn-icon {
            background: none;
            border: 0.5px solid rgba(184,150,62,0.3);
            padding: 0.5rem;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            color: var(--ink);
        }
        
        .btn-icon:hover {
            background: var(--gold);
            border-color: var(--gold);
            transform: translateY(-2px);
        }
        
        .btn-icon-danger:hover {
            background: #dc3545;
            color: white;
            border-color: #dc3545;
        }
        
        /* Empty state */
        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            background: var(--white);
        }
        
        .empty-state i {
            font-size: 4rem;
            color: var(--gold-lt);
            margin-bottom: 1rem;
        }
        
        .empty-state h3 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.5rem;
            font-weight: 300;
            margin-bottom: 0.5rem;
        }
        
        .empty-state p {
            color: var(--muted);
        }
        
        /* Alert */
        .alert-info {
            background: rgba(184,150,62,0.1);
            border: 0.5px solid rgba(184,150,62,0.3);
            color: var(--ink);
            padding: 1rem;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.8rem;
        }
        
        .alert-info i {
            color: var(--gold);
            font-size: 1.2rem;
        }
        
        /* Modal */
        .modal-content {
            border-radius: 0;
            border: none;
        }
        
        .modal-header {
            background: var(--ink);
            color: var(--white);
            border: none;
            border-radius: 0;
        }
        
        .modal-header .btn-close-white {
            filter: brightness(0) invert(1);
        }
        
        /* Responsive */
        @media (max-width: 768px) {
            .my-reservations-container { padding: 6rem 1rem 3rem; }
            .search-form { flex-direction: column; }
            .reservation-content { flex-direction: column; text-align: center; }
            .flight-meta { justify-content: center; }
            .reservation-actions { justify-content: center; }
        }
    </style>
{% endblock %}

{% block body %}
<div class="my-reservations-container">
    <!-- Header -->
    <div class="page-header">
        <h1>Mes <span>réservations</span></h1>
        <p>Retrouvez toutes vos réservations par email</p>
    </div>
    
    <!-- Messages flash -->
    {% for message in app.flashes('success') %}
        <div class="alert alert-success" style="background: #28a745; color: white; border: none; border-radius: 0; padding: 1rem; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.8rem;">
            <i class="fas fa-check-circle"></i> {{ message }}
        </div>
    {% endfor %}
    
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger" style="background: #dc3545; color: white; border: none; border-radius: 0; padding: 1rem; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.8rem;">
            <i class="fas fa-exclamation-circle"></i> {{ message }}
        </div>
    {% endfor %}
    
    <!-- Formulaire de recherche par email -->
    <div class="search-card">
        <div class="search-icon">
            <i class="fas fa-envelope"></i>
        </div>
        <h3>Retrouvez vos réservations</h3>
        <p>Saisissez l'adresse email utilisée lors de la réservation</p>
        
        <form method="GET" action="{{ path('app_mes_reservations') }}" class="search-form">
            <input type="email" name="email" class="search-input" placeholder="votre@email.com" value="{{ searchEmail }}" required>
            <button type="submit" class="search-btn">
                <i class="fas fa-search"></i> Rechercher
            </button>
        </form>
    </div>
    
    <!-- Résultats -->
    {% if searchEmail is not null %}
        {% if reservations is empty %}
            <div class="empty-state">
                <i class="fas fa-inbox"></i>
                <h3>Aucune réservation trouvée</h3>
                <p>Aucune réservation n'a été trouvée pour l'adresse <strong>{{ searchEmail }}</strong></p>
            </div>
        {% else %}
            <div class="results-header">
                <h3><i class="fas fa-ticket-alt me-2" style="color: var(--gold);"></i>Vos réservations</h3>
                <span class="results-count">{{ reservations|length }} résultat(s)</span>
            </div>
            
            <div class="reservations-list">
                {% for reservation in reservations %}
                <div class="reservation-item">
                    <div class="reservation-content">
                        <div class="reservation-info">
                            <div class="flight-badge">
                                <i class="fas fa-plane"></i> {{ reservation.flightNumber }} • {{ reservation.airline }}
                            </div>
                            <div class="destination-name">
                                <i class="fas fa-map-marker-alt"></i>
                                {{ reservation.destination }}
                            </div>
                            <div class="flight-meta">
                                <span><i class="fas fa-calendar"></i> {{ reservation.departureTime|date('d/m/Y') }}</span>
                                <span><i class="fas fa-clock"></i> {{ reservation.departureTime|date('H:i') }}</span>
                                <span><i class="fas fa-map-pin"></i> {{ reservation.departureAirport }} → {{ reservation.arrivalAirport }}</span>
                            </div>
                        </div>
                        
                        <div class="reservation-stats">
                            <div class="price">{{ reservation.totalPrice }} €</div>
                            <div class="passengers"><i class="fas fa-users"></i> {{ reservation.numberOfPassengers }} passager(s)</div>
                            <div class="mt-2">
                                <span class="status-badge status-{{ reservation.status }}">
                                    {% if reservation.status == 'confirmed' %}
                                        <i class="fas fa-check-circle"></i> Confirmé
                                    {% elseif reservation.status == 'cancelled' %}
                                        <i class="fas fa-times-circle"></i> Annulé
                                    {% elseif reservation.status == 'pending' %}
                                        <i class="fas fa-clock"></i> En attente
                                    {% else %}
                                        <i class="fas fa-flag-checkered"></i> Terminé
                                    {% endif %}
                                </span>
                            </div>
                        </div>
                        
                        <div class="reservation-actions">
                            <a href="{{ path('app_reservation_show', {'id': reservation.id}) }}" class="btn-icon" title="Voir détails">
                                <i class="fas fa-eye"></i>
                            </a>
                            
                            {% if reservation.status == 'confirmed' and reservation.hasBoardingPass %}
                                <a href="{{ path('app_reservation_boarding_pass', {'id': reservation.id}) }}" class="btn-icon" title="Carte d'embarquement" target="_blank">
                                    <i class="fas fa-qrcode"></i>
                                </a>
                            {% endif %}
                            
                            {% if reservation.cancellable %}
                                <button type="button" class="btn-icon btn-icon-danger" data-bs-toggle="modal" data-bs-target="#cancelModal{{ reservation.id }}" title="Annuler">
                                    <i class="fas fa-times"></i>
                                </button>
                            {% endif %}
                        </div>
                    </div>
                </div>
                
                <!-- Modal d'annulation -->
                <div class="modal fade" id="cancelModal{{ reservation.id }}" tabindex="-1">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <form method="post" action="{{ path('app_reservation_cancel', {'id': reservation.id}) }}">
                                <div class="modal-header">
                                    <h5 class="modal-title">
                                        <i class="fas fa-times-circle me-2"></i>Annuler la réservation
                                    </h5>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <p>Voulez-vous vraiment annuler la réservation pour <strong>{{ reservation.destination }}</strong> ?</p>
                                    <div class="form-group mt-3">
                                        <label class="form-label" style="font-size: 0.8rem;">Raison de l'annulation (optionnel)</label>
                                        <textarea name="reason" class="form-control" rows="3" placeholder="Motif de l'annulation..." style="border: 0.5px solid rgba(184,150,62,0.3); padding: 0.8rem; width: 100%;"></textarea>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn-action" data-bs-dismiss="modal">Fermer</button>
                                    <button type="submit" class="btn-action btn-danger" style="border-color: #dc3545; color: #dc3545;">Confirmer l'annulation</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        {% endif %}
    {% endif %}
</div>

<style>
    .btn-action {
        background: none;
        border: 0.5px solid rgba(184,150,62,0.3);
        padding: 0.5rem 1rem;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--ink);
    }
    
    .btn-action:hover {
        background: var(--gold);
        border-color: var(--gold);
        transform: translateY(-1px);
    }
    
    .btn-danger {
        border-color: #dc3545;
        color: #dc3545;
    }
    
    .btn-danger:hover {
        background: #dc3545;
        color: white;
        border-color: #dc3545;
    }
    
    .form-control {
        font-family: 'DM Sans', sans-serif;
    }
    
    .form-control:focus {
        border-color: var(--gold);
        outline: none;
    }
</style>

<script>
    // Animation au chargement
    document.addEventListener('DOMContentLoaded', function() {
        const items = document.querySelectorAll('.reservation-item');
        items.forEach((item, index) => {
            item.style.opacity = '0';
            item.style.transform = 'translateX(-10px)';
            setTimeout(() => {
                item.style.transition = 'all 0.3s ease';
                item.style.opacity = '1';
                item.style.transform = 'translateX(0)';
            }, index * 80);
        });
    });
</script>
{% endblock %}