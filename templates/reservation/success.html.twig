{# templates/reservation/success.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}VoyageÉlite - Réservation confirmée{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --ink: #0d0d0d;
            --sand: #f0e8d8;
            --cream: #faf6ef;
            --gold: #b8963e;
            --gold-lt: #d4b06a;
            --muted: #6b6560;
            --white: #ffffff;
        }
        
        body {
            background: var(--cream);
            font-family: 'DM Sans', sans-serif;
        }
        
        .success-container {
            max-width: 600px;
            margin: 0 auto;
            padding: 8rem 2rem 4rem;
            text-align: center;
        }
        
        .success-card {
            background: var(--white);
            padding: 3rem 2rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }
        
        .success-icon {
            width: 80px;
            height: 80px;
            background: #28a745;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
        }
        
        .success-icon i {
            font-size: 2.5rem;
            color: white;
        }
        
        .success-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2rem;
            font-weight: 300;
            margin-bottom: 1rem;
        }
        
        .success-message {
            color: var(--muted);
            margin-bottom: 2rem;
            line-height: 1.6;
        }
        
        .reservation-number {
            background: rgba(184,150,62,0.1);
            padding: 1rem;
            margin-bottom: 2rem;
        }
        
        .reservation-number span {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--muted);
        }
        
        .reservation-number strong {
            font-size: 1.2rem;
            color: var(--gold);
        }
        
        .btn-action {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: var(--gold);
            color: var(--ink);
            padding: 0.8rem 1.5rem;
            text-decoration: none;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            transition: all 0.2s;
            margin: 0 0.5rem;
        }
        
        .btn-action:hover {
            background: var(--ink);
            color: var(--white);
            transform: translateY(-2px);
        }
        
        .btn-outline {
            background: none;
            border: 0.5px solid rgba(184,150,62,0.3);
            color: var(--ink);
        }
        
        .btn-outline:hover {
            background: var(--ink);
            color: var(--white);
            border-color: var(--ink);
        }
        
        @media (max-width: 768px) {
            .success-container { padding: 6rem 1rem 2rem; }
            .btn-action { display: block; margin: 0.5rem 0; text-align: center; }
        }
    </style>
{% endblock %}

{% block body %}
<div class="success-container">
    <div class="success-card">
        <div class="success-icon">
            <i class="fas fa-check"></i>
        </div>
        <h1 class="success-title">Réservation confirmée !</h1>
        <p class="success-message">
            Merci pour votre confiance. Votre réservation a bien été enregistrée.<br>
            Vous recevrez un email de confirmation sous 24h.
        </p>
        
        <div class="reservation-number">
            <span>Numéro de réservation</span><br>
            <strong>#{{ reservation.id }}</strong>
        </div>
        
        <div>
            <a href="{{ path('app_mes_reservations') }}" class="btn-action">
                <i class="fas fa-ticket-alt"></i> Mes réservations
            </a>
            <a href="{{ path('app_avis_index') }}" class="btn-action btn-outline">
                <i class="fas fa-home"></i> Accueil
            </a>
        </div>
    </div>
</div>
{% endblock %}