{# templates/reservation/list.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}VoyageÉlite - Toutes les réservations{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --ink: #0d0d0d;
            --sand: #f0e8d8;
            --cream: #faf6ef;
            --gold: #b8963e;
            --gold-lt: #d4b06a;
            --muted: #6b6560;
            --white: #ffffff;
        }
        
        body {
            background: var(--cream);
            font-family: 'DM Sans', sans-serif;
        }
        
        .reservations-container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 7rem 2rem 4rem;
        }
        
        /* Header */
        .page-header {
            text-align: center;
            margin-bottom: 3rem;
        }
        
        .page-header h1 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2.5rem;
            font-weight: 300;
            letter-spacing: 0.02em;
            margin-bottom: 0.5rem;
        }
        
        .page-header h1 span {
            color: var(--gold);
            font-style: italic;
        }
        
        .page-header p {
            color: var(--muted);
            font-size: 0.9rem;
        }
        
        /* Filter Bar */
        .filter-bar {
            background: var(--white);
            padding: 1.5rem;
            margin-bottom: 2rem;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }
        
        .filter-grid {
            display: grid;
            grid-template-columns: 1fr 1fr auto;
            gap: 1rem;
            align-items: end;
        }
        
        .filter-group label {
            display: block;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--muted);
            margin-bottom: 0.5rem;
        }
        
        .filter-group input, .filter-group select {
            width: 100%;
            padding: 0.7rem 1rem;
            border: 0.5px solid rgba(184,150,62,0.3);
            background: var(--white);
            font-family: 'DM Sans', sans-serif;
            font-size: 0.85rem;
            outline: none;
            transition: border 0.2s;
        }
        
        .filter-group input:focus, .filter-group select:focus {
            border-color: var(--gold);
        }
        
        .btn-reset {
            background: var(--gold);
            border: none;
            padding: 0.7rem 1.5rem;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            cursor: pointer;
            transition: all 0.2s;
            font-weight: 500;
        }
        
        .btn-reset:hover {
            background: var(--ink);
            color: var(--white);
        }
        
        /* Stats */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1rem;
            margin-bottom: 2rem;
        }
        
        .stat-card {
            background: var(--white);
            padding: 1rem;
            text-align: center;
        }
        
        .stat-number {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.8rem;
            font-weight: 300;
            color: var(--gold);
        }
        
        .stat-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--muted);
        }
        
        /* Reservation Cards */
        .reservations-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
            gap: 1.5rem;
        }
        
        .reservation-card {
            background: var(--white);
            transition: transform 0.2s, box-shadow 0.2s;
            overflow: hidden;
        }
        
        .reservation-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }
        
        .card-header {
            background: var(--ink);
            color: var(--white);
            padding: 1rem 1.2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .flight-info {
            display: flex;
            align-items: center;
            gap: 0.8rem;
        }
        
        .flight-icon {
            width: 40px;
            height: 40px;
            background: rgba(255,255,255,0.15);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .flight-icon i {
            font-size: 1.2rem;
            color: var(--gold);
        }
        
        .flight-details h4 {
            font-size: 1rem;
            margin-bottom: 0.2rem;
        }
        
        .flight-details small {
            font-size: 0.7rem;
            opacity: 0.7;
        }
        
        .status-badge {
            font-size: 0.7rem;
            padding: 0.3rem 0.8rem;
            border-radius: 0;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        
        .status-confirmed {
            background: #28a745;
            color: white;
        }
        
        .status-cancelled {
            background: #dc3545;
            color: white;
        }
        
        .status-pending {
            background: #ffc107;
            color: #333;
        }
        
        .status-completed {
            background: var(--gold);
            color: var(--ink);
        }
        
        .card-body {
            padding: 1.2rem;
        }
        
        .destination {
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--ink);
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .destination i {
            color: var(--gold);
        }
        
        .flight-times {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            gap: 0.5rem;
            align-items: center;
            margin-bottom: 1rem;
            padding: 0.8rem 0;
            border-bottom: 0.5px solid rgba(184,150,62,0.2);
        }
        
        .time-point {
            text-align: center;
        }
        
        .time-label {
            font-size: 0.65rem;
            text-transform: uppercase;
            color: var(--muted);
        }
        
        .time-value {
            font-weight: 600;
            font-size: 0.9rem;
        }
        
        .flight-line {
            color: var(--gold);
            font-size: 0.8rem;
        }
        
        .passenger-info {
            display: flex;
            justify-content: space-between;
            margin-bottom: 1rem;
            font-size: 0.85rem;
        }
        
        .passenger-info span:first-child {
            color: var(--muted);
        }
        
        .passenger-info span:last-child {
            font-weight: 500;
        }
        
        .price {
            font-size: 1.3rem;
            font-weight: 600;
            color: var(--gold);
        }
        
        .card-footer {
            padding: 1rem 1.2rem;
            background: rgba(184,150,62,0.05);
            display: flex;
            gap: 0.8rem;
            flex-wrap: wrap;
        }
        
        .btn-action {
            background: none;
            border: 0.5px solid rgba(184,150,62,0.3);
            padding: 0.5rem 1rem;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            color: var(--ink);
        }
        
        .btn-action:hover {
            background: var(--gold);
            border-color: var(--gold);
            transform: translateY(-1px);
        }
        
        .btn-danger {
            border-color: #dc3545;
            color: #dc3545;
        }
        
        .btn-danger:hover {
            background: #dc3545;
            color: white;
            border-color: #dc3545;
        }
        
        .btn-success {
            border-color: #28a745;
            color: #28a745;
        }
        
        .btn-success:hover {
            background: #28a745;
            color: white;
            border-color: #28a745;
        }
        
        .btn-disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
        
        /* Empty state */
        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            background: var(--white);
        }
        
        .empty-state i {
            font-size: 4rem;
            color: var(--gold-lt);
            margin-bottom: 1rem;
        }
        
        .empty-state h3 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.5rem;
            font-weight: 300;
            margin-bottom: 0.5rem;
        }
        
        .empty-state p {
            color: var(--muted);
            margin-bottom: 1.5rem;
        }
        
        .btn-primary {
            background: var(--gold);
            color: var(--ink);
            padding: 0.8rem 1.5rem;
            text-decoration: none;
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 0.1em;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .btn-primary:hover {
            background: var(--ink);
            color: var(--white);
        }
        
        /* QR Preview */
        .qr-preview {
            width: 50px;
            height: 50px;
            cursor: pointer;
            transition: transform 0.2s;
        }
        
        .qr-preview:hover {
            transform: scale(1.05);
        }
        
        /* Modal */
        .modal-qr {
            max-width: 350px;
        }
        
        .modal-content {
            border-radius: 0;
            border: none;
        }
        
        .modal-header {
            background: var(--ink);
            color: var(--white);
            border: none;
            border-radius: 0;
        }
        
        .modal-header .btn-close-white {
            filter: brightness(0) invert(1);
        }
        
        /* Responsive */
        @media (max-width: 768px) {
            .reservations-container { padding: 6rem 1rem 3rem; }
            .filter-grid { grid-template-columns: 1fr; }
            .stats-row { grid-template-columns: repeat(2, 1fr); }
            .reservations-grid { grid-template-columns: 1fr; }
        }
    </style>
{% endblock %}

{% block body %}
<div class="reservations-container">
    <!-- Header -->
    <div class="page-header">
        <h1>Mes <span>réservations</span></h1>
        <p>Retrouvez toutes vos réservations de vols</p>
    </div>
    
    <!-- Messages flash -->
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" style="background: #28a745; color: white; border: none; border-radius: 0; padding: 1rem; margin-bottom: 1.5rem;">
            <i class="fas fa-check-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close btn-close-white float-end" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
    
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" style="background: #dc3545; color: white; border: none; border-radius: 0; padding: 1rem; margin-bottom: 1.5rem;">
            <i class="fas fa-exclamation-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close btn-close-white float-end" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
    
    <!-- Barre de recherche -->
    <div class="filter-bar">
        <div class="filter-grid">
            <div class="filter-group">
                <label><i class="fas fa-search"></i> Rechercher</label>
                <input type="text" id="searchInput" placeholder="Destination, vol ou compagnie...">
            </div>
            <div class="filter-group">
                <label><i class="fas fa-filter"></i> Statut</label>
                <select id="statusFilter">
                    <option value="all">📊 Tous les statuts</option>
                    <option value="confirmed">✅ Confirmées</option>
                    <option value="cancelled">❌ Annulées</option>
                    <option value="pending">⏳ En attente</option>
                    <option value="completed">🏁 Terminées</option>
                </select>
            </div>
            <div class="filter-group">
                <label><i class="fas fa-sort"></i> Trier par</label>
                <select id="sortFilter">
                    <option value="date_desc">🕐 Plus récentes</option>
                    <option value="date_asc">🕐 Plus anciennes</option>
                    <option value="price_desc">💰 Prix décroissant</option>
                    <option value="price_asc">💰 Prix croissant</option>
                </select>
            </div>
        </div>
        <div class="text-end mt-3">
            <button onclick="resetFilters()" class="btn-reset">
                <i class="fas fa-undo-alt me-1"></i> Réinitialiser
            </button>
        </div>
    </div>
    
    <!-- Statistiques -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-number">{{ reservations|length }}</div>
            <div class="stat-label">Total réservations</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">{{ reservations|filter(r => r.status == 'confirmed')|length }}</div>
            <div class="stat-label">Confirmées</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">{{ reservations|filter(r => r.status == 'pending')|length }}</div>
            <div class="stat-label">En attente</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">{{ reservations|filter(r => r.status == 'cancelled')|length }}</div>
            <div class="stat-label">Annulées</div>
        </div>
    </div>
    
    <!-- Liste des réservations -->
    {% if reservations|length > 0 %}
        <div class="reservations-grid" id="reservationsContainer">
            {% for reservation in reservations %}
            <div class="reservation-card reservation-item" 
                 data-id="{{ reservation.id }}"
                 data-status="{{ reservation.status }}"
                 data-destination="{{ reservation.destination|lower }}"
                 data-flight="{{ reservation.flightNumber|lower }}"
                 data-airline="{{ reservation.airline|lower }}"
                 data-date="{{ reservation.reservationDate.timestamp }}"
                 data-price="{{ reservation.totalPrice }}">
                
                <div class="card-header">
                    <div class="flight-info">
                        <div class="flight-icon">
                            <i class="fas fa-plane"></i>
                        </div>
                        <div class="flight-details">
                            <h4 class="mb-0">{{ reservation.airline }}</h4>
                            <small>{{ reservation.flightNumber }}</small>
                        </div>
                    </div>
                    <span class="status-badge status-{{ reservation.status }}">
                        {% if reservation.status == 'confirmed' %}
                            <i class="fas fa-check-circle me-1"></i> Confirmé
                        {% elseif reservation.status == 'cancelled' %}
                            <i class="fas fa-times-circle me-1"></i> Annulé
                        {% elseif reservation.status == 'pending' %}
                            <i class="fas fa-clock me-1"></i> En attente
                        {% else %}
                            <i class="fas fa-flag-checkered me-1"></i> Terminé
                        {% endif %}
                    </span>
                </div>
                
                <div class="card-body">
                    <div class="destination">
                        <i class="fas fa-map-marker-alt"></i>
                        {{ reservation.destination }}
                    </div>
                    
                    <div class="flight-times">
                        <div class="time-point">
                            <div class="time-label">Départ</div>
                            <div class="time-value">{{ reservation.departureTime|date('H:i') }}</div>
                            <small class="text-muted">{{ reservation.departureAirport }}</small>
                        </div>
                        <div class="flight-line">
                            <i class="fas fa-long-arrow-alt-right"></i>
                        </div>
                        <div class="time-point">
                            <div class="time-label">Arrivée</div>
                            <div class="time-value">{{ reservation.arrivalTime|date('H:i') }}</div>
                            <small class="text-muted">{{ reservation.arrivalAirport }}</small>
                        </div>
                    </div>
                    
                    <div class="passenger-info">
                        <span><i class="fas fa-user"></i> Passager</span>
                        <span>{{ reservation.nomClient }}</span>
                    </div>
                    
                    <div class="passenger-info">
                        <span><i class="fas fa-users"></i> Nombre</span>
                        <span>{{ reservation.numberOfPassengers }} personne(s)</span>
                    </div>
                    
                    <div class="passenger-info">
                        <span><i class="fas fa-calendar"></i> Réservation</span>
                        <span>{{ reservation.reservationDate|date('d/m/Y') }}</span>
                    </div>
                    
                    <div class="passenger-info">
                        <span><i class="fas fa-tag"></i> Prix total</span>
                        <span class="price">{{ reservation.totalPrice }} €</span>
                    </div>
                    
                    <!-- QR Code preview -->
                    {% if reservation.status == 'confirmed' and reservation.boardingPassFile %}
                    <div class="text-center mt-3">
                        <img src="{{ asset('uploads/boarding_passes/' ~ reservation.boardingPassFile) }}" 
                             class="qr-preview" 
                             alt="QR Code"
                             data-bs-toggle="modal" 
                             data-bs-target="#qrModal{{ reservation.id }}">
                    </div>
                    {% endif %}
                </div>
                
                <div class="card-footer">
                    <a href="{{ path('app_reservation_show', {'id': reservation.id}) }}" class="btn-action">
                        <i class="fas fa-eye"></i> Détails
                    </a>
                    
                    {% if reservation.status == 'confirmed' %}
                        <a href="{{ path('app_reservation_boarding_pass', {'id': reservation.id}) }}" 
                           target="_blank" class="btn-action btn-success">
                            <i class="fas fa-ticket-alt"></i> Billet
                        </a>
                        
                        {% if not reservation.boardingPassSent %}
                        <form method="post" action="{{ path('app_reservation_send_boarding_pass', {'id': reservation.id}) }}" style="display: inline;">
                            <button class="btn-action" onclick="return confirm('Envoyer le billet par email ?')">
                                <i class="fas fa-envelope"></i> Email
                            </button>
                        </form>
                        {% else %}
                        <button class="btn-action btn-disabled" disabled>
                            <i class="fas fa-check"></i> Envoyé
                        </button>
                        {% endif %}
                        
                        {% if reservation.cancellable %}
                        <form method="post" action="{{ path('app_reservation_cancel', {'id': reservation.id}) }}" style="display: inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ reservation.id) }}">
                            <button class="btn-action btn-danger" onclick="return confirm('Annuler cette réservation ?')">
                                <i class="fas fa-times"></i> Annuler
                            </button>
                        </form>
                        {% endif %}
                    {% endif %}
                </div>
            </div>
            
            <!-- Modal QR Code -->
            {% if reservation.status == 'confirmed' and reservation.boardingPassFile %}
            <div class="modal fade" id="qrModal{{ reservation.id }}" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered modal-qr">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">
                                <i class="fas fa-qrcode me-2"></i>QR Code - {{ reservation.flightNumber }}
                            </h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body text-center">
                            <img src="{{ asset('uploads/boarding_passes/' ~ reservation.boardingPassFile) }}" 
                                 alt="QR Code" class="img-fluid" style="max-width: 250px;">
                            <p class="mt-3 mb-0 small text-muted">
                                <i class="fas fa-mobile-alt"></i> Présentez ce code à l'embarquement
                            </p>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn-action" data-bs-dismiss="modal">Fermer</button>
                            <a href="{{ path('app_reservation_boarding_pass', {'id': reservation.id}) }}" 
                               target="_blank" class="btn-action btn-success">
                                <i class="fas fa-print me-1"></i> Imprimer
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            {% endif %}
            {% endfor %}
        </div>
    {% else %}
        <!-- État vide -->
        <div class="empty-state">
            <i class="fas fa-ticket-alt"></i>
            <h3>Aucune réservation</h3>
            <p>Vous n'avez pas encore effectué de réservation.</p>
            <a href="{{ path('app_avis_index') }}" class="btn-primary">
                <i class="fas fa-search me-2"></i> Découvrir des voyages
            </a>
        </div>
    {% endif %}
</div>

<script>
    // Filtres et tri
    function filterAndSort() {
        const searchTerm = document.getElementById('searchInput').value.toLowerCase();
        const statusFilter = document.getElementById('statusFilter').value;
        const sortFilter = document.getElementById('sortFilter').value;
        
        const items = Array.from(document.querySelectorAll('.reservation-item'));
        
        // Filtrer
        const filtered = items.filter(item => {
            const destination = item.dataset.destination;
            const flight = item.dataset.flight;
            const airline = item.dataset.airline;
            const status = item.dataset.status;
            
            const matchesSearch = searchTerm === '' || 
                destination.includes(searchTerm) || 
                flight.includes(searchTerm) ||
                airline.includes(searchTerm);
            const matchesStatus = statusFilter === 'all' || status === statusFilter;
            
            return matchesSearch && matchesStatus;
        });
        
        // Trier
        filtered.sort((a, b) => {
            switch(sortFilter) {
                case 'date_desc':
                    return b.dataset.date - a.dataset.date;
                case 'date_asc':
                    return a.dataset.date - b.dataset.date;
                case 'price_desc':
                    return parseFloat(b.dataset.price) - parseFloat(a.dataset.price);
                case 'price_asc':
                    return parseFloat(a.dataset.price) - parseFloat(b.dataset.price);
                default:
                    return 0;
            }
        });
        
        // Réafficher
        const container = document.getElementById('reservationsContainer');
        container.innerHTML = '';
        filtered.forEach(item => container.appendChild(item));
        
        // Afficher message si aucun résultat
        if (filtered.length === 0) {
            container.innerHTML = `
                <div class="empty-state" style="grid-column: 1/-1;">
                    <i class="fas fa-search"></i>
                    <h3>Aucun résultat</h3>
                    <p>Aucune réservation ne correspond à vos critères.</p>
                </div>
            `;
        }
    }
    
    function resetFilters() {
        document.getElementById('searchInput').value = '';
        document.getElementById('statusFilter').value = 'all';
        document.getElementById('sortFilter').value = 'date_desc';
        filterAndSort();
    }
    
    // Écouteurs d'événements
    document.getElementById('searchInput').addEventListener('input', filterAndSort);
    document.getElementById('statusFilter').addEventListener('change', filterAndSort);
    document.getElementById('sortFilter').addEventListener('change', filterAndSort);
    
    // Animation au chargement
    document.addEventListener('DOMContentLoaded', function() {
        const cards = document.querySelectorAll('.reservation-card');
        cards.forEach((card, index) => {
            card.style.opacity = '0';
            card.style.transform = 'translateY(20px)';
            setTimeout(() => {
                card.style.transition = 'all 0.3s ease';
                card.style.opacity = '1';
                card.style.transform = 'translateY(0)';
            }, index * 50);
        });
    });
</script>
{% endblock %}