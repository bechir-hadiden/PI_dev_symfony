{% extends 'base.html.twig' %}

{% block title %}Détail de la réservation - SmartTrip{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="fas fa-ticket-alt me-2"></i>Détail de la réservation #{{ reservation.id }}</h4>
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <div class="col-md-6">
                            <h5>Informations du vol</h5>
                            <table class="table table-sm">
                                <tr>
                                    <th>Compagnie:</th>
                                    <td>{{ reservation.airline }}</td>
                                </tr>
                                <tr>
                                    <th>Numéro de vol:</th>
                                    <td>{{ reservation.flightNumber }}</td>
                                </tr>
                                <tr>
                                    <th>Destination:</th>
                                    <td>{{ reservation.destination }}</td>
                                </tr>
                                <tr>
                                    <th>Départ:</th>
                                    <td>{{ reservation.departureAirport }} - {{ reservation.departureTime|date('d/m/Y H:i') }}</td>
                                </tr>
                                <tr>
                                    <th>Arrivée:</th>
                                    <td>{{ reservation.arrivalAirport }} - {{ reservation.arrivalTime|date('d/m/Y H:i') }}</td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <h5>Informations passager</h5>
                            <table class="table table-sm">
                                <tr>
                                    <th>Nom:</th>
                                    <td>{{ reservation.nomClient }}</td>
                                </tr>
                                <tr>
                                    <th>Email:</th>
                                    <td>{{ reservation.email }}</td>
                                </tr>
                                <tr>
                                    <th>Téléphone:</th>
                                    <td>{{ reservation.telephone ?? '-' }}</td>
                                </tr>
                                <tr>
                                    <th>Nombre de passagers:</th>
                                    <td>{{ reservation.numberOfPassengers }}</td>
                                </tr>
                                <tr>
                                    <th>Prix total:</th>
                                    <td><strong class="text-primary">{{ reservation.totalPrice }} €</strong></td>
                                </tr>
                                <tr>
                                    <th>Date de réservation:</th>
                                    <td>{{ reservation.reservationDate|date('d/m/Y H:i') }}</td>
                                </tr>
                                <tr>
                                    <th>Statut:</th>
                                    <td>
                                        <span class="badge {% if reservation.status == 'confirmed' %}bg-success{% else %}bg-danger{% endif %}">
                                            {{ reservation.status == 'confirmed' ? 'Confirmé' : 'Annulé' }}
                                        </span>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                    
                    <div class="mt-4 d-flex gap-2">
                        <a href="{{ path('app_reservation_list') }}" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i> Retour
                        </a>
                        {% if reservation.status == 'confirmed' and reservation.cancellable %}
                        <form method="post" action="{{ path('app_reservation_cancel', {'id': reservation.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ reservation.id) }}">
                            <button class="btn btn-danger" onclick="return confirm('Annuler cette réservation ?')">
                                <i class="fas fa-times me-1"></i> Annuler la réservation
                            </button>
                        </form>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}