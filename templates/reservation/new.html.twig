{# templates/reservation/new.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}VoyageÉlite - Réserver un vol{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --ink: #0d0d0d;
            --sand: #f0e8d8;
            --cream: #faf6ef;
            --gold: #b8963e;
            --gold-lt: #d4b06a;
            --muted: #6b6560;
            --white: #ffffff;
        }
        
        body {
            background: var(--cream);
            font-family: 'DM Sans', sans-serif;
        }
        
        .booking-container {
            max-width: 900px;
            margin: 0 auto;
            padding: 6rem 2rem 4rem;
        }
        
        .booking-card {
            background: var(--white);
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            overflow: hidden;
        }
        
        .booking-header {
            background: var(--ink);
            color: var(--white);
            padding: 2rem;
            text-align: center;
        }
        
        .booking-header h1 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2rem;
            font-weight: 300;
            letter-spacing: 0.02em;
            margin-bottom: 0.5rem;
        }
        
        .booking-header p {
            color: var(--gold-lt);
            font-size: 0.8rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }
        
        .flight-details {
            background: rgba(184,150,62,0.08);
            padding: 1.5rem;
            border-bottom: 0.5px solid rgba(184,150,62,0.2);
        }
        
        .flight-details-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
        }
        
        .flight-detail-item {
            text-align: center;
        }
        
        .flight-detail-label {
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--muted);
            margin-bottom: 0.3rem;
        }
        
        .flight-detail-value {
            font-weight: 600;
            color: var(--ink);
        }
        
        .flight-price {
            font-size: 1.2rem;
            color: var(--gold);
            font-weight: 600;
        }
        
        .booking-form {
            padding: 2rem;
        }
        
        .form-group {
            margin-bottom: 1.5rem;
        }
        
        .form-group label {
            display: block;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--muted);
            margin-bottom: 0.5rem;
        }
        
        .form-group input, .form-group select {
            width: 100%;
            padding: 0.8rem 1rem;
            border: 0.5px solid rgba(184,150,62,0.3);
            background: var(--white);
            font-family: 'DM Sans', sans-serif;
            font-size: 0.9rem;
            outline: none;
            transition: border 0.2s;
        }
        
        .form-group input:focus, .form-group select:focus {
            border-color: var(--gold);
        }
        
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }
        
        .btn-submit {
            background: var(--gold);
            color: var(--ink);
            border: none;
            padding: 1rem 2rem;
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            cursor: pointer;
            width: 100%;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }
        
        .btn-submit:hover {
            background: var(--ink);
            color: var(--white);
            transform: translateY(-2px);
        }
        
        .btn-back {
            background: none;
            border: 0.5px solid rgba(184,150,62,0.3);
            color: var(--ink);
            padding: 0.8rem 1.5rem;
            font-size: 0.8rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.2s;
        }
        
        .btn-back:hover {
            background: var(--ink);
            color: var(--white);
            border-color: var(--ink);
        }
        
        .error-message {
            color: #dc3545;
            font-size: 0.75rem;
            margin-top: 0.3rem;
        }
        
        @media (max-width: 768px) {
            .booking-container { padding: 5rem 1rem 2rem; }
            .form-row { grid-template-columns: 1fr; }
            .flight-details-grid { grid-template-columns: 1fr; gap: 0.8rem; }
        }
    </style>
{% endblock %}

{% block body %}
<div class="booking-container">
    <div class="booking-card">
        <div class="booking-header">
            <h1>Réserver votre vol</h1>
            <p><i class="fas fa-plane"></i> VoyageÉlite</p>
        </div>
        
        {% if flight %}
        <div class="flight-details">
            <div class="flight-details-grid">
                <div class="flight-detail-item">
                    <div class="flight-detail-label">Compagnie</div>
                    <div class="flight-detail-value">{{ flight.airline }}</div>
                </div>
                <div class="flight-detail-item">
                    <div class="flight-detail-label">Vol</div>
                    <div class="flight-detail-value">{{ flight.flightNumber }}</div>
                </div>
                <div class="flight-detail-item">
                    <div class="flight-detail-label">Destination</div>
                    <div class="flight-detail-value">{{ flight.destination }}</div>
                </div>
                <div class="flight-detail-item">
                    <div class="flight-detail-label">Départ</div>
                    <div class="flight-detail-value">{{ flight.departureAirport }}<br><small>{{ flight.departureTime|date('H:i') }}</small></div>
                </div>
                <div class="flight-detail-item">
                    <div class="flight-detail-label">Arrivée</div>
                    <div class="flight-detail-value">{{ flight.arrivalAirport }}<br><small>{{ flight.arrivalTime|date('H:i') }}</small></div>
                </div>
                <div class="flight-detail-item">
                    <div class="flight-detail-label">Prix</div>
                    <div class="flight-detail-value flight-price">{{ flight.price }} €</div>
                </div>
            </div>
        </div>
        {% endif %}
        
        <div class="booking-form">
            {{ form_start(form, {'attr': {'class': 'needs-validation'}}) }}
            
            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.nomClient) }}
                    {{ form_widget(form.nomClient, {'attr': {'placeholder': 'Jean Dupont'}}) }}
                    {{ form_errors(form.nomClient) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.email) }}
                    {{ form_widget(form.email, {'attr': {'placeholder': 'jean@example.com'}}) }}
                    {{ form_errors(form.email) }}
                </div>
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.telephone) }}
                    {{ form_widget(form.telephone, {'attr': {'placeholder': '+33 6 12 34 56 78'}}) }}
                    {{ form_errors(form.telephone) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.numberOfPassengers) }}
                    {{ form_widget(form.numberOfPassengers, {'attr': {'min': 1, 'max': 9}}) }}
                    {{ form_errors(form.numberOfPassengers) }}
                </div>
            </div>
            
            <button type="submit" class="btn-submit">
                <i class="fas fa-check-circle"></i> Confirmer la réservation
            </button>
            
            {{ form_end(form) }}
            
            <div class="text-center mt-4">
                <a href="{{ path('app_destination_show', {'destination': flight.destination}) }}" class="btn-back">
                    <i class="fas fa-arrow-left"></i> Retour à la destination
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}