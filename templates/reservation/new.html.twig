{# templates/reservation/new.html.twig #}
{% extends 'base_dark.html.twig' %}

{% block title %}VoyageÉlite - Réserver un vol{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --ink: #0d1b2a;
            --sand: #f0e8d8;
            --cream: #faf6ef;
            --gold: #c9a84c;
            --gold-lt: #d4b06a;
            --muted: #6b6560;
            --white: #ffffff;
            --navy: #0d1b2a;
        }
        
        body {
            background: var(--navy); /* Harmonisation avec votre thème sombre */
            font-family: 'DM Sans', sans-serif;
            color: var(--white);
        }
        
        .booking-container {
            max-width: 900px;
            margin: 0 auto;
            padding: 8rem 2rem 4rem;
        }
        
        .booking-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(201, 168, 76, 0.2);
            box-shadow: 0 10px 40px rgba(0,0,0,0.3);
            border-radius: 16px;
            overflow: hidden;
        }
        
        .booking-header {
            background: linear-gradient(to bottom, rgba(201, 168, 76, 0.1), transparent);
            padding: 2.5rem;
            text-align: center;
            border-bottom: 1px solid rgba(201, 168, 76, 0.1);
        }
        
        .booking-header h1 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2.5rem;
            font-weight: 300;
            color: var(--gold);
            margin-bottom: 0.5rem;
        }
        
        .booking-header p {
            color: var(--gold-lt);
            font-size: 0.8rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
        }
        
        .flight-details {
            background: rgba(255, 255, 255, 0.05);
            padding: 2rem;
            border-bottom: 1px solid rgba(201, 168, 76, 0.1);
        }
        
        .flight-details-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 1.5rem;
        }
        
        .flight-detail-item {
            text-align: center;
        }
        
        .flight-detail-label {
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--gold-lt);
            opacity: 0.7;
            margin-bottom: 0.4rem;
        }
        
        .flight-detail-value {
            font-weight: 500;
            color: var(--white);
            font-size: 0.95rem;
        }
        
        .flight-price {
            font-size: 1.4rem;
            color: var(--gold);
            font-weight: 700;
        }
        
        .booking-form {
            padding: 3rem;
        }
        
        /* Stylisation des champs Symfony */
        .form-group {
            margin-bottom: 1.8rem;
        }
        
        .form-group label {
            display: block;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--gold-lt);
            margin-bottom: 0.6rem;
        }
        
        .form-group input, .form-group select {
            width: 100%;
            padding: 1rem;
            border: 1px solid rgba(201, 168, 76, 0.3);
            background: rgba(13, 27, 42, 0.5);
            color: white;
            border-radius: 8px;
            font-family: 'DM Sans', sans-serif;
            transition: all 0.3s;
        }
        
        .form-group input:focus {
            border-color: var(--gold);
            box-shadow: 0 0 10px rgba(201, 168, 76, 0.2);
            outline: none;
        }

        /* Désactivation visuelle du champ destination auto-rempli */
        .form-group input:disabled, .form-group select:disabled {
            background: rgba(255,255,255,0.05);
            color: rgba(255,255,255,0.5);
            cursor: not-allowed;
        }
        
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
        }
        
        .btn-submit {
            background: linear-gradient(135deg, var(--gold), var(--gold-lt));
            color: var(--navy);
            border: none;
            padding: 1.2rem;
            border-radius: 8px;
            font-size: 0.9rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            cursor: pointer;
            width: 100%;
            transition: all 0.3s;
            margin-top: 1rem;
        }
        
        .btn-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 20px rgba(201, 168, 76, 0.4);
        }
        
        .btn-back {
            display: inline-block;
            margin-top: 2rem;
            color: var(--gold-lt);
            text-decoration: none;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            transition: color 0.3s;
        }
        
        .btn-back:hover {
            color: var(--white);
        }
        
        .error-message ul {
            list-style: none;
            padding: 0;
            color: #ff6b6b;
            font-size: 0.8rem;
            margin-top: 0.5rem;
        }
        
        @media (max-width: 768px) {
            .form-row { grid-template-columns: 1fr; }
            .booking-form { padding: 1.5rem; }
        }
    </style>
{% endblock %}

{% block body %}
<div class="booking-container">
    <div class="booking-card">
        <div class="booking-header">
            <h1>Finaliser votre réservation</h1>
            <p><i class="fas fa-crown"></i> Expérience VoyageÉlite</p>
        </div>
        
        {% if flight %}
        <div class="flight-details">
            <div class="flight-details-grid">
                <div class="flight-detail-item">
                    <div class="flight-detail-label">Destination</div>
                    <div class="flight-detail-value">{{ flight.destination }}</div>
                </div>
                <div class="flight-detail-item">
                    <div class="flight-detail-label">Compagnie</div>
                    <div class="flight-detail-value">{{ flight.airline }}</div>
                </div>
                <div class="flight-detail-item">
                    <div class="flight-detail-label">Vol N°</div>
                    <div class="flight-detail-value">{{ flight.flightNumber }}</div>
                </div>
                <div class="flight-detail-item">
                    <div class="flight-detail-label">Départ</div>
                    <div class="flight-detail-value">{{ flight.departureTime|date('d/m H:i') }}</div>
                </div>
                <div class="flight-detail-item">
                    <div class="flight-detail-label">Prix Total</div>
                    <div class="flight-detail-value flight-price">{{ flight.price }} TND</div>
                </div>
            </div>
        </div>
        {% endif %}
        
        <div class="booking-form">
            {{ form_start(form) }}
            
            {# Champ Destination (pré-rempli et désactivé) #}
            <div class="form-group">
                {{ form_label(form.destination) }}
                {{ form_widget(form.destination) }}
                <div class="error-message">{{ form_errors(form.destination) }}</div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.nomClient) }}
                    {{ form_widget(form.nomClient) }}
                    <div class="error-message">{{ form_errors(form.nomClient) }}</div>
                </div>
                <div class="form-group">
                    {{ form_label(form.email) }}
                    {{ form_widget(form.email) }}
                    <div class="error-message">{{ form_errors(form.email) }}</div>
                </div>
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.telephone) }}
                    {{ form_widget(form.telephone) }}
                    <div class="error-message">{{ form_errors(form.telephone) }}</div>
                </div>
                <div class="form-group">
                    {{ form_label(form.numberOfPassengers) }}
                    {{ form_widget(form.numberOfPassengers) }}
                    <div class="error-message">{{ form_errors(form.numberOfPassengers) }}</div>
                </div>
            </div>
            
            <button type="submit" class="btn-submit">
                <i class="fas fa-paper-plane"></i> Confirmer la réservation
            </button>
            
            {{ form_end(form) }}
            
            <div style="text-align: center;">
                <a href="javascript:history.back()" class="btn-back">
                    <i class="fas fa-chevron-left"></i> Modifier mon choix
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}