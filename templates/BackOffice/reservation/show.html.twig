{% extends 'BackOffice/base_admin.html.twig' %}
{% block title %}Détail Historique #{{ reservation.id }} – Admin{% endblock %}
{% block page_title %}Détail de l'historique #{{ reservation.id }}{% endblock %}

{% block body %}
<div style="max-width:600px">
  <div class="card" style="margin-bottom:1.2rem">
    <div class="card-header">
      <h2><i class="fas fa-user" style="color:var(--gold);margin-right:.5rem"></i>Informations client</h2>
      {% if reservation.statut == 'confirmee' %}
        <span class="badge badge-confirm">Confirmée</span>
      {% elseif reservation.statut == 'annulee' %}
        <span class="badge badge-cancel">Annulée</span>
      {% else %}
        <span class="badge badge-pending">En attente</span>
      {% endif %}
    </div>
    <div class="card-body">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
        <div><div style="font-size:.72rem;text-transform:uppercase;color:var(--muted);margin-bottom:.25rem">Nom</div><strong>{{ reservation.nomClient }}</strong></div>
        <div><div style="font-size:.72rem;text-transform:uppercase;color:var(--muted);margin-bottom:.25rem">Email</div>{{ reservation.emailClient }}</div>
        <div><div style="font-size:.72rem;text-transform:uppercase;color:var(--muted);margin-bottom:.25rem">Places réservées</div>{{ reservation.nombrePlaces }}</div>
        <div><div style="font-size:.72rem;text-transform:uppercase;color:var(--muted);margin-bottom:.25rem">Montant total</div><strong style="color:var(--gold)">{{ reservation.montantTotal|number_format(2, ',', ' ') }} DT</strong></div>
        <div><div style="font-size:.72rem;text-transform:uppercase;color:var(--muted);margin-bottom:.25rem">Date réservation</div>{{ reservation.dateReservation|date('d/m/Y à H:i') }}</div>
        <div><div style="font-size:.72rem;text-transform:uppercase;color:var(--muted);margin-bottom:.25rem">Véhicule</div>{{ reservation.transport.compagnie }} – {{ reservation.transport.numero }}</div>
      </div>
    </div>
  </div>

  <!-- Change statut -->
  <div class="card" style="margin-bottom:1.2rem">
    <div class="card-header"><h2><i class="fas fa-exchange-alt" style="color:var(--gold);margin-right:.5rem"></i>Changer le statut</h2></div>
    <div class="card-body">
      <form method="POST" action="{{ path('admin_reservation_update_statut', {id: reservation.id}) }}" style="display:flex;gap:.75rem;flex-wrap:wrap">
        <select name="statut" style="flex:1;padding:.55rem .9rem;border:1px solid var(--border);border-radius:8px;font-size:.875rem;outline:none">
          <option value="en_attente" {{ reservation.statut == 'en_attente' ? 'selected' : '' }}>En attente</option>
          <option value="confirmee"  {{ reservation.statut == 'confirmee'  ? 'selected' : '' }}>Confirmée</option>
          <option value="annulee"    {{ reservation.statut == 'annulee'    ? 'selected' : '' }}>Annulée</option>
        </select>
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Mettre à jour</button>
      </form>
    </div>
  </div>

  <div style="display:flex;gap:.75rem">
    <a href="{{ path('admin_reservation_index') }}" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Retour</a>
    <form method="POST" action="{{ path('admin_reservation_delete', {id: reservation.id}) }}" onsubmit="return confirm('Supprimer cette réservation ?')">
      <input type="hidden" name="_token" value="{{ csrf_token('delete_reservation_' ~ reservation.id) }}">
      <button type="submit" class="btn btn-danger"><i class="fas fa-trash"></i> Supprimer</button>
    </form>
  </div>
</div>
{% endblock %}
