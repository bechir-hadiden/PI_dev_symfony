{% extends 'base_dark.html.twig' %}
{% block title %}Voyages – SmartTrip{% endblock %}

{% block body %}

<div style="background:var(--navy);padding:7rem 5% 3rem;border-bottom:1px solid rgba(201,168,76,0.15);">
  <div style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:1rem;">
    <div>
      <span class="section-label">Nos Formules</span>
      <h1 class="section-title light">Tous les Voyages</h1>
      <p style="color:rgba(255,255,255,0.55);font-size:.95rem;line-height:1.75;margin-bottom:2rem;">
        Découvrez nos voyages et packages soigneusement sélectionnés.
      </p>
      <a href="{{ path('admin_voyage_new') }}" class="btn-gold">
        <i class="fas fa-plus"></i> Nouveau voyage
      </a>
    </div>
  </div>
</div>

{# ── FILTRES ── #}
<div style="background:var(--cream);padding:1.8rem 5%;border-bottom:1px solid rgba(13,27,42,0.08);display:flex;gap:1rem;flex-wrap:wrap;align-items:center;">

  <form method="GET" style="display:flex;gap:.75rem;flex:1;min-width:240px;">
    <div style="flex:1;position:relative;">
      <i class="fas fa-search" style="position:absolute;left:1rem;top:50%;transform:translateY(-50%);color:var(--muted);font-size:.875rem;"></i>
      <input type="text" name="q" value="{{ query ?? '' }}"
             placeholder="Rechercher un voyage, destination..."
             style="width:100%;padding:.7rem 1rem .7rem 2.75rem;border:1px solid rgba(13,27,42,0.15);border-radius:50px;font-family:inherit;font-size:.875rem;outline:none;background:var(--white);">
    </div>
    <button type="submit" class="btn-primary" style="padding:.7rem 1.4rem;font-size:.875rem;">
      Chercher
    </button>
    {% if query %}
      <a href="{{ path('admin_voyage_index') }}" class="btn-navy" style="padding:.7rem 1rem;">
        <i class="fas fa-times"></i>
      </a>
    {% endif %}
  </form>

  <form method="GET">
    <select name="destination" onchange="this.form.submit()"
            style="padding:.7rem 1.2rem;border:1px solid rgba(13,27,42,0.15);border-radius:50px;background:var(--white);">
      <option value="">Toutes les destinations</option>
      {% for dest in destinations %}
        <option value="{{ dest.id }}"
          {{ filtreDestId is defined and filtreDestId == dest.id ? 'selected' }}>
          {{ dest.nom }} — {{ dest.pays }}
        </option>
      {% endfor %}
    </select>
  </form>

</div>

{# ── LISTE ── #}
<div style="padding:3rem 5%;background:var(--cream);min-height:60vh;">

  {% if voyages is empty %}

    <div style="text-align:center;padding:5rem 2rem;">
      <div style="font-size:4rem;margin-bottom:1rem;">✈️</div>
      <h3 style="font-family:'Playfair Display',serif;font-size:1.5rem;color:var(--navy);">
        Aucun voyage disponible
      </h3>
    </div>

  {% else %}

    {# ── BARRE INFOS ── #}
    <p style="color:var(--muted);font-size:.82rem;margin-bottom:.8rem;">
      <i class="fas fa-plane" style="color:var(--gold);"></i>
      {{ voyages.getTotalItemCount }} voyage(s) trouvé(s)
    </p>

    {# ── PAGINATION HAUT ── #}
    <div style="margin-bottom:1.8rem;">
      {{ knp_pagination_render(voyages, null, {
        'query': {
          'q': query ?? '',
          'destination': filtreDestId ?? ''
        }
      }) }}
    </div>

    {# ── GRILLE VOYAGES ── #}
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1.4rem;">

      {% for voyage in voyages %}

        {% set matchedDest = null %}
        {% if not voyage.destinationRel %}
          {% for d in destinations %}
             {% if d.nom|lower|trim == voyage.destination|lower|trim %}
                {% set matchedDest = d %}
             {% endif %}
          {% endfor %}
        {% endif %}

        {% set cardImg =
          voyage.firstImagePath ??
          (voyage.destinationRel and voyage.destinationRel.firstImage
            ? voyage.destinationRel.firstImage
            : (matchedDest and matchedDest.firstImage ? matchedDest.firstImage : null))
        %}

        <div style="background:var(--white);border-radius:14px;overflow:hidden;
                    box-shadow:0 2px 12px rgba(13,27,42,0.08);
                    display:flex;flex-direction:column;">

          {# ── Image ── #}
          <div style="height:200px;position:relative;background:var(--navy);flex-shrink:0;">
            {% if cardImg %}
              <img src="{{ cardImg }}" style="width:100%;height:100%;object-fit:cover;">
            {% else %}
              <div style="display:flex;justify-content:center;align-items:center;height:100%;font-size:3rem;">✈️</div>
            {% endif %}
            <div style="position:absolute;bottom:10px;left:10px;background:var(--gold);
                        color:var(--navy);font-weight:700;padding:.3rem .7rem;
                        border-radius:20px;font-size:.82rem;">
              {{ voyage.prix|number_format(0,',',' ') }} TND
            </div>
            <div style="position:absolute;top:10px;right:10px;background:var(--gold);
                        color:var(--navy);font-weight:700;padding:.2rem .6rem;
                        border-radius:20px;font-size:.75rem;">
              {{ voyage.dureeJours }} JOURS
            </div>
          </div>

          {# ── Contenu ── #}
          <div style="padding:1.1rem;flex:1;display:flex;flex-direction:column;gap:.5rem;">
            <h3 style="font-family:'Playfair Display',serif;font-size:1.05rem;color:var(--navy);margin:0;">
              {{ voyage.destination }}
            </h3>
            <p style="font-size:.8rem;color:var(--muted);margin:0;">
              <i class="fas fa-calendar-alt" style="color:var(--gold);"></i>
              {{ voyage.dateDebut|date('d/m/Y') }} → {{ voyage.dateFin|date('d/m/Y') }}
            </p>
            {% if voyage.paysDepart %}
              <p style="font-size:.8rem;color:var(--muted);margin:0;">
                <i class="fas fa-plane-departure" style="color:var(--gold);"></i>
                Départ : {{ voyage.paysDepart }}
              </p>
            {% endif %}
            {% if voyage.description %}
              <p style="font-size:.8rem;color:var(--navy);margin:0;line-height:1.5;">
                {{ voyage.description|slice(0,80) }}...
              </p>
            {% endif %}
          </div>

          {# ── Boutons ── #}
          <div style="padding:.9rem 1.1rem;border-top:1px solid rgba(13,27,42,0.08);
                      display:flex;gap:.5rem;align-items:center;flex-wrap:wrap;">

            {# Voir #}
            <a href="{{ path('admin_voyage_show', {id: voyage.id}) }}"
               style="flex:1;display:inline-flex;align-items:center;justify-content:center;
                      gap:.35rem;padding:.5rem .9rem;background:var(--navy);color:var(--gold);
                      border:1px solid rgba(201,168,76,0.3);border-radius:8px;
                      font-size:.78rem;font-weight:600;text-decoration:none;transition:all .2s;"
               onmouseover="this.style.background='var(--gold)';this.style.color='var(--navy)'"
               onmouseout="this.style.background='var(--navy)';this.style.color='var(--gold)'">
              <i class="fas fa-eye"></i> Voir
            </a>

            {# Modifier #}
            <a href="{{ path('admin_voyage_edit', {id: voyage.id}) }}"
               style="flex:1;display:inline-flex;align-items:center;justify-content:center;
                      gap:.35rem;padding:.5rem .9rem;background:rgba(201,168,76,0.1);
                      color:var(--gold);border:1px solid rgba(201,168,76,0.3);border-radius:8px;
                      font-size:.78rem;font-weight:600;text-decoration:none;transition:all .2s;"
               onmouseover="this.style.background='var(--gold)';this.style.color='var(--navy)'"
               onmouseout="this.style.background='rgba(201,168,76,0.1)';this.style.color='var(--gold)'">
              <i class="fas fa-edit"></i> Modifier
            </a>

            {# Supprimer — ✅ CSRF corrigé : 'delete_voyage_' ~ voyage.id #}
            <form method="POST"
                  action="{{ path('admin_voyage_delete', {id: voyage.id}) }}"
                  onsubmit="return confirm('Supprimer ce voyage ?')"
                  style="flex:1;">
              <input type="hidden" name="_token"
                     value="{{ csrf_token('delete_voyage_' ~ voyage.id) }}">
              <button type="submit"
                style="width:100%;display:inline-flex;align-items:center;justify-content:center;
                       gap:.35rem;padding:.5rem .9rem;background:rgba(220,38,38,0.08);
                       color:#dc2626;border:1px solid rgba(220,38,38,0.2);border-radius:8px;
                       font-size:.78rem;font-weight:600;cursor:pointer;transition:all .2s;
                       font-family:inherit;"
                onmouseover="this.style.background='#dc2626';this.style.color='#fff'"
                onmouseout="this.style.background='rgba(220,38,38,0.08)';this.style.color='#dc2626'">
                <i class="fas fa-trash"></i> Supprimer
              </button>
            </form>

          </div>
        </div>

      {% endfor %}
    </div>

    {# ── PAGINATION BAS ── #}
    <div style="margin-top:2.5rem;display:flex;justify-content:center;">
      {{ knp_pagination_render(voyages, null, {
        'query': {
          'q': query ?? '',
          'destination': filtreDestId ?? ''
        }
      }) }}
    </div>

  {% endif %}

</div>

{% endblock %}
