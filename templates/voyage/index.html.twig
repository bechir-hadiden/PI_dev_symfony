{% extends 'base_dark.html.twig' %}
{% block title %}Voyages – SmartTrip{% endblock %}

{% block body %}

<div style="background:var(--navy);padding:7rem 5% 3rem;border-bottom:1px solid rgba(201,168,76,0.15);">
  <div style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:1rem;">
    <div>
      <span class="section-label">Nos Formules</span>
      <h1 class="section-title light">Tous les Voyages</h1>
      <p style="color:rgba(255,255,255,0.55);font-size:.95rem;line-height:1.75;margin-bottom:2rem;">
        Découvrez nos voyages et packages soigneusement sélectionnés.
      </p>
      <a href="{{ path('admin_voyage_new') }}" class="btn-gold">
        <i class="fas fa-plus"></i> Nouveau voyage
      </a>
    </div>
  </div>
</div>

{# ── FILTRES ── #}
<div style="background:var(--cream);padding:1.8rem 5%;border-bottom:1px solid rgba(13,27,42,0.08);display:flex;gap:1rem;flex-wrap:wrap;align-items:center;">
  <form method="GET" style="display:flex;gap:.75rem;flex:1;min-width:240px;">
    <div style="flex:1;position:relative;">
      <i class="fas fa-search" style="position:absolute;left:1rem;top:50%;transform:translateY(-50%);color:var(--muted);font-size:.875rem;"></i>
      <input type="text" name="q" value="{{ query ?? '' }}"
             placeholder="Rechercher un voyage, destination..."
             style="width:100%;padding:.7rem 1rem .7rem 2.75rem;border:1px solid rgba(13,27,42,0.15);border-radius:50px;font-family:inherit;font-size:.875rem;outline:none;background:var(--white);transition:border-color .3s;"
             onfocus="this.style.borderColor='var(--gold)'"
             onblur="this.style.borderColor='rgba(13,27,42,0.15)'">
    </div>
    <button type="submit" class="btn-primary" style="padding:.7rem 1.4rem;font-size:.875rem;">Chercher</button>
    {% if query %}
      <a href="{{ path('admin_voyage_index') }}" class="btn-navy" style="padding:.7rem 1rem;"><i class="fas fa-times"></i></a>
    {% endif %}
  </form>

  <form method="GET">
    <select name="destination" onchange="this.form.submit()"
            style="padding:.7rem 1.2rem;border:1px solid rgba(13,27,42,0.15);border-radius:50px;font-family:inherit;font-size:.875rem;outline:none;cursor:pointer;background:var(--white);color:var(--navy);">
      <option value="">Toutes les destinations</option>
      {% for dest in destinations %}
        <option value="{{ dest.id }}" {{ filtreDestId is defined and filtreDestId == dest.id ? 'selected' }}>
          {{ dest.nom }} — {{ dest.pays }}
        </option>
      {% endfor %}
    </select>
  </form>
</div>

{# ── LISTE ── #}
<div style="padding:3rem 5%;background:var(--cream);min-height:60vh;">

  {% if voyages is empty %}
    <div style="text-align:center;padding:5rem 2rem;">
      <div style="font-size:4rem;margin-bottom:1rem;">✈️</div>
      <h3 style="font-family:'Playfair Display',serif;font-size:1.5rem;color:var(--navy);margin-bottom:.75rem;">
        {% if query is defined and query %}Aucun résultat pour « {{ query }} »{% else %}Aucun voyage disponible{% endif %}
      </h3>
      <p style="color:var(--muted);margin-bottom:2rem;">Commencez par créer votre premier voyage.</p>
      <a href="{{ path('admin_voyage_new') }}" class="btn-primary"><i class="fas fa-plus"></i> Créer un voyage</a>
    </div>

  {% else %}
    <p style="color:var(--muted);font-size:.82rem;margin-bottom:1.8rem;">
      <i class="fas fa-plane" style="color:var(--gold);"></i> {{ voyages|length }} voyage(s) trouvé(s)
    </p>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1.4rem;">
      {% for voyage in voyages %}
        {% if voyage.imagePath %}
          {% set cardImg = voyage.imagePath %}
        {% elseif voyage.destinationRel and voyage.destinationRel.firstImage %}
          {% set cardImg = voyage.destinationRel.firstImage %}
        {% else %}
          {% set cardImg = null %}
        {% endif %}

        <div style="background:var(--white);border-radius:14px;overflow:hidden;box-shadow:0 2px 12px rgba(13,27,42,0.08);border:1px solid rgba(13,27,42,0.06);transition:transform .3s,box-shadow .3s;position:relative;"
             onmouseover="this.style.transform='translateY(-6px)';this.style.boxShadow='0 16px 40px rgba(13,27,42,0.14)'"
             onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 2px 12px rgba(13,27,42,0.08)'">

          <div style="position:relative;height:200px;overflow:hidden;background:var(--navy);">
            {% if cardImg %}
              <img src="{{ cardImg }}" alt="{{ voyage.destination }}"
                   style="width:100%;height:100%;object-fit:cover;transition:transform .5s;"
                   onmouseover="this.style.transform='scale(1.06)'"
                   onmouseout="this.style.transform='scale(1)'">
            {% else %}
              <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:3.5rem;opacity:.25;">✈️</div>
            {% endif %}
            <div style="position:absolute;bottom:.75rem;left:.75rem;background:rgba(13,27,42,0.88);color:var(--gold);font-size:.82rem;font-weight:700;padding:.35rem .85rem;border-radius:50px;">
              {{ voyage.prix|number_format(0,',',' ') }} TND
            </div>
            <div style="position:absolute;top:.75rem;right:.75rem;background:rgba(201,168,76,0.92);color:var(--navy);font-size:.65rem;font-weight:700;padding:.2rem .6rem;border-radius:50px;letter-spacing:.5px;">
              {{ voyage.dureeJours }} JOURS
            </div>
          </div>

          <div style="padding:1.2rem;">
            <h3 style="font-family:'Playfair Display',serif;font-size:1.1rem;color:var(--navy);margin-bottom:.4rem;">
              {{ voyage.destination }}
            </h3>
            <div style="display:flex;gap:1rem;font-size:.78rem;color:var(--muted);margin-bottom:.6rem;flex-wrap:wrap;">
              {% if voyage.paysDepart %}
                <span><i class="fas fa-plane-departure" style="color:var(--gold);margin-right:.3rem;"></i>{{ voyage.paysDepart }}</span>
              {% endif %}
              <span><i class="fas fa-calendar" style="color:var(--gold);margin-right:.3rem;"></i>{{ voyage.dateDebut|date('d/m/Y') }}</span>
              <span><i class="fas fa-calendar-check" style="color:var(--gold);margin-right:.3rem;"></i>{{ voyage.dateFin|date('d/m/Y') }}</span>
            </div>
            {% if voyage.description %}
              <p style="font-size:.8rem;color:var(--muted);line-height:1.6;">
                {{ voyage.description|slice(0,80) }}{% if voyage.description|length > 80 %}...{% endif %}
              </p>
            {% endif %}
          </div>

          <div style="padding:.9rem 1.2rem;border-top:1px solid rgba(13,27,42,0.06);display:flex;justify-content:space-between;align-items:center;">
            <a href="{{ path('admin_voyage_show', {id: voyage.id}) }}" class="btn-navy" style="padding:.5rem 1.1rem;font-size:.8rem;">
              <i class="fas fa-eye"></i> Voir
            </a>
            <div style="display:flex;gap:.5rem;">
              <a href="{{ path('admin_voyage_edit', {id: voyage.id}) }}" class="btn-gold" style="padding:.5rem 1rem;font-size:.8rem;">
                <i class="fas fa-pen"></i>
              </a>
              <form method="POST" action="{{ path('admin_voyage_delete', {id: voyage.id}) }}"
                    onsubmit="return confirm('Supprimer ce voyage ?')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_voyage_' ~ voyage.id) }}">
                <button type="submit" class="btn-danger-sm" style="padding:.5rem 1rem;">
                  <i class="fas fa-trash"></i>
                </button>
              </form>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}

</div>
{% endblock %}