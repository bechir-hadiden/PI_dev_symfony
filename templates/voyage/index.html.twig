{# templates/voyage/index.html.twig #}
{% extends 'base.html.twig' %}
{% block title %}Voyages{% endblock %}

{% block body %}
<div class="page-header">
  <h1>✈️ <span>Voyages</span></h1>
  <a href="{{ path('voyage_new') }}" class="btn btn-gold">+ Nouveau voyage</a>
</div>

{# Search & Filters #}
<div style="display:flex;gap:12px;margin-bottom:28px;flex-wrap:wrap;">
  <form method="GET" style="display:flex;gap:8px;flex:1;min-width:260px;">
    <input type="text" name="q" value="{{ query }}" placeholder="🔍 Destination, titre, pays..." style="flex:1;padding:11px 16px;border:2px solid #e5e7eb;border-radius:12px;font-family:inherit;font-size:0.875rem;outline:none;">
    <button type="submit" class="btn btn-primary">Chercher</button>
    {% if query %}<a href="{{ path('voyage_index') }}" class="btn btn-outline">✕</a>{% endif %}
  </form>

  <form method="GET" style="display:flex;gap:8px;align-items:center;">
    <select name="destination" onchange="this.form.submit()" style="padding:11px 14px;border:2px solid #e5e7eb;border-radius:12px;font-family:inherit;font-size:0.875rem;outline:none;cursor:pointer;">
      <option value="">🌍 Toutes les destinations</option>
      {% for dest in destinations %}
        <option value="{{ dest.id }}" {{ filtreDestId == dest.id ? 'selected' }}>{{ dest.nom }} — {{ dest.pays }}</option>
      {% endfor %}
    </select>
  </form>
</div>

{% if voyages is empty %}
  <div class="empty-state">
    <div class="icon">✈️</div>
    <h3>Aucun voyage trouvé</h3>
    <p style="margin-bottom:16px;">{% if query %}Aucun résultat pour « {{ query }} »{% else %}Commencez par ajouter un voyage.{% endif %}</p>
    <a href="{{ path('voyage_new') }}" class="btn btn-gold">+ Créer un voyage</a>
  </div>
{% else %}
  <p style="color:var(--muted);font-size:0.82rem;margin-bottom:20px;">{{ voyages|length }} voyage(s) trouvé(s)</p>

  {# Table view #}
  <div class="card" style="overflow:hidden;">
    <table class="data-table">
      <thead>
        <tr>
          <th>Voyage</th>
          <th>Destination</th>
          <th>Dates</th>
          <th>Durée</th>
          <th>Prix</th>
          <th>Statut</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {% for voyage in voyages %}
          <tr>
            <td>
              <div style="font-weight:600;color:var(--navy);">
                {% if voyage.populaire %}<span style="color:var(--gold);">⭐</span> {% endif %}
                {{ voyage.titre }}
              </div>
              {% if voyage.paysDepart %}<div style="font-size:0.75rem;color:var(--muted);">🛫 {{ voyage.paysDepart }}</div>{% endif %}
            </td>
            <td>
              <div style="font-weight:500;">{{ voyage.destination.nom }}</div>
              <div style="font-size:0.75rem;color:var(--muted);">📍 {{ voyage.destination.pays }}</div>
            </td>
            <td style="font-size:0.82rem;">
              {{ voyage.dateDebut|date('d/m/Y') }}<br>
              <span style="color:var(--muted);">→ {{ voyage.dateFin|date('d/m/Y') }}</span>
            </td>
            <td style="font-size:0.82rem;color:var(--muted);">{{ voyage.dureeJours }}j</td>
            <td>
              <div style="font-weight:700;color:var(--gold);white-space:nowrap;">
                {{ voyage.prix|number_format(0,',',' ') }} {{ voyage.devise }}
              </div>
            </td>
            <td>
              <span class="badge {{ voyage.statut == 'disponible' ? 'badge-green' : (voyage.statut == 'complet' ? 'badge-red' : 'badge-navy') }}">
                {{ voyage.statut }}
              </span>
              {% if voyage.placesTotal %}
                <div style="font-size:0.72rem;color:var(--muted);margin-top:3px;">
                  {{ voyage.placesDisponibles }}/{{ voyage.placesTotal }} places
                </div>
              {% endif %}
            </td>
            <td>
              <div class="actions">
                <a href="{{ path('voyage_show', {id: voyage.id}) }}" class="btn btn-outline btn-sm" title="Voir">👁️</a>
                <a href="{{ path('voyage_edit', {id: voyage.id}) }}" class="btn btn-gold btn-sm" title="Modifier">✏️</a>
                <form method="POST" action="{{ path('voyage_delete', {id: voyage.id}) }}" onsubmit="return confirm('Supprimer ce voyage ?')">
                  <input type="hidden" name="_token" value="{{ csrf_token('delete_voyage_' ~ voyage.id) }}">
                  <button type="submit" class="btn btn-danger btn-sm" title="Supprimer">🗑️</button>
                </form>
              </div>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% endif %}
{% endblock %}
