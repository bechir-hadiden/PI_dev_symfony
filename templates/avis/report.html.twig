{% extends 'base.html.twig' %}

{% block body %}
<div style="padding: 10rem 2rem; background: var(--cream); min-height: 100vh; display: flex; align-items: center; justify-content: center;">
    <div style="max-width: 500px; width: 100%; background: #fff; padding: 3rem; box-shadow: 0 30px 60px rgba(0,0,0,0.1); border-top: 4px solid var(--gold);">
        <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 2.2rem; margin-bottom: 1.5rem;">Signaler un <em>contenu</em></h2>
        
        <div style="background: var(--cream); padding: 1rem; margin-bottom: 2rem; font-size: 0.85rem; border-left: 2px solid var(--gold);">
            Avis de <strong>{{ avis.nom }}</strong> pour <strong>{{ avis.destination }}</strong>.
        </div>

        {{ form_start(form) }}
            <div class="form-group">
                <label style="display: block; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.5rem;">Motif du signalement</label>
                <select name="motif" style="width: 100%; padding: 1rem; border: 0.5px solid #ddd; outline: none;">
                    <option>Contenu haineux ou offensant</option>
                    <option>Publicité ou Spam</option>
                    <option>Faux avis / Fraude</option>
                    <option>Autre</option>
                </select>
            </div>
            
            <button type="submit" style="background: var(--ink); color: white; width: 100%; padding: 1.2rem; border: none; cursor: pointer; text-transform: uppercase; letter-spacing: 0.2em; margin-top: 1rem;">
                Envoyer le signalement
            </button>
            
            <a href="{{ path('app_avis_index') }}" style="display: block; text-align: center; margin-top: 1.5rem; font-size: 0.7rem; color: var(--muted); text-decoration: none; text-transform: uppercase; letter-spacing: 0.1em;">Annuler</a>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}