        // ========== SIGNALEMENT ==========
        function showSignalementModal(avisId) {
            document.getElementById('signalementAvisId').value = avisId;
            document.getElementById('signalementModal').style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }
        
        function closeSignalementModal() {
            document.getElementById('signalementModal').style.display = 'none';
            document.getElementById('signalementForm').reset();
            document.body.style.overflow = 'auto';
        }
        
        document.getElementById('signalementForm')?.addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const avisId = document.getElementById('signalementAvisId').value;
            const motif = document.querySelector('input[name="motif"]:checked')?.value;
            const description = document.getElementById('signalementDescription').value;
            
            if (!motif) {
                alert('Veuillez sélectionner un motif');
                return;
            }
            
            const submitBtn = this.querySelector('.btn-report-submit');
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Envoi en cours...';
            
            try {
                const response = await fetch(`/avis/${avisId}/signaler`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ motif, description })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    alert('✅ Signalement envoyé ! Notre équipe va vérifier cet avis.');
                    closeSignalementModal();
                } else {
                    alert('❌ Erreur: ' + (data.error || 'Impossible d\'envoyer le signalement'));
                }
            } catch (error) {
                alert('❌ Erreur de connexion');
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="fas fa-paper-plane"></i> Envoyer le signalement';
            }
        });
        
        document.getElementById('signalementModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                closeSignalementModal();
            }
        });
        
        function initVoiceSearch() {
            const voiceSearchBtn = document.getElementById('voiceSearchBtn');
            const voiceSearchInput = document.getElementById('voiceSearchInput');
            const voiceSearchResult = document.getElementById('voiceSearchResult');
            
            if (!voiceSearchBtn) return;
            if (!('webkitSpeechRecognition' in window) && !('SpeechRecognition' in window)) {
                voiceSearchBtn.disabled = true;
                return;
            }
            
            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            let recognition = null;
            
            voiceSearchBtn.addEventListener('click', function() {
                if (recognition) {
                    recognition.stop();
                    recognition = null;
                    voiceSearchBtn.innerHTML = '<i class="fas fa-microphone"></i> Dicter';
                    voiceSearchBtn.classList.remove('listening');
                    return;
                }
                
                recognition = new SpeechRecognition();
                recognition.lang = 'fr-FR';
                recognition.interimResults = false;
                
                recognition.onstart = function() {
                    voiceSearchBtn.innerHTML = '<i class="fas fa-stop"></i> Arrêter';
                    voiceSearchBtn.classList.add('listening');
                    if (voiceSearchResult) {
                        voiceSearchResult.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i> Écoute en cours...';
                        voiceSearchResult.style.display = 'block';
                    }
                };
                
                recognition.onresult = function(event) {
                    const transcript = event.results[0][0].transcript;
                    if (voiceSearchInput) voiceSearchInput.value = transcript;
                    processVoiceCommand(transcript, voiceSearchResult, voiceSearchInput);
                };
                
                recognition.onerror = function() {
                    if (voiceSearchResult) {
                        voiceSearchResult.innerHTML = '<i class="fas fa-exclamation-triangle"></i> Erreur de reconnaissance';
                    }
                    voiceSearchBtn.innerHTML = '<i class="fas fa-microphone"></i> Dicter';
                    voiceSearchBtn.classList.remove('listening');
                };
                
                recognition.onend = function() {
                    recognition = null;
                    voiceSearchBtn.innerHTML = '<i class="fas fa-microphone"></i> Dicter';
                    voiceSearchBtn.classList.remove('listening');
                };
                
                recognition.start();
            });
            
            if (voiceSearchInput) {
                voiceSearchInput.addEventListener('input', function() {
                    if (this.value) processVoiceCommand(this.value, voiceSearchResult, voiceSearchInput);
                    else if (voiceSearchResult) voiceSearchResult.style.display = 'none';
                });
            }
            
            document.querySelectorAll('.voice-command-chip').forEach(chip => {
                chip.addEventListener('click', function() {
                    const command = this.dataset.command;
                    if (voiceSearchInput) voiceSearchInput.value = command;
                    processVoiceCommand(command, voiceSearchResult, voiceSearchInput);
                });
            });
        }
        
        function processVoiceCommand(query, resultDiv, inputField) {
            const lowerQuery = query.toLowerCase();
            
            if (lowerQuery.includes('afficher tout') || lowerQuery.includes('tout afficher')) {
                if (document.getElementById('filterNote')) document.getElementById('filterNote').value = '0';
                filterAvis();
                if (resultDiv) {
                    resultDiv.innerHTML = '<i class="fas fa-check-circle"></i> ✅ Tous les avis sont affichés';
                    resultDiv.style.display = 'block';
                }
                if (inputField) inputField.value = '';
                setTimeout(() => { if (resultDiv) resultDiv.style.display = 'none'; }, 3000);
                return;
            }
            
            if (lowerQuery.includes('meilleurs avis') || lowerQuery.includes('top avis')) {
                if (document.getElementById('filterNote')) document.getElementById('filterNote').value = '4';
                filterAvis();
                if (resultDiv) {
                    resultDiv.innerHTML = '<i class="fas fa-star"></i> ⭐ Affichage des meilleurs avis';
                    resultDiv.style.display = 'block';
                }
                setTimeout(() => { if (resultDiv) resultDiv.style.display = 'none'; }, 3000);
                return;
            }
            
            let searchTerm = '';
            if (lowerQuery.startsWith('recherche')) {
                searchTerm = lowerQuery.replace('recherche', '').trim();
            } else if (lowerQuery.startsWith('cherche')) {
                searchTerm = lowerQuery.replace('cherche', '').trim();
            } else {
                searchTerm = lowerQuery;
            }
            
            const noteMatch = searchTerm.match(/(\d)\s*étoiles?/);
            if (noteMatch && document.getElementById('filterNote')) {
                document.getElementById('filterNote').value = noteMatch[1];
                filterAvis();
                if (resultDiv) {
                    resultDiv.innerHTML = `<i class="fas fa-star"></i> ⭐ Affichage des avis ${noteMatch[1]} étoiles`;
                    resultDiv.style.display = 'block';
                }
                setTimeout(() => { if (resultDiv) resultDiv.style.display = 'none'; }, 3000);
                return;
            }
            
            if (searchTerm) {
                filterAvisByText(searchTerm);
                if (resultDiv) {
                    resultDiv.innerHTML = `<i class="fas fa-search"></i> 🔍 Recherche : "${searchTerm}"`;
                    resultDiv.style.display = 'block';
                }
                highlightSearchTerm(searchTerm);
                setTimeout(() => { if (resultDiv) resultDiv.style.display = 'none'; }, 5000);
            }
        }
        
        function filterAvisByText(searchText) {
            const cards = document.querySelectorAll('.avis-card');
            const searchLower = searchText.toLowerCase();
            let found = false;
            cards.forEach(card => {
                const comment = card.dataset.commentaire;
                const nom = card.dataset.nom;
                if (comment && (comment.includes(searchLower) || (nom && nom.includes(searchLower)))) {
                    card.style.display = '';
                    found = true;
                } else {
                    card.style.display = 'none';
                }
            });
            if (!found && document.getElementById('filterNote')) {
                document.getElementById('filterNote').value = '0';
                filterAvis();
            }
        }
        
        function highlightSearchTerm(term) {
            removeHighlights();
            const cards = document.querySelectorAll('.avis-card');
            const regex = new RegExp(`(${term})`, 'gi');
            cards.forEach(card => {
                const commentElement = card.querySelector('.avis-commentaire');
                if (commentElement && commentElement.innerText.toLowerCase().includes(term.toLowerCase())) {
                    commentElement.innerHTML = commentElement.innerText.replace(regex, '<mark class="highlight">$1</mark>');
                }
            });
        }
        
        function removeHighlights() {
            document.querySelectorAll('.avis-commentaire mark').forEach(mark => {
                const parent = mark.parentNode;
                parent.innerHTML = parent.innerText;
            });
        }
        
        function initMicDictation() {
            const micBtn = document.getElementById('micBtn');
            const stopMicBtn = document.getElementById('stopMicBtn');
            const listeningIndicator = document.getElementById('listeningIndicator');
            const commentaireInput = document.getElementById('commentaire-input');
            
            if (!micBtn || !('webkitSpeechRecognition' in window)) return;
            
            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            
            micBtn.addEventListener('click', function() {
                if (micRecognition) {
                    micRecognition.stop();
                    return;
                }
                
                micRecognition = new SpeechRecognition();
                micRecognition.lang = 'fr-FR';
                micRecognition.interimResults = true;
                micRecognition.continuous = true;
                
                micRecognition.onstart = function() {
                    micBtn.style.display = 'none';
                    if (stopMicBtn) stopMicBtn.style.display = 'inline-flex';
                    if (listeningIndicator) listeningIndicator.style.display = 'block';
                    if (commentaireInput) commentaireInput.classList.add('listening');
                };
                
                micRecognition.onresult = function(event) {
                    let finalTranscript = '';
                    for (let i = event.resultIndex; i < event.results.length; i++) {
                        if (event.results[i].isFinal) finalTranscript += event.results[i][0].transcript;
                    }
                    if (finalTranscript && commentaireInput) {
                        let currentText = commentaireInput.value;
                        if (currentText && !currentText.endsWith(' ') && !currentText.endsWith('\n')) currentText += ' ';
                        commentaireInput.value = currentText + finalTranscript;
                        // Trigger validation
                        const event = new Event('input');
                        commentaireInput.dispatchEvent(event);
                    }
                };
                
                micRecognition.onerror = function() { resetMic(); };
                micRecognition.onend = function() { resetMic(); };
                
                micRecognition.start();
            });
            
            if (stopMicBtn) {
                stopMicBtn.addEventListener('click', function() { if (micRecognition) micRecognition.stop(); });
            }
            
            function resetMic() {
                if (micBtn) micBtn.style.display = 'inline-flex';
                if (stopMicBtn) stopMicBtn.style.display = 'none';
                if (listeningIndicator) listeningIndicator.style.display = 'none';
                if (commentaireInput) commentaireInput.classList.remove('listening');
                micRecognition = null;
            }
        }
        
        function initTranslation() {
            document.querySelectorAll('.translate-btn').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    const avisId = this.dataset.id;
                    const targetLang = this.dataset.lang;
                    const translationDiv = document.getElementById(`translation-${avisId}`);
                    const commentElement = this.closest('.avis-card')?.querySelector('.avis-commentaire');
                    let originalText = commentElement?.innerText;
                    
                    if (!originalText || !translationDiv) return;
                    
                    originalText = originalText.replace(/<mark class="highlight">|<\/mark>/g, '');
                    
                    translationDiv.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Traduction en cours...';
                    translationDiv.style.display = 'block';
                    
                    fetch(`/avis/translate/${avisId}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ lang: targetLang })
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success && data.translated) {
                            translationDiv.innerHTML = data.translated;
                        } else {
                            translationDiv.innerHTML = '❌ Traduction non disponible';
                        }
                    })
                    .catch(() => {
                        translationDiv.innerHTML = '❌ Erreur de traduction';
                    });
                });
            });
        }
        
        const responses = [
            "Excellente question ! Pour un budget de 3 000 € par personne, je vous recommande Santorin puis Amalfi. Voulez-vous que je prépare l'itinéraire complet ?",
            "Absolument ! J'ai trouvé des vols directs pour vos dates. Préférez-vous Business ou Première Classe ?",
            "Votre itinéraire est prêt. Je vous envoie le dossier complet par email.",
            "Je réserve immédiatement ! Votre voyage est confirmé. Y a-t-il autre chose ?"
        ];
        let rIdx = 0;
        
        function addChatMessage(text, isUser) {
            const msgs = document.getElementById('chatMessages');
            if (!msgs) return;
            const div = document.createElement('div');
            div.className = 'voyage-msg' + (isUser ? ' user' : '');
            const av = document.createElement('div');
            av.className = 'voyage-msg-avatar' + (isUser ? ' user-av' : '');
            av.textContent = isUser ? 'V' : 'E';
            const bubble = document.createElement('div');
            bubble.className = 'voyage-msg-bubble ' + (isUser ? 'user' : 'agent');
            bubble.textContent = text;
            div.appendChild(av);
            div.appendChild(bubble);
            msgs.appendChild(div);
            msgs.scrollTop = msgs.scrollHeight;
        }
        
        const sendBtn = document.getElementById('chatSend');
        const chatInput = document.getElementById('chatInput');
        
        if (sendBtn && chatInput) {
            sendBtn.addEventListener('click', function() {
                const text = chatInput.value.trim();
                if (!text) return;
                addChatMessage(text, true);
                chatInput.value = '';
                
                const typingDiv = document.createElement('div');
                typingDiv.className = 'voyage-msg';
                typingDiv.id = 'typingMsg';
                const typingAv = document.createElement('div');
                typingAv.className = 'voyage-msg-avatar';
                typingAv.textContent = 'E';
                const typingBubble = document.createElement('div');
                typingBubble.className = 'voyage-msg-bubble agent voyage-typing';
                typingBubble.innerHTML = '<span></span><span></span><span></span>';
                typingDiv.appendChild(typingAv);
                typingDiv.appendChild(typingBubble);
                document.getElementById('chatMessages').appendChild(typingDiv);
                document.getElementById('chatMessages').scrollTop = 99999;
                
                setTimeout(() => {
                    const typingEl = document.getElementById('typingMsg');
                    if (typingEl) typingEl.remove();
                    const resp = responses[rIdx % responses.length];
                    rIdx++;
                    addChatMessage(resp, false);
                }, 1600);
            });
            
            chatInput.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') sendBtn.click();
            });
        }
        
        const newsletterSubmit = document.getElementById('newsletterSubmit');
        if (newsletterSubmit) {
            newsletterSubmit.addEventListener('click', function() {
                const email = document.getElementById('newsletterEmail').value;
                if (email && email.includes('@')) {
                    alert('Merci pour votre inscription ! Vous recevrez nos meilleures offres.');
                    document.getElementById('newsletterEmail').value = '';
                } else {
                    alert('Veuillez entrer une adresse email valide.');
                }
            });
        }
    </script>
