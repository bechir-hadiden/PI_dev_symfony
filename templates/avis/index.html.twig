{% block javascripts %}
    {{ parent() }}
    <script>
        let currentRating = 5;
        let editModal;
        let voiceRecognition = null;
        let micRecognition = null;
        
        document.addEventListener('DOMContentLoaded', function() {
            const stars = document.querySelectorAll('.rating-star');
            stars.forEach(star => {
                star.addEventListener('click', function() {
                    currentRating = parseInt(this.dataset.value);
                    document.getElementById('avisNote').value = currentRating;
                    stars.forEach((s, i) => {
                        if (i < currentRating) s.classList.add('active');
                        else s.classList.remove('active');
                    });
                    // Remove error on rating
                    document.getElementById('form-group-note')?.classList.remove('error');
                    document.getElementById('error-note')?.classList.remove('show');
                });
            });
            if (stars.length > 0) stars[4]?.classList.add('active');
            
            const filterNote = document.getElementById('filterNote');
            const sortBy = document.getElementById('sortBy');
            if (filterNote) filterNote.addEventListener('change', filterAvis);
            if (sortBy) sortBy.addEventListener('change', sortAvis);
            
            if (typeof bootstrap !== 'undefined') {
                const editModalEl = document.getElementById('editModal');
                if (editModalEl) editModal = new bootstrap.Modal(editModalEl);
            }
            
            initVoiceSearch();
            initMicDictation();
            initTranslation();
            initFormValidation();
        });
        
        // ========== CONTRÔLE DE SAISIE POUR LE FORMULAIRE ==========
        function initFormValidation() {
            const form = document.getElementById('newAvisForm');
            if (!form) return;
            
            const nomInput = document.getElementById('avisNom');
            const emailInput = document.getElementById('avisEmail');
            const destinationInput = document.getElementById('destination-input');
            const commentaireInput = document.getElementById('commentaire-input');
            
            // Validation en temps réel
            if (nomInput) {
                nomInput.addEventListener('input', function() {
                    validateField(this, document.getElementById('form-group-nom'), document.getElementById('error-nom'), 
                        () => this.value.trim().length >= 2, 'Veuillez entrer votre nom (minimum 2 caractères)');
                });
            }
            
            if (emailInput) {
                emailInput.addEventListener('input', function() {
                    const emailRegex = /^[^\s@]+@([^\s@.,]+\.)+[^\s@.,]{2,}$/;
                    validateField(this, document.getElementById('form-group-email'), document.getElementById('error-email'), 
                        () => emailRegex.test(this.value.trim()), 'Veuillez entrer une adresse email valide');
                });
            }
            
            if (destinationInput) {
                destinationInput.addEventListener('input', function() {
                    validateField(this, document.getElementById('form-group-destination'), document.getElementById('error-destination'), 
                        () => this.value.trim().length >= 2, 'Veuillez entrer une destination');
                });
            }
            
            if (commentaireInput) {
                commentaireInput.addEventListener('input', function() {
                    validateField(this, document.getElementById('form-group-commentaire'), document.getElementById('error-commentaire'), 
                        () => this.value.trim().length >= 10, 'Veuillez entrer un commentaire (minimum 10 caractères)');
                });
            }
            
            // Soumission du formulaire
            form.addEventListener('submit', function(e) {
                let isValid = true;
                
                // Validation nom
                if (nomInput && !validateField(nomInput, document.getElementById('form-group-nom'), document.getElementById('error-nom'), 
                    () => nomInput.value.trim().length >= 2, 'Veuillez entrer votre nom (minimum 2 caractères)')) {
                    isValid = false;
                }
                
                // Validation email
                const emailRegex = /^[^\s@]+@([^\s@.,]+\.)+[^\s@.,]{2,}$/;
                if (emailInput && !validateField(emailInput, document.getElementById('form-group-email'), document.getElementById('error-email'), 
                    () => emailRegex.test(emailInput.value.trim()), 'Veuillez entrer une adresse email valide')) {
                    isValid = false;
                }
                
                // Validation destination
                if (destinationInput && !validateField(destinationInput, document.getElementById('form-group-destination'), document.getElementById('error-destination'), 
                    () => destinationInput.value.trim().length >= 2, 'Veuillez entrer une destination')) {
                    isValid = false;
                }
                
                // Validation commentaire
                if (commentaireInput && !validateField(commentaireInput, document.getElementById('form-group-commentaire'), document.getElementById('error-commentaire'), 
                    () => commentaireInput.value.trim().length >= 10, 'Veuillez entrer un commentaire (minimum 10 caractères)')) {
                    isValid = false;
                }
                
                if (!isValid) {
                    e.preventDefault();
                    // Scroll to first error
                    const firstError = document.querySelector('.form-group.error');
                    if (firstError) {
                        firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    }
                }
            });
        }
        
        function validateField(input, group, errorMsg, validationFn, errorText) {
            if (!input || !group || !errorMsg) return true;
            const isValid = validationFn();
            if (!isValid) {
                group.classList.add('error');
                errorMsg.textContent = errorText;
                errorMsg.classList.add('show');
            } else {
                group.classList.remove('error');
                errorMsg.classList.remove('show');
            }
            return isValid;
        }
        
        function filterAvis() {
            const note = document.getElementById('filterNote').value;
            document.querySelectorAll('.avis-card').forEach(card => {
                card.style.display = (note == 0 || card.dataset.note == note) ? '' : 'none';
            });
        }
        
        function sortAvis() {
            const sortBy = document.getElementById('sortBy').value;
            const container = document.getElementById('avisContainer');
            const cards = Array.from(document.querySelectorAll('.avis-card'));
            cards.sort((a, b) => {
                if (sortBy === 'date') {
                    return parseInt(b.dataset.date) - parseInt(a.dataset.date);
                } else {
                    return parseInt(b.dataset.note) - parseInt(a.dataset.note);
                }
            });
            cards.forEach(card => container.appendChild(card));
        }
        
        function toggleComments(id) {
            const div = document.getElementById(`comments-${id}`);
            const chevron = document.getElementById(`chevron-${id}`);
            if (!div) return;
            if (div.style.display === 'none' || !div.style.display) {
                div.style.display = 'block';
                if (chevron) {
                    chevron.classList.remove('fa-chevron-down');
                    chevron.classList.add('fa-chevron-up');
                }
            } else {
                div.style.display = 'none';
                if (chevron) {
                    chevron.classList.remove('fa-chevron-up');
                    chevron.classList.add('fa-chevron-down');
                }
            }
        }
        
        function addComment(id) {
            const input = document.getElementById(`comment-input-${id}`);
            if (!input || !input.value.trim()) return;
            fetch(`/avis/commentaire/${id}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ auteur: 'Visiteur', texte: input.value })
            }).then(() => location.reload());
        }
        
        function editAvis(id) {
            fetch(`/avis/modifier/${id}`).then(r => r.json()).then(avis => {
                document.getElementById('editId').value = avis.id;
                document.getElementById('editNom').value = avis.nomClient;
                document.getElementById('editEmail').value = avis.email;
                document.getElementById('editNote').value = avis.note;
                document.getElementById('editVoyageId').value = avis.voyageId;
                document.getElementById('editCommentaire').value = avis.commentaire;
                document.getElementById('editDestination').value = avis.destination || '';
                if (editModal) editModal.show();
            });
        }
        
        function saveEdit() {
            const id = document.getElementById('editId').value;
            const data = {
                nomClient: document.getElementById('editNom').value,
                email: document.getElementById('editEmail').value,
                note: document.getElementById('editNote').value,
                voyageId: document.getElementById('editVoyageId').value,
                commentaire: document.getElementById('editCommentaire').value,
                destination: document.getElementById('editDestination').value
            };
            fetch(`/avis/modifier/${id}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            }).then(() => location.reload());
        }
        
        function deleteAvis(id) {
            if (confirm('Supprimer cet avis ?')) {
                fetch(`/avis/supprimer/${id}`, { method: 'POST' }).then(() => location.reload());
            }
        }
        
