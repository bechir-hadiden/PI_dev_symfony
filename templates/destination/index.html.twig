{% extends 'base_dark.html.twig' %}

{% block title %}Destinations{% endblock %}

{% block stylesheets %}
<style>
/* ── PAGE HEADER ── */
.page-header {
    min-height: 38vh;
    background: var(--ink);
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 6rem 3.5rem 3.5rem;
    position: relative; overflow: hidden;
}
.page-header::after {
    content:'';
    position: absolute; inset:0;
    background: linear-gradient(135deg, rgba(201,168,76,0.08) 0%, transparent 60%);
    pointer-events: none;
}
.page-header-tag {
    font-size: 0.7rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--gold); display: flex; align-items: center; gap: 0.7rem;
    margin-bottom: 0.9rem;
}
.page-header-tag::before {
    content:''; display:block; width:28px; height:0.5px; background:var(--gold);
}
.page-header h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 5vw, 4.2rem);
    font-weight: 300;
    color: var(--white);
    line-height: 1.1;
}
.page-header h1 em { font-style: italic; color: var(--gold); }
.page-header-sub {
    font-size: 0.88rem;
    color: rgba(245,240,232,0.5);
    margin-top: 0.8rem;
}

/* ── SEARCH ── */
.search-section {
    padding: 2.5rem 3.5rem;
    background: var(--sand);
}
.search-form {
    display: flex;
    max-width: 600px;
}
.search-input {
    flex: 1;
    padding: 0.9rem 1.3rem;
    border: 1px solid rgba(201,168,76,0.4);
}
.search-btn {
    padding: 0.9rem 1.8rem;
    background: var(--gold);
    border: none;
    font-weight: 600;
}

/* ── GRID ── */
.dest-section { padding: 5rem 3.5rem; }
.dest-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5px;
    background: rgba(201,168,76,0.15);
}

.dest-card {
    position: relative;
    overflow: hidden;
    min-height: 380px;
    background: var(--ink);
    text-decoration: none;
}

.dest-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.75;
}

.dest-body {
    position: absolute;
    bottom: 0;
    padding: 2rem;
    color: white;
}

/* empty */
.empty-state {
    text-align: center;
    padding: 6rem 2rem;
    grid-column: 1 / -1;
}
</style>
{% endblock %}

{% block body %}

<div class="page-header">
    <div class="page-header-tag">SmartTrip · Catalogue</div>

    <h1>Nos <em>Destinations</em></h1>

    <p class="page-header-sub">
        {{ destinations|length }} destination(s) disponible(s)
    </p>
</div>

{# SEARCH #}
<div class="search-section">
    <form class="search-form" method="GET">
        <input type="text"
               name="q"
               class="search-input"
               placeholder="Rechercher..."
               value="{{ query ?? '' }}">

        <button class="search-btn">Rechercher</button>
    </form>

    {% if query %}
        <p style="margin-top:10px;font-size:12px;">
            {{ destinations|length }} résultat(s) pour "{{ query }}"
            · <a href="{{ path('client_destination_index') }}">Effacer</a>
        </p>
    {% endif %}
</div>

{# GRID #}
<section class="dest-section">
    <div class="dest-grid">

        {% if destinations is empty %}
            <div class="empty-state">
                <h3>Aucune destination trouvée</h3>
            </div>
        {% else %}

            {% for dest in destinations %}

                <a href="{{ path('client_destination_show', {id: dest.id}) }}"
                   class="dest-card">

                    {% if dest.firstImage %}
                        <img src="{{ dest.firstImage }}" alt="{{ dest.nom }}">
                    {% else %}
                        <div style="height:100%;background:linear-gradient(135deg,#1a3c5e,#c9a84c);"></div>
                    {% endif %}

                    <div class="dest-body">
                        <div>{{ dest.pays }}</div>
                        <h2>{{ dest.nom }}</h2>

                        {% if dest.description %}
                            <p style="font-size:12px;opacity:.7;">
                                {{ dest.description|slice(0,80) }}...
                            </p>
                        {% endif %}
                    </div>

                </a>

            {% endfor %}

        {% endif %}

    </div>
</section>

{% endblock %}