<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}SmartTrip{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2290%22>✈️</text></svg>">
        
        <!-- 1. Bootstrap 5 CSS -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        
        <!-- 2. Ton CSS personnalisé -->
        <link rel="stylesheet" href="{{ asset('css/style2.css') }}">

        {% block stylesheets %}{% endblock %}
        
        <style>
            /* Style pour la Navbar pour qu'elle soit pro */
            .main-navbar {
                background-color: white !important;
                border-bottom: 1px solid #E5E7EB;
            }
            .nav-link-custom {
                color: #4B5563 !important;
                font-weight: 600;
                transition: 0.3s;
            }
            .nav-link-custom:hover {
                color: #1A73E8 !important;
            }
            .nav-link-active {
                color: #1A73E8 !important;
                border-bottom: 2px solid #1A73E8;
            }
        </style>
    </head>
    <body style="background-color: #F4F7FB;"> <!-- Fond gris clair uniforme -->

        <!-- BARRE DE NAVIGATION GLOBALE -->
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top main-navbar">
            <div class="container px-4">
                <a class="navbar-brand fw-bold text-primary" href="{{ path('app_offre_client_index') }}" style="font-size: 1.5rem;">
                    🚀 SmartTrip
                </a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-center">
                        <!-- Lien vers le Catalogue Client -->
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom px-3" href="{{ path('app_offre_client_index') }}">
                                Vue Voyageur 🌍
                            </a>
                        </li>

                        <!-- Lien vers l'Espace Administration -->
                        <li class="nav-item">
                            <a class="nav-link btn btn-primary text-white rounded-pill px-4 ms-lg-3 shadow-sm" 
                               href="{{ path('app_offre_index') }}" 
                               style="background-color: #1A73E8; border: none; font-weight: bold;">
                               Espace Admin ⚙️
                            </a>
                        </li>
                        
                        <!-- Petit avatar pour faire pro -->
                        <li class="nav-item ms-4 d-none d-lg-block">
                            <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center fw-bold" 
                                 style="width: 38px; height: 38px; font-size: 14px;">
                                AR
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <!-- CONTENU DE LA PAGE -->
        {% block body %}{% endblock %}

        <!-- 3. Bootstrap 5 JS -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>