<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="description" content="Smart Trip - Agence de voyage premium. Découvrez nos voyages sur mesure, destinations exclusives et offres spéciales.">
    <meta name="keywords" content="voyage, agence de voyage, tourisme, destination, réservation, avis, Smart Trip">
    <meta name="author" content="Smart Trip">
    
    <title>{% block title %}SmartTrip - Voyages et Avis{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>✈️</text></svg>">
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    {% block stylesheets %}
        <style>
            /* ========== STYLES DE BASE ========== */
            :root {
                --gold: #ffd700;
                --gold-l: #ffed4a;
                --navy: #1a2a3a;
                --navy-light: #2a3a4a;
                --muted: #6c757d; 
                --dark: #0a0f1a;
                --dark-card: rgba(255,255,255,0.05);
            }
            
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }
            
            body {
                font-family: 'Inter', sans-serif;
                background: #f8f9fa;
                overflow-x: hidden;
            }
            
            .navbar {
                background: #0a0f1a !important;
                border-bottom: 1px solid rgba(255, 215, 0, 0.2);
                padding: 1rem 0;
                transition: all 0.3s ease;
            }
            
            .navbar-brand {
                font-weight: 700;
                font-size: 1.5rem;
                color: var(--gold) !important;
            }
            
            .navbar-brand i {
                margin-right: 8px;
                color: var(--gold);
            }
            
            .nav-link {
                font-weight: 500;
                transition: all 0.2s;
                color: white !important;
            }
            
            .nav-link:hover {
                color: var(--gold) !important;
            }
            
            .dropdown-menu {
                border-radius: 12px;
                box-shadow: 0 10px 30px rgba(0,0,0,0.15);
                border: none;
                margin-top: 10px;
                background: #1a2a3a;
            }
            
            .dropdown-item {
                padding: 8px 20px;
                transition: all 0.2s;
                color: white;
            }
            
            .dropdown-item:hover {
                background: linear-gradient(135deg, var(--gold), #e6a800);
                color: #0a0f1a;
            }
            
            .admin-badge {
                background: #dc3545;
                color: white;
                padding: 2px 8px;
                border-radius: 20px;
                font-size: 0.7rem;
                margin-left: 10px;
            }
            
            .btn-primary {
                background: linear-gradient(135deg, var(--gold), #e6a800);
                border: none;
                color: #0a0f1a;
                font-weight: 600;
            }
            
            .footer {
                background: #0a0f1a;
                padding: 3rem 5%;
                border-top: 1px solid rgba(255,215,0,0.2);
                color: rgba(255,255,255,0.7);
            }
            
            .footer a {
                color: rgba(255,255,255,0.7);
                text-decoration: none;
            }
            
            .footer a:hover {
                color: var(--gold);
            }
            
            .footer h5 {
                color: var(--gold);
                margin-bottom: 1rem;
            }
            
            .social-links {
                display: flex;
                gap: 1rem;
                margin-top: 1rem;
            }
            
            .alert {
                position: fixed;
                top: 80px;
                right: 20px;
                padding: 1rem 1.5rem;
                border-radius: 10px;
                z-index: 1001;
                animation: slideIn 0.3s ease;
                display: flex;
                align-items: center;
                gap: 0.5rem;
            }
            
            .alert-close {
                margin-left: auto;
                background: none;
                border: none;
                font-size: 1.2rem;
                cursor: pointer;
            }
            
            @keyframes slideIn {
                from {
                    opacity: 0;
                    transform: translateX(100%);
                }
                to {
                    opacity: 1;
                    transform: translateX(0);
                }
            }
            
            @media (max-width: 768px) {
                .hero-content h1 {
                    font-size: 2rem;
                }
            }
        </style>
    {% endblock %}
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="fas fa-plane"></i> SmartTrip
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/#destinations">Destinations</a></li>
                    <li class="nav-item"><a class="nav-link" href="/#packages">Voyages</a></li>
                    <li class="nav-item"><a class="nav-link" href="/#avis">Avis</a></li>
                    <li class="nav-item"><a class="nav-link" href="/#reservation">Réservation</a></li>
                    <li class="nav-item"><a class="nav-link" href="/avis">Tous les avis</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }}">
                    {{ message|raw }}
                    <button class="alert-close" onclick="this.parentElement.remove()">&times;</button>
                </div>
            {% endfor %}
        {% endfor %}
        
        {% block body %}{% endblock %}
    </main>

    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <h5>SmartTrip</h5>
                    <p class="small">Votre partenaire de confiance pour des voyages inoubliables.</p>
                </div>
                <div class="col-md-4 mb-3">
                    <h5>Liens utiles</h5>
                    <ul class="list-unstyled small">
                        <li><a href="/avis">Avis clients</a></li>
                        <li><a href="#">Conditions générales</a></li>
                        <li><a href="#">Contact</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-3">
                    <h5>Contact</h5>
                    <p class="small">+216 71 234 567<br>contact@SmartTrip.tn</p>
                    <p class="small mb-0">&copy; {{ "now"|date("Y") }} SmartTrip.</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>