{# templates/bundles/KnpPaginatorBundle/Pagination/twitter_bootstrap_v4_pagination.html.twig #}
{% if pageCount > 1 %}
    <nav>
        <ul class="pagination justify-content-center">
            {% if previous is defined %}
                <li class="page-item">
                    <a class="page-link" rel="prev" href="{{ path(route, query|merge({(pageParameterName): previous})) }}">« Précédent</a>
                </li>
            {% else %}
                <li class="page-item disabled">
                    <span class="page-link">« Précédent</span>
                </li>
            {% endif %}

            {% for page in pagesInRange %}
                {% if page != current %}
                    <li class="page-item">
                        <a class="page-link" href="{{ path(route, query|merge({(pageParameterName): page})) }}">{{ page }}</a>
                    </li>
                {% else %}
                    <li class="page-item active">
                        <span class="page-link">{{ page }}</span>
                    </li>
                {% endif %}
            {% endfor %}

            {% if next is defined %}
                <li class="page-item">
                    <a class="page-link" rel="next" href="{{ path(route, query|merge({(pageParameterName): next})) }}">Suivant »</a>
                </li>
            {% else %}
                <li class="page-item disabled">
                    <span class="page-link">Suivant »</span>
                </li>
            {% endif %}
        </ul>
    </nav>
{% endif %}