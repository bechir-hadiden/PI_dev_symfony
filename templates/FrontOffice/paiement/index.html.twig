{% extends 'base_dark.html.twig' %}

{% block title %}Mes Paiements – VoyageElite{% endblock %}

{% block body %}
<div style="background:var(--navy);padding:7rem 5% 3rem;border-bottom:1px solid rgba(201,168,76,0.15);">
    <h1 class="section-title light">Mes Paiements</h1>
    <p style="color:rgba(255,255,255,0.55);">Consultez l'historique de vos transactions.</p>
</div>

<div style="padding:3rem 5%;background:var(--cream);min-height:60vh;">
    <!-- Email lookup -->
    <div style="background:#fff;border:1px solid rgba(13,27,42,0.1);border-radius:14px;padding:1.4rem;margin-bottom:1.8rem;max-width:500px">
        <form method="GET" style="display:flex;gap:.6rem;align-items:flex-end">
            <div style="flex:1">
                <label style="display:block;font-size:.73rem;font-weight:700;color:var(--muted);margin-bottom:.35rem;text-transform:uppercase;">Votre email</label>
                <input type="email" name="email" value="{{ email }}" placeholder="votre@email.com"
                    style="width:100%;padding:.6rem .9rem;border:1px solid rgba(13,27,42,0.1);border-radius:8px;font-size:.875rem;outline:none">
            </div>
            <button type="submit" class="btn-primary" style="padding:.7rem 1.4rem;">Rechercher</button>
        </form>
    </div>

    {% if email and paiements is empty %}
        <div style="text-align:center;padding:3rem;color:var(--muted)">
            <p>Aucun paiement trouvé pour <strong>{{ email }}</strong>.</p>
        </div>
    {% elseif email %}
        <div style="display:flex;flex-direction:column;gap:1rem">
            {% for p in paiements %}
                <div style="background:#fff;border:1px solid rgba(13,27,42,0.08);border-radius:14px;padding:1.2rem;display:flex;justify-content:space-between;align-items:center;">
                    <div>
                        <div style="font-size:1.1rem;font-weight:700;color:var(--navy)">{{ p.montant|number_format(2, ',', ' ') }} DT</div>
                        <div style="font-size:.8rem;color:var(--muted)">
                            {{ p.datePaiement|date('d/m/Y à H:i') }} &nbsp;·&nbsp; {{ p.methodePaiement }}
                        </div>
                    </div>
                    <div style="text-align:right">
                        <span class="badge" style="background:rgba(34,197,94,0.1);color:#15803d;padding:.4rem .8rem;font-weight:700;border-radius:50px;">
                            {{ p.statutPaiement == 'Payé' ? 'Payé' : 'Terminé' }}
                        </span>
                        <div style="font-size:.7rem;color:var(--muted);margin-top:.3rem">Réservation #{{ p.reservation.id }}</div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
