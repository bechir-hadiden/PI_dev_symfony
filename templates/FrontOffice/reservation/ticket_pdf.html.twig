<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Billet de Réservation - SmartTrip</title>
    <style>
        body { font-family: 'Helvetica', 'Arial', sans-serif; color: #0d1b2a; margin: 0; padding: 0; }
        .ticket-container { width: 100%; max-width: 600px; margin: 20px auto; border: 2px solid #0d1b2a; border-radius: 12px; overflow: hidden; }
        .header { background-color: #0d1b2a; color: #ffffff; padding: 20px; text-align: center; }
        .header h1 { margin: 0; font-size: 24px; color: #c9a84c; }
        .header p { margin: 5px 0 0; font-size: 14px; opacity: 0.8; }
        .content { padding: 30px; position: relative; }
        .client-info { margin-bottom: 25px; border-bottom: 1px dashed #ccc; padding-bottom: 15px; }
        .client-info h2 { font-size: 18px; margin: 0 0 10px; color: #c9a84c; }
        .transport-details { width: 100%; margin-bottom: 20px; border-collapse: collapse; }
        .label { font-weight: bold; padding: 8px 0; width: 40%; color: #7a8a99; font-size: 14px; }
        .value { padding: 8px 0; font-size: 15px; font-weight: bold; }
        .price-box { border: 2px solid #c9a84c; border-radius: 8px; padding: 20px; text-align: center; margin-top: 20px; }
        .price-label { font-size: 12px; text-transform: uppercase; color: #7a8a99; margin-bottom: 5px; }
        .price-value { font-size: 28px; font-weight: bold; color: #0d1b2a; }
        .footer { background-color: #f5f0e8; padding: 15px; text-align: center; font-size: 11px; color: #7a8a99; border-top: 1px solid #ddd; }
        .qr-placeholder { position: absolute; right: 30px; top: 180px; width: 100px; height: 100px; border: 1px solid #ddd; text-align: center; line-height: 100px; font-size: 10px; color: #ccc; }
    </style>
</head>
<body>

    <div class="ticket-container">
        <div class="header">
            <h1>SmartTrip</h1>
            <p>BON DE RÉSERVATION OFFICIEL</p>
        </div>

        <div class="content">
            <!-- QR Placeholder (Disabled remote temporarily for debugging) -->
            <div class="qr-placeholder" style="background:#eee;border:1px dashed #ccc;display:flex;align-items:center;justify-content:center;font-size:10px;color:#999">
                QR CODE
            </div>

            <div class="client-info">
                <h2>Informations Passager</h2>
                <table style="width: 100%;">
                    <tr>
                        <td class="label">Nom complet :</td>
                        <td class="value">{{ reservation.nomClient }}</td>
                    </tr>
                    <tr>
                        <td class="label">Email :</td>
                        <td class="value">{{ reservation.emailClient }}</td>
                    </tr>
                </table>
            </div>

            <table class="transport-details">
                <tr>
                    <td class="label">Compagnie :</td>
                    <td class="value">{{ reservation.transport.compagnie }}</td>
                </tr>
                <tr>
                    <td class="label">Type de transport :</td>
                    <td class="value">{{ reservation.transport.transportType.nom }}</td>
                </tr>
                <tr>
                    <td class="label">Numéro véhicule :</td>
                    <td class="value">{{ reservation.transport.numero }}</td>
                </tr>
                <tr>
                    <td class="label">Date de réservation :</td>
                    <td class="value">{{ reservation.dateReservation|date('d/m/Y à H:i') }}</td>
                </tr>
                <tr>
                    <td class="label">Nombre de places :</td>
                    <td class="value">{{ reservation.nombrePlaces }}</td>
                </tr>
            </table>

            <div class="price-box">
                <div class="price-label">Montant Total Payé</div>
                <div class="price-value">{{ reservation.montantTotal|number_format(2, ',', ' ') }} DT</div>
            </div>
        </div>

        <div class="footer">
            <p>Ce document fait office de billet officiel. Présentez-le lors de l'embarquement.</p>
            <p>Support : contact@smarttrip.com | Site : www.smarttrip.com</p>
        </div>
    </div>

</body>
</html>
