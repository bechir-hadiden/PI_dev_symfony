{% extends 'FrontOffice/base_user.html.twig' %}
{% block title %}Mes Réservations – SmartTrip{% endblock %}

{% block body %}
<div class="wrap">
  <div class="page-header">
    <h1><i class="fas fa-calendar-check" style="color:var(--gold);margin-right:.5rem"></i>Mes Réservations</h1>
    <p>Consultez et gérez vos réservations de transport.</p>
  </div>

  <!-- Email lookup -->
  <div style="background:#fff;border:1px solid var(--border);border-radius:14px;padding:1.4rem;margin-bottom:1.8rem;max-width:500px">
    <form method="GET" action="{{ path('mes_reservations_index') }}" style="display:flex;gap:.6rem;align-items:flex-end">
      <div style="flex:1">
        <label style="display:block;font-size:.73rem;font-weight:600;color:var(--muted);margin-bottom:.35rem;text-transform:uppercase;letter-spacing:.4px">Votre email</label>
        <input type="email" name="email" value="{{ email }}" placeholder="votre@email.com"
          style="width:100%;padding:.6rem .9rem;border:1px solid var(--border);border-radius:8px;font-size:.875rem;outline:none"
          onfocus="this.style.borderColor='var(--gold)'" onblur="this.style.borderColor='var(--border)'">
      </div>
      <button type="submit" class="btn btn-nav"><i class="fas fa-search"></i> Rechercher</button>
    </form>
  </div>

  {% if email and pagination is empty %}
    <div style="text-align:center;padding:3rem;color:var(--muted)">
      <i class="fas fa-inbox" style="font-size:3rem;opacity:.2;display:block;margin-bottom:1rem"></i>
      <p>Aucune réservation trouvée pour <strong>{{ email }}</strong>.</p>
      <a href="{{ path('transport_index') }}" style="color:var(--gold);margin-top:.6rem;display:inline-block"><i class="fas fa-bus-alt"></i> Découvrir nos transports</a>
    </div>

  {% elseif not email %}
    <div style="text-align:center;padding:3rem;color:var(--muted)">
      <i class="fas fa-envelope-open-text" style="font-size:3rem;opacity:.2;display:block;margin-bottom:1rem"></i>
      <p>Saisissez votre email pour retrouver vos réservations.</p>
    </div>

  {% else %}
    <div style="margin-bottom:.8rem;color:var(--muted);font-size:.85rem">
      <i class="fas fa-list" style="color:var(--gold)"></i> {{ pagination.totalItemCount }} réservation(s) pour <strong>{{ email }}</strong>
    </div>

    <div style="display:flex;flex-direction:column;gap:1rem">
      {% for r in pagination %}
      <div style="background:#fff;border:1px solid var(--border);border-radius:14px;overflow:hidden;display:flex;align-items:stretch">

        <!-- color bar by status -->
        <div style="width:5px;background:{% if r.statut == 'confirmee' %}var(--green){% elseif r.statut == 'annulee' %}var(--red){% else %}var(--gold){% endif %}"></div>

        <!-- image -->
        <div style="width:100px;flex-shrink:0;overflow:hidden">
          {% if r.transport.imageUrl %}
            <img src="{{ r.transport.imageUrl }}" alt="{{ r.transport.compagnie }}" style="width:100%;height:100%;object-fit:cover">
          {% else %}
            <div style="width:100%;height:100%;background:linear-gradient(135deg,var(--navy),var(--navy-2));display:flex;align-items:center;justify-content:center;color:var(--gold);font-size:1.8rem">
              <i class="fas fa-bus-alt"></i>
            </div>
          {% endif %}
        </div>

        <!-- content -->
        <div style="flex:1;padding:1rem 1.2rem;display:flex;justify-content:space-between;align-items:center;gap:1rem;flex-wrap:wrap">
          <div>
            <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.3rem">
              <strong style="font-size:.95rem">{{ r.transport.compagnie }}</strong>
              <span class="badge" style="background:rgba(201,168,76,0.1);color:var(--gold)">{{ r.transport.transportType.nom }}</span>
            </div>
            <div style="font-size:.8rem;color:var(--muted)">
              <i class="fas fa-hashtag" style="color:var(--gold)"></i> {{ r.transport.numero }} &nbsp;·&nbsp;
              <i class="fas fa-users" style="color:var(--gold)"></i> {{ r.nombrePlaces }} place(s) &nbsp;·&nbsp;
              <i class="fas fa-calendar" style="color:var(--gold)"></i> {{ r.dateReservation|date('d/m/Y à H:i') }}
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:1rem">
            <div style="text-align:right">
              <div style="font-size:1.1rem;font-weight:700;color:var(--gold)">{{ r.montantTotal|number_format(2, ',', ' ') }} DT</div>
              {% if r.statut == 'confirmee' %}
                <span class="badge badge-confirm">Confirmée</span>
              {% elseif r.statut == 'annulee' %}
                <span class="badge badge-cancel">Annulée</span>
              {% else %}
                <span class="badge badge-pending">En attente</span>
              {% endif %}
            </div>
            <div style="display:flex;gap:.5rem;align-items:center">
              {% if r.statut != 'annulee' %}
                <a href="{{ path('mes_reservations_download_ticket', {id: r.id}) }}" class="btn" style="background:#0d1b2a;color:var(--gold);border-radius:8px;padding:.4rem .9rem;font-size:.78rem;font-weight:600;text-decoration:none">
                  <i class="fas fa-file-pdf"></i> Billet
                </a>
                <form method="POST" action="{{ path('mes_reservations_cancel', {id: r.id}) }}" onsubmit="return confirm('Annuler cette réservation ?')">
                  <input type="hidden" name="_token" value="{{ csrf_token('cancel_reservation_' ~ r.id) }}">
                  <input type="hidden" name="email" value="{{ email }}">
                  <button type="submit" class="btn btn-danger-sm"><i class="fas fa-times"></i> Annuler</button>
                </form>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
    
    <div style="display:flex; justify-content:center; margin-top:2rem;">
      {{ knp_pagination_render(pagination) }}
    </div>
  {% endif %}

  <div style="margin-top:2rem">
    <a href="{{ path('transport_index') }}" class="btn btn-nav"><i class="fas fa-bus-alt"></i> Réserver un transport</a>
  </div>
</div>
{% endblock %}
