{% extends 'base.html.twig' %}
{% block title %}Set New Password{% endblock %}

{% block extra_css %}
.reset-page { min-height:100vh; display:grid; grid-template-columns:1fr 1fr; padding-top:0!important; }
.reset-left { background:var(--ink); position:relative; overflow:hidden; display:flex; flex-direction:column; justify-content:flex-end; padding:3rem; }
.reset-left-bg { position:absolute; inset:0; background:url('https://images.unsplash.com/photo-1566073771259-6a8506099945?w=900&q=80') center/cover; opacity:0.22; }
.reset-left-content { position:relative; z-index:1; }
.reset-left h2 { font-size:clamp(1.8rem,2.5vw,2.5rem); color:var(--white); font-weight:300; line-height:1.2; margin-bottom:0.8rem; }
.reset-left h2 em { color:var(--gold-lt); }
.reset-left p { color:rgba(240,232,216,0.6); font-size:0.86rem; line-height:1.7; max-width:320px; }
.reset-logo { font-family:'Cormorant Garamond',serif; font-size:1.5rem; font-weight:300; letter-spacing:0.12em; color:var(--white); text-decoration:none; margin-bottom:auto; padding-bottom:3rem; display:block; }
.reset-logo span { color:var(--gold-lt); font-style:italic; }
.reset-right { display:flex; flex-direction:column; justify-content:center; align-items:center; padding:3rem 4rem; background:var(--cream); }
.reset-wrap { max-width:400px; width:100%; }
.step-dot { width:32px; height:32px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.72rem; font-weight:500; border:1.5px solid var(--border); color:var(--muted); background:var(--cream); position:relative; z-index:1; transition:all 0.3s; }
.step-dot.active { background:var(--gold); border-color:var(--gold); color:var(--white); }
.step-dot.done { background:var(--ink); border-color:var(--ink); color:var(--white); }
.step-line { width:60px; height:1px; background:var(--border); }
.step-label { font-size:0.62rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--muted); text-align:center; margin-top:0.3rem; }
.steps-row { display:flex; flex-direction:column; align-items:center; }

/* Password strength bar */
.strength-bar { height: 3px; background: var(--border); margin-top: 0.5rem; border-radius: 2px; overflow: hidden; }
.strength-fill { height: 100%; width: 0; transition: width 0.3s, background 0.3s; }
.strength-label { font-size: 0.68rem; color: var(--muted); margin-top: 0.3rem; text-align: right; }

/* Password toggle eye */
.pw-wrap { position: relative; }
.pw-toggle { position: absolute; right: 0.8rem; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: var(--muted); font-size: 0.85rem; padding: 0; }
.pw-toggle:hover { color: var(--gold); }

/* Requirements checklist */
.requirements { margin-top: 0.6rem; }
.req-item { font-size: 0.72rem; color: var(--muted); display: flex; align-items: center; gap: 0.4rem; padding: 0.15rem 0; transition: color 0.2s; }
.req-item .dot { width: 5px; height: 5px; border-radius: 50%; background: var(--border); transition: background 0.2s; flex-shrink: 0; }
.req-item.met { color: var(--success); }
.req-item.met .dot { background: var(--success); }

@media (max-width: 768px) {
    .reset-page { grid-template-columns: 1fr; }
    .reset-left { display: none; }
    .reset-right { padding: 2rem 1.5rem; }
}
{% endblock %}

{% block body %}
<div class="reset-page" style="padding-top:0!important;">

    <div class="reset-left">
        <div class="reset-left-bg"></div>
        <a href="{{ path('app_login') }}" class="reset-logo">Smart<span>Trip</span></a>
        <div class="reset-left-content">
            <h2>Almost there —<br>create a <em>strong</em><br>new password.</h2>
            <p>Use at least 8 characters including uppercase, lowercase, a number, and a special character.</p>
        </div>
    </div>

    <div class="reset-right">
        <div class="reset-wrap">

            {# Steps indicator #}
            <div class="steps-indicator" style="display:flex;align-items:flex-start;margin-bottom:2.5rem;">
                <div class="steps-row">
                    <div class="step-dot done">✓</div>
                    <div class="step-label">Email</div>
                </div>
                <div class="step-line" style="margin-top:16px;"></div>
                <div class="steps-row">
                    <div class="step-dot done">✓</div>
                    <div class="step-label">Verify</div>
                </div>
                <div class="step-line" style="margin-top:16px;"></div>
                <div class="steps-row">
                    <div class="step-dot active">3</div>
                    <div class="step-label">Password</div>
                </div>
            </div>

            <div class="section-tag" style="margin-bottom:0.8rem;">Step 3 of 3</div>
            <h1 style="font-size:1.9rem;margin-bottom:0.4rem;">New Password</h1>
            <p style="color:var(--muted);font-size:0.88rem;margin-bottom:2rem;">
                Choose a strong password you haven't used before.
            </p>

            {% if error %}
            <div class="flash flash-error" style="position:static;margin-bottom:1.2rem;">{{ error }}</div>
            {% endif %}

            <form method="post" action="{{ path('password_reset_new_password') }}" novalidate>

                <div class="form-group">
                    <label class="form-label" for="password">New Password</label>
                    <div class="pw-wrap">
                        <input
                            type="password"
                            id="password"
                            name="password"
                            class="form-control"
                            placeholder="Min. 8 characters"
                            autocomplete="new-password"
                            autofocus
                            required
                        >
                        <button type="button" class="pw-toggle" onclick="togglePw('password', this)">👁</button>
                    </div>
                    {# Strength bar #}
                    <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
                    <div class="strength-label" id="strengthLabel"></div>
                    {# Requirements #}
                    <div class="requirements">
                        <div class="req-item" id="req-len"><span class="dot"></span> At least 8 characters</div>
                        <div class="req-item" id="req-upper"><span class="dot"></span> One uppercase letter</div>
                        <div class="req-item" id="req-lower"><span class="dot"></span> One lowercase letter</div>
                        <div class="req-item" id="req-num"><span class="dot"></span> One number</div>
                        <div class="req-item" id="req-sym"><span class="dot"></span> One special character</div>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" for="password_confirm">Confirm Password</label>
                    <div class="pw-wrap">
                        <input
                            type="password"
                            id="password_confirm"
                            name="password_confirm"
                            class="form-control"
                            placeholder="Repeat your password"
                            autocomplete="new-password"
                            required
                        >
                        <button type="button" class="pw-toggle" onclick="togglePw('password_confirm', this)">👁</button>
                    </div>
                    <div class="form-error" id="matchError" style="display:none;">Passwords do not match.</div>
                </div>

                <button type="submit" class="btn btn-primary w-100" style="justify-content:center;margin-top:0.5rem;" id="submitBtn">
                    Set New Password →
                </button>
            </form>

        </div>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
function togglePw(id, btn) {
    const input = document.getElementById(id);
    input.type = input.type === 'password' ? 'text' : 'password';
    btn.textContent = input.type === 'password' ? '👁' : '🙈';
}

const pwInput   = document.getElementById('password');
const confirmPw = document.getElementById('password_confirm');
const matchErr  = document.getElementById('matchError');

// Requirements check
function checkRequirements(val) {
    const checks = {
        'req-len':   val.length >= 8,
        'req-upper': /[A-Z]/.test(val),
        'req-lower': /[a-z]/.test(val),
        'req-num':   /\d/.test(val),
        'req-sym':   /[\W_]/.test(val),
    };
    let met = 0;
    for (const [id, ok] of Object.entries(checks)) {
        const el = document.getElementById(id);
        el.classList.toggle('met', ok);
        if (ok) met++;
    }
    return met;
}

// Strength bar
pwInput.addEventListener('input', () => {
    const val  = pwInput.value;
    const met  = checkRequirements(val);
    const fill = document.getElementById('strengthFill');
    const lbl  = document.getElementById('strengthLabel');

    const pct    = (met / 5) * 100;
    const colors = ['', '#c0392b', '#e67e22', '#f1c40f', '#2d7a4f', '#2d7a4f'];
    const labels = ['', 'Very Weak', 'Weak', 'Fair', 'Strong', 'Very Strong'];

    fill.style.width = pct + '%';
    fill.style.background = met > 0 ? colors[met] : '';
    lbl.textContent = met > 0 ? labels[met] : '';
    lbl.style.color = met > 0 ? colors[met] : 'var(--muted)';
});

// Confirm match
confirmPw.addEventListener('input', () => {
    matchErr.style.display = (confirmPw.value && confirmPw.value !== pwInput.value) ? 'block' : 'none';
});
</script>
{% endblock %}
