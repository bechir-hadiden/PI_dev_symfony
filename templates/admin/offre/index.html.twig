{% extends 'BackOffice/base_admin.html.twig' %}

{% block title %}SmartTrip - Gestion des Promotions{% endblock %}

{% block body %}

{# ═══════════════════════════════════════════════
   STYLES
═══════════════════════════════════════════════ #}
<style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=Syne:wght@600;700;800&display=swap');

    .promo-page * { box-sizing: border-box; }
    .promo-page { font-family: 'DM Sans', sans-serif; }

    /* ── PAGE HEADER ── */
    .promo-page-title {
        font-family: 'Syne', sans-serif;
        font-size: 26px;
        font-weight: 700;
        color: #0d1b2a;
        line-height: 1.2;
        margin: 0;
    }
    .promo-page-sub {
        font-size: 13px;
        color: #7a8aa0;
        margin-top: 5px;
        margin-bottom: 0;
    }
    .promo-search {
        position: relative;
    }
    .promo-search svg {
        position: absolute;
        left: 13px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        pointer-events: none;
        width: 14px; height: 14px;
    }
    .promo-search-input {
        background: #fff;
        border: 1.5px solid #eaeff7;
        border-radius: 11px;
        padding: 10px 16px 10px 38px;
        font-size: 13px;
        font-family: 'DM Sans', sans-serif;
        color: #0d1b2a;
        width: 260px;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
        height: 42px;
    }
    .promo-search-input::placeholder { color: #b0bac8; }
    .promo-search-input:focus {
        border-color: #c9a84c;
        box-shadow: 0 0 0 3px rgba(201,168,76,0.12);
    }
    .promo-btn-create {
        background: linear-gradient(135deg, #c9a84c 0%, #e8c97a 100%);
        color: #0d1b2a;
        font-family: 'DM Sans', sans-serif;
        font-size: 13px;
        font-weight: 700;
        border: none;
        border-radius: 11px;
        padding: 0 20px;
        height: 42px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        transition: opacity 0.15s, transform 0.1s;
        box-shadow: 0 2px 8px rgba(201,168,76,0.35);
        white-space: nowrap;
    }
    .promo-btn-create:hover { opacity: 0.9; transform: translateY(-1px); color: #0d1b2a; text-decoration: none; }
    .promo-btn-create:active { transform: translateY(0); }

    /* ── STAT CARDS ── */
    .promo-stat-card {
        background: #fff;
        border-radius: 16px;
        padding: 22px;
        border: 1px solid #eaeff7;
        transition: box-shadow 0.2s;
        height: 100%;
    }
    .promo-stat-card:hover { box-shadow: 0 4px 20px rgba(13,27,42,0.06); }
    .promo-stat-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 14px;
    }
    .promo-stat-label {
        font-size: 11px;
        font-weight: 700;
        color: #7a8aa0;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        line-height: 1.4;
    }
    .promo-stat-icon {
        width: 40px; height: 40px;
        border-radius: 11px;
        display: flex; align-items: center; justify-content: center;
        font-size: 17px;
        flex-shrink: 0;
    }
    .si-gold   { background: rgba(201,168,76,0.12); }
    .si-green  { background: rgba(16,185,129,0.12); }
    .si-indigo { background: rgba(99,102,241,0.12); }
    .si-slate  { background: rgba(100,116,139,0.1); }
    .promo-stat-value {
        font-family: 'Syne', sans-serif;
        font-size: 32px;
        font-weight: 700;
        color: #0d1b2a;
        line-height: 1;
        margin-bottom: 6px;
    }
    .sv-green  { color: #10B981; }
    .sv-indigo { color: #6366F1; }
    .sv-slate  { color: #64748b; }
    .promo-stat-desc { font-size: 12px; color: #7a8aa0; }

    /* ── DASHBOARD GRID ── */
    .promo-dashboard-grid {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 16px;
    }

    /* ── CHART CARD ── */
    .promo-chart-card, .promo-odd-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #eaeff7;
        padding: 26px 28px;
    }
    .promo-card-heading {
        font-size: 11px;
        font-weight: 700;
        color: #7a8aa0;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 22px;
    }
    .promo-chart-inner {
        display: flex;
        align-items: center;
        gap: 28px;
    }
    .promo-donut-wrap {
        width: 140px; height: 140px;
        flex-shrink: 0;
        position: relative;
    }
    .promo-donut-center {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        pointer-events: none;
    }
    .promo-donut-num {
        font-family: 'Syne', sans-serif;
        font-size: 22px;
        font-weight: 700;
        color: #0d1b2a;
    }
    .promo-donut-label { font-size: 10px; color: #7a8aa0; margin-top: 1px; }
    .promo-legend-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 13px; flex: 1; }
    .promo-legend-item { display: flex; align-items: center; gap: 10px; font-size: 13px; color: #475569; }
    .promo-legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .promo-legend-name { flex: 1; }
    .promo-legend-bar-bg { height: 4px; background: #edf0f7; border-radius: 99px; overflow: hidden; width: 80px; }
    .promo-legend-bar { height: 100%; border-radius: 99px; }
    .promo-legend-count { font-weight: 700; color: #0d1b2a; font-size: 14px; min-width: 14px; text-align: right; }

    /* ── ODD CARD ── */
    .promo-odd-card { display: flex; flex-direction: column; }
    .promo-odd-banner {
        display: flex; align-items: center; gap: 13px;
        background: linear-gradient(135deg, #f0fdf8, #dcfce7);
        border: 1px solid #bbf7d0;
        border-radius: 13px;
        padding: 14px 16px;
        margin-bottom: 20px;
    }
    .promo-odd-banner-icon { font-size: 24px; line-height: 1; }
    .promo-odd-banner-title { font-weight: 700; font-size: 15px; color: #166534; line-height: 1.2; }
    .promo-odd-banner-sub { font-size: 12px; color: #16a34a; margin-top: 3px; }
    .promo-odd-big {
        font-family: 'Syne', sans-serif;
        font-size: 52px; font-weight: 800;
        color: #10B981;
        text-align: center; line-height: 1;
        margin-bottom: 8px;
    }
    .promo-odd-caption { font-size: 12.5px; color: #7a8aa0; text-align: center; line-height: 1.5; margin-bottom: 18px; }
    .promo-odd-progress-wrap { margin-top: auto; }
    .promo-odd-progress-header { display: flex; justify-content: space-between; font-size: 11px; color: #7a8aa0; margin-bottom: 6px; }
    .promo-odd-progress-bg { height: 8px; background: #e2e8f0; border-radius: 99px; overflow: hidden; }
    .promo-odd-progress-bar { height: 100%; background: linear-gradient(90deg, #10B981, #34d399); border-radius: 99px; }

    /* ── TABLE ── */
    .promo-table-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #eaeff7;
        overflow: hidden;
    }
    .promo-table-card table { width: 100%; border-collapse: collapse; }
    .promo-table-card thead tr { background: #F8FAFD; border-bottom: 1.5px solid #eaeff7; }
    .promo-table-card th {
        padding: 14px 16px;
        font-size: 11px; font-weight: 700;
        color: #7a8aa0;
        text-transform: uppercase; letter-spacing: 0.7px;
        text-align: left; white-space: nowrap;
    }
    .promo-table-card th:first-child { padding-left: 28px; }
    .promo-table-card th:last-child  { text-align: right; padding-right: 28px; }
    .promo-table-card td {
        padding: 16px; font-size: 13.5px;
        color: #475569;
        border-bottom: 1px solid #f1f5fb;
        vertical-align: middle;
    }
    .promo-table-card td:first-child { padding-left: 28px; }
    .promo-table-card td:last-child  { padding-right: 28px; }
    .promo-table-card tbody tr { transition: background 0.12s; }
    .promo-table-card tbody tr:hover td { background: #fafbff; }
    .promo-table-card tbody tr:last-child td { border-bottom: none; }

    /* KNP sort links */
    .promo-table-card th a {
        color: #7a8aa0 !important;
        text-decoration: none !important;
        text-transform: uppercase;
        font-size: 11px; font-weight: 700;
        letter-spacing: 0.7px;
        transition: color 0.15s;
    }
    .promo-table-card th a:hover { color: #c9a84c !important; }

    .td-id { font-weight: 600; font-size: 12px; color: #c9a84c; }
    .td-title { font-weight: 600; color: #0d1b2a; font-size: 14px; }

    .badge-remise {
        background: rgba(201,168,76,0.12); color: #9a7a2e;
        font-size: 12px; font-weight: 600;
        padding: 4px 11px; border-radius: 99px; display: inline-block;
    }
    .badge-active {
        background: #EFF6FF; color: #1D4ED8;
        font-size: 11px; font-weight: 600; letter-spacing: 0.3px;
        padding: 4px 11px; border-radius: 99px; display: inline-block;
    }
    .badge-local {
        background: #DCFCE7; color: #166534;
        font-size: 11px; font-weight: 600;
        padding: 4px 11px; border-radius: 99px; display: inline-block;
    }
    .td-std { color: #b0bac8; font-size: 12px; display: flex; align-items: center; gap: 6px; }
    .td-std::before {
        content: '';
        display: inline-block;
        width: 14px; height: 1.5px;
        background: #cbd5e1; border-radius: 99px;
    }

    /* Action buttons */
    .promo-actions { display: flex; gap: 7px; justify-content: flex-end; align-items: center; flex-wrap: nowrap; }
    .promo-btn {
        font-family: 'DM Sans', sans-serif;
        font-size: 11.5px; font-weight: 600;
        padding: 6px 13px; border-radius: 9px; border: none; cursor: pointer;
        display: inline-flex; align-items: center; gap: 5px;
        transition: all 0.15s; text-decoration: none; white-space: nowrap;
    }
    .pb-coupon { background: #EEF2FF; color: #4338CA; }
    .pb-coupon:hover { background: #e0e7ff; color: #4338CA; text-decoration: none; }
    .pb-edit { background: #F1F5F9; color: #475569; border: 1px solid #e2e8f0 !important; }
    .pb-edit:hover { background: #e8edf5; color: #475569; text-decoration: none; }

    /* Delete form override */
    .promo-actions form { margin: 0 !important; padding: 0 !important; display: inline-flex !important; align-items: center; }
    .promo-actions form button {
        background: #FEF2F2 !important; color: #DC2626 !important;
        border: none !important; border-radius: 9px !important;
        padding: 6px 13px !important; font-size: 11.5px !important;
        font-weight: 600 !important; font-family: 'DM Sans', sans-serif !important;
        cursor: pointer; transition: all 0.15s;
        display: inline-flex; align-items: center; gap: 5px;
    }
    .promo-actions form button:hover { background: #fee2e2 !important; color: #b91c1c !important; }

    /* ── PAGINATION ── */
    .promo-pagination { display: flex; align-items: center; justify-content: center; gap: 7px; }
    .promo-pagination ul { display: flex; list-style: none; padding: 0; margin: 0; gap: 7px; }
    .promo-pagination li a,
    .promo-pagination li span {
        font-family: 'DM Sans', sans-serif;
        font-size: 13px; font-weight: 500;
        padding: 7px 15px; border-radius: 9px;
        border: 1.5px solid #eaeff7;
        background: #fff; color: #64748b;
        text-decoration: none; display: block;
        transition: all 0.15s;
    }
    .promo-pagination li a:hover { background: #F1F5F9; border-color: #d0d8e4; }
    .promo-pagination li.active span,
    .promo-pagination li.current span {
        background: #0d1b2a; color: #c9a84c;
        border-color: #0d1b2a; font-weight: 700;
    }
</style>

{# ═══════════════════════════════════════════════
   PAGE WRAPPER
═══════════════════════════════════════════════ #}
<div class="promo-page container-fluid py-4 px-lg-5" style="background-color: #F2F5FA; min-height: 100vh;">

    {# ── 1. HEADER ── #}
    <div class="d-flex flex-wrap justify-content-between align-items-start mb-4 gap-3">
        <div>
            <h1 class="promo-page-title">Gestion des promotions</h1>
            <p class="promo-page-sub">Pilotez vos campagnes et analysez l'impact ODD 8</p>
        </div>
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <div class="promo-search">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                </svg>
                <input type="text" id="adminSearch" class="promo-search-input" placeholder="Rechercher une offre...">
            </div>
            <a href="{{ path('app_offre_new') }}" class="promo-btn-create">
                <i class="fas fa-plus" style="font-size:12px;"></i> Créer une Offre
            </a>
        </div>
    </div>

    {# ── 2. STAT CARDS ── #}
    {% set totalOffres = offres.getTotalItemCount %}
    {% set totalLocal  = allOffres|filter(o => o.isLocalSupport)|length %}
    {% set totalAll    = allOffres|length %}
    {% set oddPercent  = totalAll > 0 ? ((totalLocal / totalAll) * 100)|round : 0 %}

    {# Compute average discount #}
    {% set sumRemise = 0 %}
    {% for o in allOffres %}{% set sumRemise = sumRemise + o.tauxRemise %}{% endfor %}
    {% set avgRemise = totalAll > 0 ? (sumRemise / totalAll)|round : 0 %}

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="promo-stat-card">
                <div class="promo-stat-top">
                    <div class="promo-stat-label">Total<br>Offres</div>
                    <div class="promo-stat-icon si-gold">🏷️</div>
                </div>
                <div class="promo-stat-value">{{ totalOffres }}</div>
                <div class="promo-stat-desc">Offres actives</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="promo-stat-card">
                <div class="promo-stat-top">
                    <div class="promo-stat-label">Impact<br>ODD 8</div>
                    <div class="promo-stat-icon si-green">🤝</div>
                </div>
                <div class="promo-stat-value sv-green">{{ totalLocal }}</div>
                <div class="promo-stat-desc">Soutien local actif</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="promo-stat-card">
                <div class="promo-stat-top">
                    <div class="promo-stat-label">Remise<br>Moyenne</div>
                    <div class="promo-stat-icon si-indigo">📊</div>
                </div>
                <div class="promo-stat-value sv-indigo">-{{ avgRemise }}%</div>
                <div class="promo-stat-desc">Sur toutes les offres</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="promo-stat-card">
                <div class="promo-stat-top">
                    <div class="promo-stat-label">Coupons<br>Émis</div>
                    <div class="promo-stat-icon si-slate">🎟️</div>
                </div>
                <div class="promo-stat-value sv-slate">{{ stats.totalCoupons ?? 'N/A' }}</div>xamp
                <div class="promo-stat-desc">Ce mois-ci</div>
            </div>
        </div>
    </div>

    {# ── 3. DASHBOARD GRID: Chart + ODD ── #}
    <div class="promo-dashboard-grid mb-4">

        {# Chart Card #}
        <div class="promo-chart-card">
            <div class="promo-card-heading">Répartition par catégorie</div>
            <div class="promo-chart-inner">
                <div class="promo-donut-wrap">
                    <canvas id="statChart" width="140" height="140"></canvas>
                    <div class="promo-donut-center">
                        <span class="promo-donut-num">{{ totalAll }}</span>
                        <span class="promo-donut-label">offres</span>
                    </div>
                </div>
                {% set nbHotel     = allOffres|filter(o => o.category == 'HOTEL')|length %}
                {% set nbVol       = allOffres|filter(o => o.category == 'VOL')|length %}
                {% set nbTransport = allOffres|filter(o => o.category == 'TRANSPORT')|length %}
                {% set nbVoyage    = allOffres|filter(o => o.category == 'VOYAGE' or o.category is null)|length %}
                <ul class="promo-legend-list">
                    <li class="promo-legend-item">
                        <span class="promo-legend-dot" style="background:#c9a84c;"></span>
                        <span class="promo-legend-name">Hôtels</span>
                        <div class="promo-legend-bar-bg"><div class="promo-legend-bar" style="background:#c9a84c; width:{{ totalAll > 0 ? ((nbHotel/totalAll)*100)|round : 0 }}%;"></div></div>
                        <span class="promo-legend-count">{{ nbHotel }}</span>
                    </li>
                    <li class="promo-legend-item">
                        <span class="promo-legend-dot" style="background:#0d1b2a;"></span>
                        <span class="promo-legend-name">Vols</span>
                        <div class="promo-legend-bar-bg"><div class="promo-legend-bar" style="background:#0d1b2a; width:{{ totalAll > 0 ? ((nbVol/totalAll)*100)|round : 0 }}%;"></div></div>
                        <span class="promo-legend-count">{{ nbVol }}</span>
                    </li>
                    <li class="promo-legend-item">
                        <span class="promo-legend-dot" style="background:#10B981;"></span>
                        <span class="promo-legend-name">Transports</span>
                        <div class="promo-legend-bar-bg"><div class="promo-legend-bar" style="background:#10B981; width:{{ totalAll > 0 ? ((nbTransport/totalAll)*100)|round : 0 }}%;"></div></div>
                        <span class="promo-legend-count">{{ nbTransport }}</span>
                    </li>
                    <li class="promo-legend-item">
                        <span class="promo-legend-dot" style="background:#94a3b8;"></span>
                        <span class="promo-legend-name">Voyages</span>
                        <div class="promo-legend-bar-bg"><div class="promo-legend-bar" style="background:#94a3b8; width:{{ totalAll > 0 ? ((nbVoyage/totalAll)*100)|round : 0 }}%;"></div></div>
                        <span class="promo-legend-count">{{ nbVoyage }}</span>
                    </li>
                </ul>
            </div>
        </div>

        {# ODD 8 Card #}
        <div class="promo-odd-card">
            <div class="promo-odd-banner">
                <span class="promo-odd-banner-icon">🌍</span>
                <div>
                    <div class="promo-odd-banner-title">Impact ODD 8</div>
                    <div class="promo-odd-banner-sub">Travail décent &amp; croissance</div>
                </div>
            </div>
            <div class="promo-odd-big">{{ oddPercent }}%</div>
            <div class="promo-odd-caption">des offres soutiennent l'économie locale</div>
            <div class="promo-odd-progress-wrap">
                <div class="promo-odd-progress-header">
                    <span>Progression</span>
                    <span style="font-weight:700; color:#10B981;">{{ totalLocal }} / {{ totalAll }}</span>
                </div>
                <div class="promo-odd-progress-bg">
                    <div class="promo-odd-progress-bar" style="width: {{ oddPercent }}%;"></div>
                </div>
            </div>
        </div>

    </div>

    {# ── 4. TABLE ── #}
    <div class="promo-table-card mb-4">
        <table>
            <thead>
                <tr>
                    <th>{{ knp_pagination_sortable(offres, 'ID', 'o.id') }}</th>
                    <th>{{ knp_pagination_sortable(offres, 'Titre', 'o.titre') }}</th>
                    <th>{{ knp_pagination_sortable(offres, 'Remise', 'o.tauxRemise') }}</th>
                    <th>Statut</th>
                    <th>Impact ODD 8</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="offreTableBody">
                {% for o in offres %}
                <tr class="offre-row">
                    <td class="td-id">#{{ o.id }}</td>
                    <td class="td-title offre-titre">{{ o.titre }}</td>
                    <td><span class="badge-remise">-{{ o.tauxRemise }}%</span></td>
                    <td><span class="badge-active">ACTIVE</span></td>
                    <td>
                        {% if o.isLocalSupport %}
                            <span class="badge-local">🤝 Soutien Local</span>
                        {% else %}
                            <span class="td-std">Standard</span>
                        {% endif %}
                    </td>
                    <td>
                        <div class="promo-actions">
                            <a href="{{ path('app_admin_offre_coupons', {'id': o.id}) }}" class="promo-btn pb-coupon">
                                🎟️ Coupons
                            </a>
                            <a href="{{ path('app_offre_edit', {'id': o.id}) }}" class="promo-btn pb-edit">
                                <i class="fas fa-edit" style="font-size:11px;"></i> Modifier
                            </a>
                            {{ include('offre/_delete_form.html.twig', {'offre': o}) }}
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="6" class="text-center py-5" style="color:#b0bac8; font-size:14px;">
                        Aucune offre trouvée.
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# ── 5. PAGINATION ── #}
    <div class="promo-pagination mt-3">
        {{ knp_pagination_render(offres) }}
    </div>

</div>

{# ═══════════════════════════════════════════════
   SCRIPTS
═══════════════════════════════════════════════ #}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {

    // ── SEARCH ──
    const searchInput = document.getElementById('adminSearch');
    const rows = document.querySelectorAll('.offre-row');
    if (searchInput) {
        searchInput.addEventListener('input', function () {
            const q = this.value.toLowerCase().trim();
            rows.forEach(row => {
                const title = row.querySelector('.offre-titre');
                if (title) row.style.display = title.textContent.toLowerCase().includes(q) ? '' : 'none';
            });
        });
    }

    // ── DONUT CHART ──
    const ctx = document.getElementById('statChart');
    if (ctx) {
        const existing = Chart.getChart('statChart');
        if (existing) existing.destroy();
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Hôtels', 'Vols', 'Transports', 'Voyages'],
                datasets: [{
                    data: [
                        {{ nbHotel }},
                        {{ nbVol }},
                        {{ nbTransport }},
                        {{ nbVoyage }}
                    ],
                    backgroundColor: ['#c9a84c', '#0d1b2a', '#10B981', '#94a3b8'],
                    borderWidth: 0,
                    hoverOffset: 5
                }]
            },
            options: {
                cutout: '72%',
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: ctx => ` ${ctx.label} : ${ctx.raw} offre${ctx.raw > 1 ? 's' : ''}`
                        }
                    }
                },
                maintainAspectRatio: false
            }
        });
    }
});
</script>

{% endblock %}
