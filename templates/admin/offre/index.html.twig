{% extends 'base.html.twig' %}

{% block title %}SmartTrip - Admin Dashboard{% endblock %}

{% block body %}
<div class="container-fluid py-4" style="background-color: #F4F7FB; min-height: 100vh;">
    
    <!-- En-tête -->
    <div class="d-flex justify-content-between align-items-center mb-4 px-4">
        <h1 class="label-title">Gestion des promotions</h1>
        <div class="d-flex gap-3">
            <!-- ID ajouté pour le script de recherche -->
            <input type="text" id="adminSearch" class="form-control rounded-pill" placeholder="Rechercher par titre..." style="width: 250px;">
            <a href="{{ path('app_offre_new') }}" class="btn btn-primary rounded-pill px-4" style="background-color: #1A73E8; border: none;">
                + Créer une Offre
            </a>
        </div>
    </div>

    <!-- 1. ZONE STATISTIQUES -->
    <div class="row g-4 mb-4 px-4">
        <div class="col-md-4">
            <div class="bg-white rounded-4 shadow-sm p-4 h-100 border-0">
                <h6 class="text-muted fw-bold small mb-3">ANALYSE DES OFFRES</h6>
                <div class="mb-3">
                    <span class="text-muted">Total Offres : </span>
                    <span id="totalCounter" class="h4 fw-bold text-primary">{{ offres|length }}</span>
                </div>
                <div>
                    <span class="text-muted">Impact ODD 8 : </span>
                    <span class="h4 fw-bold text-success">
                        {% set countODD = 0 %}
                        {% for o in offres %}{% if o.isLocalSupport %}{% set countODD = countODD + 1 %}{% endif %}{% endfor %}
                        {{ countODD }}
                    </span>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="bg-white rounded-4 shadow-sm p-3 border-0">
                <div class="d-flex justify-content-between align-items-center px-3">
                    <h6 class="fw-bold">Répartition par Catégorie</h6>
                </div>
                <canvas id="statChart" style="max-height: 160px;"></canvas>
            </div>
        </div>
    </div>

    <!-- 2. LA CARTE DU TABLEAU -->
    <div class="mx-4">
        <div class="bg-white rounded-4 shadow-sm border-0 overflow-hidden">
            <table class="table table-hover mb-0 align-middle">
    <thead style="background-color: #F8FAFC;">
        <tr>
            <!-- NOUVEAU : On utilise knp_pagination_sortable pour permettre le tri -->
            <th class="ps-4 text-muted small">
                {{ knp_pagination_sortable(offres, 'ID', 'o.id') }}
            </th>
            <th class="text-muted small">
                {{ knp_pagination_sortable(offres, 'Titre', 'o.titre') }}
            </th>
            <th class="text-muted small text-center">
                {{ knp_pagination_sortable(offres, 'Remise (%)', 'o.tauxRemise') }}
            </th>
            <th class="text-muted small">Statut</th>
            <th class="text-muted small">Impact ODD 8</th>
            <th class="text-end pe-4 text-muted small">Actions</th>
        </tr>
    </thead>
    <tbody id="offreTableBody">
        {% for offre in offres %}
        <tr class="offre-row">
            <td class="ps-4 text-muted">#{{ offre.id }}</td>
            <td class="fw-bold text-dark offre-titre">{{ offre.titre }}</td>
            <td class="text-center">
                <span class="fw-bold text-primary">{{ offre.tauxRemise }}%</span>
            </td>
            <td>
                <span class="badge rounded-pill px-3 py-2" style="background-color: #DBEAFE; color: #1E40AF;">
                    ACTIVE
                </span>
            </td>
            <td>
                {% if offre.isLocalSupport %}
                    <span class="badge rounded-pill px-3 py-2" style="background-color: #DCFCE7; color: #166534;">
                        🤝 Soutien Local
                    </span>
                {% else %}
                    <span class="text-muted small">Standard</span>
                {% endif %}
            </td>
            <td class="text-end pe-4">
                <div class="d-flex gap-2 justify-content-end align-items-center">
                    <a href="{{ path('app_admin_offre_coupons', {'id': offre.id}) }}" 
                       class="btn btn-sm btn-primary rounded-pill px-3 shadow-sm" 
                       style="background-color: #1A73E8; border: none; font-size: 0.85rem;">
                       Coupons 🎟️
                    </a>
                    <a href="{{ path('app_offre_edit', {'id': offre.id}) }}" 
                       class="btn btn-sm btn-light rounded-pill border px-3" 
                       style="font-size: 0.85rem;">
                       Modifier
                    </a>
                    <div style="display: inline-block;">
                        {{ include('offre/_delete_form.html.twig') }}
                    </div>
                </div>
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>
<div class="navigation d-flex justify-content-center mt-4">
    {{ knp_pagination_render(offres) }}
</div>

            <!-- Message si aucun résultat -->
            <div id="noMatch" class="text-center py-4 d-none">
                <p class="text-muted">Aucune promotion ne correspond à votre recherche.</p>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // 1. RECHERCHE DYNAMIQUE (LOGIQUE MÉTIER CLIENT-SIDE)
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('adminSearch');
        const rows = document.querySelectorAll('.offre-row');
        const totalCounter = document.getElementById('totalCounter');
        const noMatch = document.getElementById('noMatch');

        searchInput.addEventListener('input', function() {
            const query = this.value.toLowerCase().trim();
            let visibleCount = 0;

            rows.forEach(row => {
                const title = row.querySelector('.offre-titre').textContent.toLowerCase();
                if (title.includes(query)) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });

            // Mise à jour du compteur en temps réel
            totalCounter.textContent = visibleCount;

            // Affichage du message si vide
            if (visibleCount === 0) noMatch.classList.remove('d-none');
            else noMatch.classList.add('d-none');
        });
    });

    // 2. CONFIGURATION DU GRAPHIQUE
    const ctx = document.getElementById('statChart');
    new Chart(ctx, {
        type: 'pie',
        data: {
            labels: ['Hôtels', 'Vols', 'Transports', 'Voyages'],
            datasets: [{
                data: [
                    {{ offres|filter(o => o.category == 'HOTEL')|length }},
                    {{ offres|filter(o => o.category == 'VOL')|length }},
                    {{ offres|filter(o => o.category == 'TRANSPORT')|length }},
                    {{ offres|filter(o => o.category == 'VOYAGE' or o.category is null)|length }}
                ],
                backgroundColor: ['#1A73E8', '#FF5A1F', '#27AE60', '#64748B'],
                borderWidth: 0
            }]
        },
        options: {
            plugins: {
                legend: { position: 'right', labels: { usePointStyle: true, boxWidth: 10 } }
            },
            maintainAspectRatio: false
        }
    });
</script>
{% endblock %}