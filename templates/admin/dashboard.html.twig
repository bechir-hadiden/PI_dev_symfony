{% extends 'base.html.twig' %}
{% block title %}Admin Dashboard{% endblock %}

{% block extra_css %}
.dashboard { padding: 2.5rem; }
.page-header { margin-bottom: 2.5rem; }
.page-header h1 { font-size: 2.2rem; margin-bottom: 0.3rem; }
.stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--border); margin-bottom: 2.5rem; }
.stat-card { background: var(--white); padding: 1.8rem 1.5rem; }
.stat-num { font-family:'Cormorant Garamond',serif; font-size:2.8rem; font-weight:300; line-height:1; color:var(--ink); }
.stat-label { font-size:0.72rem; letter-spacing:0.15em; text-transform:uppercase; color:var(--muted); margin-top:0.4rem; }
.stat-card.gold .stat-num { color:var(--gold); }
.two-col { display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; }
.panel { background:var(--white); border:0.5px solid var(--border); padding:1.5rem; }
.panel-title { font-size:0.7rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--muted); margin-bottom:1.2rem; padding-bottom:0.8rem; border-bottom:0.5px solid var(--border); }
.mini-list-item { display:flex; align-items:center; gap:0.8rem; padding:0.65rem 0; border-bottom:0.5px solid var(--border); }
.mini-list-item:last-child { border-bottom:none; }
.mini-avatar { width:32px;height:32px;border-radius:50%;object-fit:cover;border:1px solid var(--border); }
.mini-info { flex:1; }
.mini-name { font-size:0.85rem; font-weight:500; }
.mini-sub { font-size:0.72rem; color:var(--muted); }
.hotel-thumb { width:42px;height:32px;object-fit:cover;border:0.5px solid var(--border); }
{% endblock %}

{% block body %}
<div class="dashboard">
    <div class="page-header">
        <div class="section-tag">Overview</div>
        <h1>Admin <em style="font-style:italic;color:var(--gold);">Dashboard</em></h1>
        <p class="text-muted" style="font-size:0.88rem;margin-top:0.3rem;">
            Welcome back, {{ app.user.fullName }}
        </p>
    </div>

    {# ── Stats ── #}
    <div class="stats-grid">
        <div class="stat-card gold">
            <div class="stat-num">{{ total_hotels }}</div>
            <div class="stat-label">Hotels Listed</div>
        </div>
        <div class="stat-card">
            <div class="stat-num">{{ total_users }}</div>
            <div class="stat-label">Total Users</div>
        </div>
        <div class="stat-card">
            <div class="stat-num">{{ total_clients }}</div>
            <div class="stat-label">Clients</div>
        </div>
        <div class="stat-card">
            <div class="stat-num">{{ total_admins }}</div>
            <div class="stat-label">Admins</div>
        </div>
    </div>

    {# ── Quick actions ── #}
    <div style="display:flex;gap:1rem;margin-bottom:2.5rem;">
        <a href="{{ path('admin_hotel_new') }}" class="btn btn-primary">+ Add Hotel</a>
        <a href="{{ path('admin_user_new') }}" class="btn btn-ghost">+ Add User</a>
        <a href="{{ path('admin_hotel_index') }}" class="btn btn-ghost">View All Hotels</a>
        <a href="{{ path('admin_user_index') }}" class="btn btn-ghost">View All Users</a>
    </div>

    {# ── Recent data panels ── #}
    <div class="two-col">

        {# Recent Users #}
        <div class="panel">
            <div class="panel-title">Recent Users</div>
            {% for user in recent_users %}
            <div class="mini-list-item">
                <img src="{{ user.avatarUrl }}" alt="{{ user.username }}" class="mini-avatar">
                <div class="mini-info">
                    <div class="mini-name">
                        {{ user.fullName }}
                        {% if user.isBlocked() %}<span class="badge badge-blocked" style="margin-left:0.3rem;">Blocked</span>{% endif %}
                    </div>
                    <div class="mini-sub">{{ user.email }} · {{ user.createdAt|date('d M Y') }}</div>
                </div>
                <span class="badge {{ user.isAdmin() ? 'badge-admin' : 'badge-client' }}">
                    {{ user.role }}
                </span>
            </div>
            {% else %}
            <p class="text-muted" style="font-size:0.85rem;">No users yet.</p>
            {% endfor %}
            <a href="{{ path('admin_user_index') }}" class="btn btn-ghost btn-sm mt-3">View All →</a>
        </div>

        {# Recent Hotels #}
        <div class="panel">
            <div class="panel-title">Recent Hotels</div>
            {% for hotel in recent_hotels %}
            <div class="mini-list-item">
                <img src="{{ hotel.mainImageUrl }}" alt="{{ hotel.name }}" class="hotel-thumb">
                <div class="mini-info">
                    <div class="mini-name">{{ hotel.name }}</div>
                    <div class="mini-sub">{{ hotel.city }}, {{ hotel.country }} · €{{ hotel.pricePerNight }}/night</div>
                </div>
                <span style="font-size:0.78rem;color:var(--gold);">★ {{ hotel.rating }}</span>
            </div>
            {% else %}
            <p class="text-muted" style="font-size:0.85rem;">No hotels yet.</p>
            {% endfor %}
            <a href="{{ path('admin_hotel_index') }}" class="btn btn-ghost btn-sm mt-3">View All →</a>
        </div>

    </div>
</div>
{% endblock %}
