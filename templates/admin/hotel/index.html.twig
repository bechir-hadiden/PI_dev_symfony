{% extends 'base.html.twig' %}
{% block title %}Hotels — Admin{% endblock %}

{% block extra_css %}
.content { padding: 2.5rem; }
.page-header { display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:2rem; }
.page-header h1 { font-size:2rem; }
.search-bar { display:flex;gap:0.6rem;margin-bottom:1.5rem; }
.search-bar input { flex:1;max-width:360px; }
.hotel-img { width:55px;height:42px;object-fit:cover;border:0.5px solid var(--border); }
.amenity-chip {
    display:inline-block;padding:0.15rem 0.5rem;
    font-size:0.65rem;letter-spacing:0.06em;text-transform:uppercase;
    background:rgba(184,150,62,0.1);color:var(--gold-dark);margin:0.1rem;
}
.actions-cell { display:flex;gap:0.4rem; }
{% endblock %}

{% block body %}
<div class="content">
    <div class="page-header">
        <div>
            <div class="section-tag">Hotel Management</div>
            <h1>Hotels <em style="font-style:italic;color:var(--gold);">Listings</em></h1>
        </div>
        <a href="{{ path('admin_hotel_new') }}" class="btn btn-primary">+ New Hotel</a>
    </div>

    {# Search #}
    <form method="get" class="search-bar">
        <input type="text" name="q" value="{{ query }}" class="form-control" placeholder="Search by name, city, country…">
        <button type="submit" class="btn btn-gold btn-sm">Search</button>
        {% if query %}<a href="{{ path('admin_hotel_index') }}" class="btn btn-ghost btn-sm">Clear</a>{% endif %}
    </form>

    <div class="card table-wrap">
        <table>
            <thead>
                <tr>
                    <th></th>
                    <th>Hotel</th>
                    <th>Location</th>
                    <th>Price/Night</th>
                    <th>Rating</th>
                    <th>Amenities</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for hotel in hotels %}
                <tr>
                    <td>
                        <img src="{{ hotel.mainImageUrl }}" alt="{{ hotel.name }}" class="hotel-img">
                    </td>
                    <td>
                        <div style="font-weight:500;">{{ hotel.name }}</div>
                        <div style="font-size:0.75rem;color:var(--muted);">{{ hotel.city }}, {{ hotel.country }}</div>
                    </td>
                    <td style="font-size:0.83rem;color:var(--muted);">{{ hotel.location }}</td>
                    <td>
                        <strong style="color:var(--gold);">€{{ hotel.pricePerNight }}</strong>
                    </td>
                    <td>
                        <span style="color:var(--gold);font-size:0.85rem;">★ {{ hotel.rating }}</span>
                        <div style="font-size:0.7rem;color:var(--muted);">({{ hotel.reviewCount }} reviews)</div>
                    </td>
                    <td>
                        {% for amenity in hotel.amenities|slice(0, 3) %}
                            <span class="amenity-chip">{{ amenity.amenityName }}</span>
                        {% endfor %}
                        {% if hotel.amenities|length > 3 %}
                            <span class="amenity-chip" style="opacity:0.6;">+{{ hotel.amenities|length - 3 }}</span>
                        {% endif %}
                    </td>
                    <td>
                        <div class="actions-cell">
                            <a href="{{ path('admin_hotel_show', {id: hotel.id}) }}" class="btn btn-ghost btn-xs">View</a>
                            <a href="{{ path('admin_hotel_edit', {id: hotel.id}) }}" class="btn btn-outline btn-xs">Edit</a>
                            <form id="del-hotel-{{ hotel.id }}" method="post" action="{{ path('admin_hotel_delete', {id: hotel.id}) }}" style="display:inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_hotel_' ~ hotel.id) }}">
                                <button
                                    type="button"
                                    class="btn btn-danger btn-xs"
                                    onclick="confirmDelete('del-hotel-{{ hotel.id }}', 'Delete «{{ hotel.name }}»? This cannot be undone.')"
                                >
                                    Delete
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="7" style="text-align:center;padding:3rem;color:var(--muted);">
                        {% if query %}
                            No hotels found matching "{{ query }}".
                        {% else %}
                            No hotels yet. <a href="{{ path('admin_hotel_new') }}" style="color:var(--gold);">Add the first one →</a>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
