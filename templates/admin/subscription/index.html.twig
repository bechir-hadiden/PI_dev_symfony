{% extends 'BackOffice/base_admin.html.twig' %}

{% block title %}Gestion Abonnements – Admin{% endblock %}
{% block page_title %}Moniteur de revenus Premium{% endblock %}

{% block body %}
<div class="stat-row">
    <div class="stat-card">
        <div class="stat-icon gold"><i class="fas fa-crown"></i></div>
        <div>
            <div class="stat-value">{{ stats.total_count }}</div>
            <div class="stat-label">Total Abonnés</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="fas fa-check-circle"></i></div>
        <div>
            <div class="stat-value">{{ stats.total_active }}</div>
            <div class="stat-label">Actifs</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon blue"><i class="fas fa-wallet"></i></div>
        <div>
            <div class="stat-value">{{ stats.total_revenue|number_format(2, ',', ' ') }} <small>DT</small></div>
            <div class="stat-label">Revenus Actuels</div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h2><i class="fas fa-list-ul" style="color:var(--gold);margin-right:.5rem"></i>Journal des membres premium</h2>
        <div class="search-premium" style="position: relative; width: 250px;">
            <i class="fas fa-search" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--muted); font-size: 0.8rem;"></i>
            <input type="text" placeholder="Filtrer..." style="padding-left: 32px; font-size: 0.8rem;">
        </div>
    </div>
    <div class="card-body" style="padding:0">
        <table>
            <thead>
                <tr>
                    <th class="ps-4">Membre</th>
                    <th>Plan</th>
                    <th>Validité</th>
                    <th>Statut</th>
                    <th>Progression</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% if subscriptions is empty %}
                    <tr>
                        <td colspan="6" style="padding:3rem;text-align:center;color:var(--muted)">
                            <i class="fas fa-crown" style="font-size:3rem;opacity:.2;display:block;margin-bottom:1rem"></i>
                            Aucun abonnement enregistré pour le moment.
                        </td>
                    </tr>
                {% else %}
                    {% for s in subscriptions %}
                    <tr>
                        <td class="ps-4">
                            <div style="display:flex; align-items:center; gap:0.8rem">
                                <div style="width:36px; height:36px; background:var(--navy); color:var(--gold); border-radius:10px; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:0.9rem">
                                    {{ s.user.email|slice(0, 1)|upper }}
                                </div>
                                <div>
                                    <div style="font-weight:700; color:var(--navy); font-size:0.85rem">{{ s.user.email }}</div>
                                    <div style="font-size:0.65rem; color:var(--muted)">ID: #{{ s.id }}</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="badge" style="background: {{ s.plan == 'premium' ? 'rgba(201,168,76,0.1)' : 'rgba(100,116,139,0.1)' }}; color: {{ s.plan == 'premium' ? 'var(--gold)' : 'var(--muted)' }}; text-transform: uppercase; font-size: 0.65rem;">
                                {{ s.plan }}
                            </span>
                        </td>
                        <td>
                            <div style="font-size: 0.75rem;">
                                <div style="color:var(--muted)">Fin :</div>
                                <div style="font-weight:700">{{ s.endDate|date('d/m/Y') }}</div>
                            </div>
                        </td>
                        <td>
                            {% if s.isActive %}
                                <span class="badge badge-confirm">Actif</span>
                            {% elseif s.status == 'suspended' %}
                                <span class="badge badge-pending">Suspendu</span>
                            {% else %}
                                <span class="badge badge-cancel">Expiré</span>
                            {% endif %}
                        </td>
                        <td style="width: 150px;">
                            <div style="font-size: 0.65rem; display: flex; justify-content: space-between; margin-bottom: 4px;">
                                <span style="font-weight: 700;">{{ s.getProgressPercentage }}%</span>
                                <span style="color: var(--muted);">{{ s.getRemainingDays }}j</span>
                            </div>
                            <div style="height: 6px; background: #f1f5f9; border-radius: 10px; overflow: hidden;">
                                <div style="width: {{ s.getProgressPercentage }}%; height: 100%; background: var(--gold); box-shadow: 0 2px 4px rgba(201,168,76,0.3);"></div>
                            </div>
                        </td>
                        <td class="text-end pe-4">
                            <div style="display:flex; gap:.4rem; justify-content: flex-end;">
                                {% if s.status == 'active' %}
                                    <form action="{{ path('app_admin_subscription_suspend', {id: s.id}) }}" method="POST">
                                        <button class="btn btn-sm btn-secondary" title="Suspendre">
                                            <i class="fas fa-pause" style="color: var(--yellow);"></i>
                                        </button>
                                    </form>
                                {% elseif s.status == 'suspended' %}
                                    <form action="{{ path('app_admin_subscription_activate', {id: s.id}) }}" method="POST">
                                        <button class="btn btn-sm btn-secondary" title="Réactiver">
                                            <i class="fas fa-play" style="color: var(--green);"></i>
                                        </button>
                                    </form>
                                {% endif %}
                                <button class="btn btn-sm btn-secondary" title="Paramètres">
                                    <i class="fas fa-cog"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                {% endif %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
