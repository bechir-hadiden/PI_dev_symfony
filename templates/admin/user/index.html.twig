{% extends 'base.html.twig' %}
{% block title %}Users — Admin{% endblock %}

{% block extra_css %}
.content { padding: 2.5rem; }
.page-header { display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:2rem; }
.page-header h1 { font-size:2rem; }
.avatar-sm { width:34px;height:34px;border-radius:50%;object-fit:cover;border:1.5px solid var(--border); }
.actions-cell { display:flex;gap:0.4rem;flex-wrap:wrap; }
.blocked-row td { opacity: 0.6; }
{% endblock %}

{% block body %}
<div class="content">
    <div class="page-header">
        <div>
            <div class="section-tag">User Management</div>
            <h1>Users <em style="font-style:italic;color:var(--gold);">Directory</em></h1>
        </div>
        <a href="{{ path('admin_user_new') }}" class="btn btn-primary">+ New User</a>
    </div>

    {# Search #}
    <form method="get" style="display:flex;gap:0.6rem;margin-bottom:1.5rem;">
        <input type="text" name="q" value="{{ query }}" class="form-control" style="max-width:360px;" placeholder="Search by name, username, email…">
        <button type="submit" class="btn btn-gold btn-sm">Search</button>
        {% if query %}<a href="{{ path('admin_user_index') }}" class="btn btn-ghost btn-sm">Clear</a>{% endif %}
    </form>

    <div class="card table-wrap">
        <table>
            <thead>
                <tr>
                    <th></th>
                    <th>User</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Joined</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                <tr class="{{ user.isBlocked ? 'blocked-row' : '' }}">
                    <td>
                        <img src="{{ user.avatarUrl }}" alt="{{ user.username }}" class="avatar-sm">
                    </td>
                    <td>
                        <div style="font-weight:500;">{{ user.fullName }}</div>
                        <div style="font-size:0.75rem;color:var(--muted);">@{{ user.username }}</div>
                    </td>
                    <td style="font-size:0.83rem;">{{ user.email }}</td>
                    <td>
                        <span class="badge {{ user.isAdmin() ? 'badge-admin' : 'badge-client' }}">
                            {{ user.role }}
                        </span>
                    </td>
                    <td>
                        {% if user.isBlocked %}
                            <span class="badge badge-blocked">Blocked</span>
                        {% else %}
                            <span class="badge badge-active">Active</span>
                        {% endif %}
                    </td>
                    <td style="font-size:0.8rem;color:var(--muted);">
                        {{ user.createdAt ? user.createdAt|date('d M Y') : '—' }}
                    </td>
                    <td>
                        <div class="actions-cell">
                            <a href="{{ path('admin_user_show', {id: user.id}) }}" class="btn btn-ghost btn-xs">View</a>
                            <a href="{{ path('admin_user_edit', {id: user.id}) }}" class="btn btn-outline btn-xs">Edit</a>

                            {# Block / Unblock #}
                            {% if user != app.user %}
                            <form id="block-{{ user.id }}" method="post" action="{{ path('admin_user_toggle_block', {id: user.id}) }}" style="display:inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('toggle_block_' ~ user.id) }}">
                                <button
                                    type="button"
                                    class="btn btn-xs {{ user.isBlocked ? 'btn-gold' : 'btn-ghost' }}"
                                    style="{{ not user.isBlocked ? 'border-color:var(--danger);color:var(--danger);' : '' }}"
                                    onclick="confirmDelete('block-{{ user.id }}', '{{ user.isBlocked ? 'Unblock' : 'Block' }} user @{{ user.username }}?')"
                                    title="{{ user.isBlocked ? 'Unblock user' : 'Block user' }}"
                                >
                                    {{ user.isBlocked ? 'Unblock' : 'Block' }}
                                </button>
                            </form>

                            {# Delete #}
                            <form id="del-user-{{ user.id }}" method="post" action="{{ path('admin_user_delete', {id: user.id}) }}" style="display:inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ user.id) }}">
                                <button
                                    type="button"
                                    class="btn btn-danger btn-xs"
                                    onclick="confirmDelete('del-user-{{ user.id }}', 'Delete user @{{ user.username }}? This cannot be undone.')"
                                >
                                    Delete
                                </button>
                            </form>
                            {% else %}
                            <span style="font-size:0.7rem;color:var(--muted);">(you)</span>
                            {% endif %}
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="7" style="text-align:center;padding:3rem;color:var(--muted);">
                        {% if query %}
                            No users found matching "{{ query }}".
                        {% else %}
                            No users found.
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
